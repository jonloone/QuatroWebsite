---
import type { Locale } from '@/lib/i18n'
import { t, localizeHref } from '@/lib/i18n'
import QuatroLogo from '@/components/QuatroLogo.astro'
import { getFooterNavigation } from '@/lib/navigation'

interface Props {
  lang?: Locale
}

const { lang = 'en' } = Astro.props
const footerNav = getFooterNavigation(lang)
const columns = Object.values(footerNav)
const currentYear = new Date().getFullYear()
const homeHref = lang === 'es' ? '/es/' : '/'
---

<footer class="bg-black">
  <div class="py-16 text-neutral-50">
    <div class="mx-auto max-w-7xl px-6 lg:px-10 flex flex-col gap-16">
      <!-- Logo and tagline -->
      <div>
        <a href={homeHref} class="flex items-center mb-4" aria-label={t('nav.home', lang)}>
          <QuatroLogo light class="h-7 w-auto" />
        </a>
        <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-white/40 whitespace-pre-line">
          {t('footer.tagline', lang)}
        </p>
      </div>

      <!-- Link columns -->
      <nav class="grid grid-cols-2 gap-8 sm:grid-cols-4">
        {columns.map((column) => (
          <div>
            <h3 class="font-mono text-[10px] uppercase tracking-[0.1em] text-white/60">{column.title}</h3>
            <ul role="list" class="mt-3 flex flex-col gap-2.5">
              {column.items.map((item) => (
                <li>
                  <a href={item.href} class="font-sans text-sm text-white/40 hover:text-white/80 transition-colors duration-150">
                    {item.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </nav>

      <!-- Copyright -->
      <div class="pt-8 flex flex-col sm:flex-row items-center justify-between gap-4" style="border-top: 1px solid rgba(255,255,255,0.1);">
        <p class="font-mono text-[10px] uppercase tracking-[0.05em] text-white/30">
          &copy; {currentYear} Quatro. {t('footer.copyright', lang)}
        </p>
        <div class="flex items-center gap-6">
          <a href={localizeHref('/legal/privacy', lang)} class="font-mono text-[10px] uppercase tracking-[0.05em] text-white/30 hover:text-white/60 transition-colors duration-150">{t('footer.privacy', lang)}</a>
          <a href={localizeHref('/legal/terms', lang)} class="font-mono text-[10px] uppercase tracking-[0.05em] text-white/30 hover:text-white/60 transition-colors duration-150">{t('footer.terms', lang)}</a>
          <a href={localizeHref('/legal/security', lang)} class="font-mono text-[10px] uppercase tracking-[0.05em] text-white/30 hover:text-white/60 transition-colors duration-150">{t('footer.security', lang)}</a>
        </div>
      </div>
    </div>
  </div>
</footer>
