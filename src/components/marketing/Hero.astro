---
import Button from '@/components/ui/Button.astro'
import Container from '@/components/ui/Container.astro'

interface Props {
  eyebrow?: string
  title: string
  description?: string
  primaryCta?: { label: string; href: string }
  microcopy?: string
  variant?: 'light' | 'dark'
  backgroundImage?: string
  class?: string
}

const {
  eyebrow,
  title,
  description,
  primaryCta,
  microcopy,
  variant = 'light',
  backgroundImage,
  class: className,
} = Astro.props

const isLight = variant === 'light'
---

<section data-hero data-hero-section class:list={[className]}>
  {isLight ? (
    <!-- Light variant: neutral background, centered editorial -->
    <div class="relative overflow-hidden bg-neutral-100 min-h-screen">
      <div class="relative px-8 lg:px-16 min-h-screen flex flex-col">
        <div class="mx-auto max-w-7xl w-full flex-1 flex flex-col">
          <!-- Text Content — centered editorial layout -->
          <div data-hero-text class="flex-1 flex shrink-0 flex-col items-center justify-center text-center gap-6 pt-[max(18vh,140px)] pb-16">
            {eyebrow && (
              <div class="font-mono text-[10px] uppercase tracking-[0.1em] text-neutral-400">
                {eyebrow}
              </div>
            )}
            <h1 class="max-w-4xl font-sans font-light text-4xl tracking-tight text-neutral-800 sm:text-5xl lg:text-6xl xl:text-7xl leading-[1.05]">
              {title}
            </h1>
            {description && (
              <div class="max-w-2xl text-lg lg:text-xl leading-relaxed text-neutral-500">
                {description}
              </div>
            )}
            {primaryCta && (
              <div class="flex flex-col items-center gap-3 mt-4">
                <Button href={primaryCta.href} size="lg" color="dark">
                  {primaryCta.label}
                </Button>
                {microcopy && (
                  <div class="text-sm text-neutral-400">{microcopy}</div>
                )}
              </div>
            )}
          </div>

          <!-- Demo slot -->
          <div class="mx-auto max-w-5xl pb-8">
            <slot name="demo" />
          </div>
        </div>
      </div>
    </div>
  ) : (
    <!-- Dark variant: dark background with image overlay, centered editorial -->
    <div
      class="relative overflow-hidden bg-cover bg-center min-h-screen"
      style={`background-image: url('${backgroundImage || '/images/bg555.png'}')`}
    >
      <!-- Vignette overlay -->
      <div class="absolute inset-0" style="background: radial-gradient(ellipse 70% 60% at 50% 45%, transparent 0%, rgba(15,23,42,0.45) 60%, rgba(15,23,42,0.8) 100%);"></div>
      <div class="absolute inset-0 bg-neutral-900/40"></div>

      <!-- Hero image - anchored to bottom right, sized to fill -->
      <div class="absolute bottom-0 right-0 w-[60%] max-w-5xl pointer-events-none hidden lg:block">
        <slot name="demo" />
      </div>

      <div class="relative px-8 lg:px-16 min-h-screen flex flex-col">
        <div class="mx-auto max-w-7xl w-full flex-1 flex flex-col">
          <!-- Text Content — centered editorial layout -->
          <div data-hero-text class="flex-1 flex shrink-0 flex-col items-center justify-center text-center gap-6 pt-[max(18vh,140px)] pb-16">
            {eyebrow && (
              <div class="font-mono text-[10px] uppercase tracking-[0.1em] text-white/40">
                {eyebrow}
              </div>
            )}
            <h1 class="max-w-4xl font-sans font-light text-4xl tracking-tight text-white sm:text-5xl lg:text-6xl xl:text-7xl leading-[1.05]">
              {title}
            </h1>
            {description && (
              <div class="max-w-2xl text-lg lg:text-xl leading-relaxed text-white/60">
                {description}
              </div>
            )}
            {primaryCta && (
              <div class="flex flex-col items-center gap-3 mt-4">
                <Button href={primaryCta.href} size="lg">
                  {primaryCta.label}
                </Button>
                {microcopy && (
                  <div class="text-sm text-white/40">{microcopy}</div>
                )}
              </div>
            )}
          </div>
        </div>
      </div>
    </div>
  )}
  <slot name="footer" />
</section>

<script>
  const heroSection = document.querySelector('[data-hero-section]');
  const heroText = document.querySelector('[data-hero-text]');
  if (heroSection && heroText) {
    const heroHeight = heroSection.getBoundingClientRect().height;
    let ticking = false;
    window.addEventListener('scroll', () => {
      if (!ticking) {
        requestAnimationFrame(() => {
          const scrollY = window.scrollY;
          if (scrollY < heroHeight) {
            const progress = Math.min(scrollY / (heroHeight * 0.6), 1);
            (heroText as HTMLElement).style.transform = `translateY(${-scrollY * 0.3}px)`;
            (heroText as HTMLElement).style.opacity = String(1 - progress);
          }
          ticking = false;
        });
        ticking = true;
      }
    }, { passive: true });
  }
</script>
