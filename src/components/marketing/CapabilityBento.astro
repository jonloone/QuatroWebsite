---
/**
 * CapabilityBento — Dark bento grid for industry capabilities
 * Inspired by Tailark Features 8: 3-col top row, 2-col bottom rows
 * Adapts to 6-8 capabilities automatically
 */
interface Capability {
  name: string
  description: string
  outcome?: string
  tier?: string
  featured?: boolean
}

interface Props {
  title?: string
  subtitle?: string
  capabilities: Capability[]
  class?: string
}

const {
  title,
  subtitle,
  capabilities,
  class: className,
} = Astro.props

// Split capabilities into rows:
// Row 1: first 3 (equal thirds)
// Row 2: next 2 (halves, larger treatment)
// Row 3: remaining (thirds or halves)
const row1 = capabilities.slice(0, 3)
const row2 = capabilities.slice(3, 5)
const row3 = capabilities.slice(5)
---

<section
  class:list={['relative py-20 lg:py-28 px-6 overflow-hidden', className]}
  style="background: #0a0a0a;"
>
  <!-- Subtle grain overlay -->
  <div class="absolute inset-0 opacity-[0.03]" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%270 0 256 256%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cfilter id=%27noise%27%3E%3CfeTurbulence type=%27fractalNoise%27 baseFrequency=%270.65%27 numOctaves=%273%27 stitchTiles=%27stitch%27/%3E%3C/filter%3E%3Crect width=%27100%25%27 height=%27100%25%27 filter=%27url(%23noise)%27/%3E%3C/svg%3E');"></div>

  <div class="relative z-10 mx-auto max-w-6xl">

    {(title || subtitle) && (
      <div class="mb-12 fade-up">
        {title && (
          <h2 class="font-display text-xl font-bold" style="color: var(--color-forest);">
            {title}
          </h2>
        )}
        {subtitle && (
          <p class="mt-4 font-sans text-lg leading-relaxed max-w-3xl text-white/50">
            {subtitle}
          </p>
        )}
      </div>
    )}

    <!-- Bento Grid -->
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-3 fade-up">

      <!-- Row 1: Three equal cards -->
      {row1.map((cap) => (
        <div
          class="group p-6 flex flex-col justify-between min-h-[220px] transition-colors duration-300 hover:bg-white/[0.06]"
          style="border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.03);"
        >

          <div class="mt-auto">
            <h3 class="font-display text-lg font-bold text-white">
              {cap.name}
            </h3>
            <p class="mt-2 font-sans text-sm leading-relaxed text-white/50">
              {cap.description}
            </p>
            {cap.outcome && (
              <p class="mt-3 font-display text-sm font-bold" style="color: var(--color-forest);">
                {cap.outcome}
              </p>
            )}
          </div>
        </div>
      ))}
    </div>

    <!-- Row 2: Two wider cards -->
    {row2.length > 0 && (
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-3 mt-3 fade-up">
        {row2.map((cap) => (
          <div
            class="group p-6 sm:p-8 flex flex-col justify-between min-h-[240px] transition-colors duration-300 hover:bg-white/[0.06]"
            style="border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.03);"
          >
            <div class="mt-auto">
              <h3 class="font-display text-xl font-bold text-white">
                {cap.name}
              </h3>
              <p class="mt-2 font-sans text-sm leading-relaxed text-white/50">
                {cap.description}
              </p>
              {cap.outcome && (
                <p class="mt-3 font-display text-sm font-bold" style="color: var(--color-forest);">
                  {cap.outcome}
                </p>
              )}
            </div>
          </div>
        ))}
      </div>
    )}

    <!-- Row 3: Remaining capabilities -->
    {row3.length > 0 && (
      <div class:list={[
        'grid gap-3 mt-3 fade-up',
        row3.length === 1 ? 'grid-cols-1' : row3.length === 2 ? 'grid-cols-1 sm:grid-cols-2' : 'grid-cols-1 sm:grid-cols-3'
      ]}>
        {row3.map((cap) => (
          <div
            class="group p-6 flex flex-col justify-between min-h-[220px] transition-colors duration-300 hover:bg-white/[0.06]"
            style="border: 1px solid rgba(255,255,255,0.08); background: rgba(255,255,255,0.03);"
          >
            <div class="mt-auto">
              <h3 class="font-display text-lg font-bold text-white">
                {cap.name}
              </h3>
              <p class="mt-2 font-sans text-sm leading-relaxed text-white/50">
                {cap.description}
              </p>
              {cap.outcome && (
                <p class="mt-3 font-display text-sm font-bold" style="color: var(--color-forest);">
                  {cap.outcome}
                </p>
              )}
            </div>
          </div>
        ))}
      </div>
    )}
  </div>
</section>
