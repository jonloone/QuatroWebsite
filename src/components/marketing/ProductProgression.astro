---
interface Props {
  current?: string
}

const { current } = Astro.props

const products = [
  {
    step: 1,
    name: 'See',
    slug: 'see',
    tagline: 'Complete operational picture across every system. 9,000+ integrations from 1,000+ vendors.',
    href: '/network',
  },
  {
    step: 2,
    name: 'Understand',
    slug: 'understand',
    tagline: 'Predictive intelligence that forecasts failures before they happen. AI decision support.',
    href: '/network',
  },
  {
    step: 3,
    name: 'Orchestrate',
    slug: 'orchestrate',
    tagline: 'End-to-end process orchestration across systems and teams. The entire operation as one.',
    href: '/network',
  },
]

function getStepState(slug: string): 'completed' | 'active' | 'upcoming' {
  if (!current) return 'upcoming'
  const currentIndex = products.findIndex((p) => p.slug === current)
  const thisIndex = products.findIndex((p) => p.slug === slug)
  if (thisIndex < currentIndex) return 'completed'
  if (thisIndex === currentIndex) return 'active'
  return 'upcoming'
}
---

<div>
  {/* ── Stepper bar (desktop) ── */}
  <div class="hidden sm:block">
    <div class="relative flex items-center justify-between">
      {/* Horizontal line behind badges */}
      <div class="absolute inset-x-0 top-1/2 h-px -translate-y-1/2 bg-neutral-300" aria-hidden="true" />

      {products.map((product) => {
        const state = getStepState(product.slug)
        return (
          <div class="relative z-10 flex flex-col items-center">
            {/* Step badge */}
            <span
              class:list={[
                'inline-flex items-center rounded-full px-3 py-1 text-xs font-display font-bold tracking-wide',
                state === 'active'
                  ? 'bg-brand-500 text-white'
                  : state === 'completed'
                    ? 'bg-brand-100 text-brand-700'
                    : 'border border-neutral-300 bg-white text-neutral-400',
              ]}
            >
              Step {product.step}
            </span>
            {/* Diamond indicator */}
            <div
              class:list={[
                'mt-3 h-3 w-3 rotate-45',
                state === 'active'
                  ? 'bg-brand-500'
                  : state === 'completed'
                    ? 'bg-brand-300'
                    : 'bg-neutral-300',
              ]}
              aria-hidden="true"
            />
          </div>
        )
      })}
    </div>
  </div>

  {/* ── Cards ── */}
  <div class="mt-8 grid gap-px overflow-hidden rounded-lg border border-neutral-200 bg-neutral-200 sm:grid-cols-3">
    {products.map((product) => {
      const state = getStepState(product.slug)
      const isActive = state === 'active'
      return (
        <a
          href={product.href}
          class:list={[
            'group relative flex flex-col p-6 transition-colors',
            isActive
              ? 'bg-brand-50'
              : 'bg-white hover:bg-neutral-50',
          ]}
        >
          {/* Mobile step label */}
          <span
            class:list={[
              'mb-2 inline-flex w-fit items-center rounded-full px-2.5 py-0.5 text-[11px] font-display font-bold tracking-wide sm:hidden',
              isActive
                ? 'bg-brand-500 text-white'
                : state === 'completed'
                  ? 'bg-brand-100 text-brand-700'
                  : 'border border-neutral-300 bg-white text-neutral-400',
            ]}
          >
            Step {product.step}
          </span>

          <h3
            class:list={[
              'font-display text-lg font-bold',
              isActive ? 'text-brand-700' : 'text-neutral-800',
            ]}
          >
            {product.name}
          </h3>
          <p class="mt-1.5 text-sm leading-relaxed text-neutral-500">
            {product.tagline}
          </p>
          <p
            class:list={[
              'mt-4 text-sm font-display font-medium',
              isActive
                ? 'text-brand-600'
                : 'text-brand-500 opacity-0 transition-opacity group-hover:opacity-100',
            ]}
          >
            {isActive ? 'You are here' : 'Learn more \u2192'}
          </p>
        </a>
      )
    })}
  </div>
</div>
