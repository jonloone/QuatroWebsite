---
import Container from '@/components/ui/Container.astro'

interface Props {
  eyebrow?: string
  title?: string
  description?: string
  primaryCta?: { label: string; href: string }
  secondaryCta?: { label: string; href: string } | null
  textLink?: { label: string; href: string }
  microcopy?: string
  illustration?: string
  class?: string
}

const {
  eyebrow,
  title = 'Ready to transform your operations?',
  description,
  primaryCta = { label: 'Schedule a Demo', href: '/contact/demo' },
  secondaryCta = null,
  textLink,
  microcopy,
  illustration,
  class: className,
} = Astro.props
---

<section class:list={['relative overflow-hidden py-12 lg:py-20', className]} style="border-top: 1px solid var(--color-structure);">
  <Container>
    <div class="relative overflow-hidden py-16 lg:py-24 px-8 lg:px-16">
      <!-- Background image -->
      <div class="absolute inset-0">
        <img src="/images/cta.png" alt="" class="h-full w-full object-cover" />
        <div class="absolute inset-0" style="background: rgba(0,0,0,0.75);"></div>
      </div>

      <div class="relative z-10">
        <div class="mx-auto max-w-2xl text-center">
          {eyebrow && (
            <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-white/60 mb-6">
              {eyebrow}
            </p>
          )}

          <h2 class="font-sans text-3xl lg:text-5xl font-light text-white leading-tight">
            {title}
          </h2>

          {description && (
            <p class="mt-6 font-sans text-lg text-white/70 leading-relaxed">
              {description}
            </p>
          )}

          <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
            <a
              href={primaryCta.href}
              class="font-mono text-xs uppercase tracking-[0.05em] px-8 py-4 transition-colors duration-300 ease-linear hover:opacity-90"
              style="background-color: white; color: var(--color-forest);"
            >
              {primaryCta.label}
            </a>
            {secondaryCta && (
              <a
                href={secondaryCta.href}
                class="font-mono text-xs uppercase tracking-[0.05em] px-8 py-4 text-white transition-colors duration-300 ease-linear hover:bg-white/10"
                style="border: 1px solid rgba(255,255,255,0.2);"
              >
                {secondaryCta.label}
              </a>
            )}
            {!secondaryCta && textLink && (
              <a href={textLink.href} class="font-mono text-xs uppercase tracking-[0.05em] text-white/60 transition hover:text-white">
                {textLink.label} &rarr;
              </a>
            )}
          </div>

          {microcopy && (
            <p class="mt-4 font-mono text-xs text-white/40">{microcopy}</p>
          )}
        </div>

        <!-- Trust bar -->
        <div class="mt-14 pt-8 flex flex-wrap items-center justify-center gap-8" style="border-top: 1px solid rgba(255,255,255,0.15);">
          <a href="/resources/documentation" class="font-mono text-xs uppercase tracking-wider text-white/50 hover:text-white/80 transition-colors duration-300 ease-linear">Documentation</a>
          <a href="/platform" class="font-mono text-xs uppercase tracking-wider text-white/50 hover:text-white/80 transition-colors duration-300 ease-linear">API</a>
          <a href="/legal/security" class="font-mono text-xs uppercase tracking-wider text-white/50 hover:text-white/80 transition-colors duration-300 ease-linear">Security</a>
        </div>
      </div>
    </div>
  </Container>
</section>
