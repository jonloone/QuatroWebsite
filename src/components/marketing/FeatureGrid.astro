---
import Database from 'phosphor-astro/Database.astro'
import ChartLine from 'phosphor-astro/ChartLine.astro'
import Tag from 'phosphor-astro/Tag.astro'
import Cpu from 'phosphor-astro/Cpu.astro'
import Code from 'phosphor-astro/Code.astro'
import ShieldCheck from 'phosphor-astro/ShieldCheck.astro'
import Monitor from 'phosphor-astro/Monitor.astro'
import Wrench from 'phosphor-astro/Wrench.astro'
import Warning from 'phosphor-astro/Warning.astro'
import Layout from 'phosphor-astro/Layout.astro'
import Phone from 'phosphor-astro/Phone.astro'
import MapTrifold from 'phosphor-astro/MapTrifold.astro'
import TreeStructure from 'phosphor-astro/TreeStructure.astro'
import Users from 'phosphor-astro/Users.astro'
import Truck from 'phosphor-astro/Truck.astro'
import Stack from 'phosphor-astro/Stack.astro'
import Link from 'phosphor-astro/Link.astro'
import Globe from 'phosphor-astro/Globe.astro'
import Gear from 'phosphor-astro/Gear.astro'
import ChartBar from 'phosphor-astro/ChartBar.astro'

const iconMap: Record<string, any> = {
  database: Database,
  chart: ChartLine,
  tag: Tag,
  cpu: Cpu,
  code: Code,
  shield: ShieldCheck,
  monitor: Monitor,
  wrench: Wrench,
  alert: Warning,
  layout: Layout,
  phone: Phone,
  map: MapTrifold,
  workflow: TreeStructure,
  users: Users,
  truck: Truck,
  layers: Stack,
  link: Link,
  globe: Globe,
  cog: Gear,
  'chart-bar': ChartBar,
}

interface Feature {
  icon?: string
  image?: string
  name: string
  description?: string
  href?: string
  keywords?: string[]
}

interface Props {
  title?: string
  subtitle?: string
  features: Feature[]
  columns?: 2 | 3 | 4
  dark?: boolean
}

const { title, subtitle, features, columns = 3, dark = false } = Astro.props

const gridClasses = {
  2: 'sm:grid-cols-2',
  3: 'sm:grid-cols-2 lg:grid-cols-3',
  4: 'sm:grid-cols-2 lg:grid-cols-4',
}
---

<div>
  {(title || subtitle) && (
    <div class="mb-12 text-center">
      {title && (
        <h2 class:list={[
          'font-display text-2xl font-bold tracking-tight sm:text-3xl',
          dark ? 'text-white' : 'text-neutral-800'
        ]}>{title}</h2>
      )}
      {subtitle && (
        <p class:list={[
          'mt-4 text-lg',
          dark ? 'text-neutral-300' : 'text-neutral-600'
        ]}>{subtitle}</p>
      )}
    </div>
  )}
  <div class:list={['grid gap-8', gridClasses[columns]]}>
    {features.map((feature) => {
      const Tag = feature.href ? 'a' : 'div'
      const linkProps = feature.href
        ? { href: feature.href }
        : {}
      const baseClass = dark
        ? 'p-6'
        : 'p-6'
      const baseStyle = dark
        ? 'border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.05);'
        : 'border: 1px solid rgba(226,232,240,1);'
      const linkClass = feature.href
        ? dark
          ? 'group p-6 transition hover:border-brand-500/40'
          : 'group p-6 transition hover:border-brand-500/30'
        : baseClass
      const linkStyle = feature.href
        ? dark
          ? 'border: 1px solid rgba(255,255,255,0.1); background: rgba(255,255,255,0.05);'
          : 'border: 1px solid rgba(226,232,240,1);'
        : baseStyle

      const IconComponent = feature.icon ? iconMap[feature.icon] : null

      return (
        <Tag class={linkClass} style={linkStyle} {...linkProps}>
          {feature.image ? (
            <div class="mb-3 h-40 w-full overflow-hidden rounded-md">
              <img alt="" src={feature.image} class="h-full w-full object-cover" />
            </div>
          ) : IconComponent ? (
            <div class:list={[
              'mb-3 flex h-10 w-10 items-center justify-center rounded-md',
              dark ? 'bg-brand-500/20 text-brand-400' : 'bg-brand-50 text-brand-600'
            ]}>
              <IconComponent size={22} />
            </div>
          ) : null}
          <h3 class:list={[
            'text-base font-display font-semibold',
            dark ? 'text-white' : 'text-neutral-800'
          ]}>{feature.name}</h3>
          {feature.description && (
            <p class:list={[
              'mt-2 text-sm',
              dark ? 'text-neutral-400' : 'text-neutral-600'
            ]}>{feature.description}</p>
          )}
          {feature.keywords && feature.keywords.length > 0 && (
            <div class="mt-3 flex flex-wrap gap-1.5 opacity-0 transition-opacity group-hover:opacity-100">
              {feature.keywords.map((kw) => (
                <span class:list={[
                  'rounded-sm px-2 py-0.5 text-xs font-medium',
                  dark ? 'bg-brand-500/20 text-brand-400' : 'bg-brand-500/10 text-brand-600'
                ]}>
                  {kw}
                </span>
              ))}
            </div>
          )}
        </Tag>
      )
    })}
  </div>
</div>
