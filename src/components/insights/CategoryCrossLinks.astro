---
import { getCollection } from 'astro:content'
import { categoryMeta } from '@/lib/category-meta'

interface Props {
  currentCategory: string
}

const { currentCategory } = Astro.props

const allInsights = await getCollection('insights')

const otherCategories = Object.entries(categoryMeta)
  .filter(([slug]) => slug !== currentCategory)
  .map(([slug, meta]) => ({
    slug,
    ...meta,
    count: allInsights.filter(a => a.data.category === slug).length,
  }))
---

<section class="py-16 lg:py-20 px-6" style="border-top: 1px solid var(--color-structure);">
  <div class="mx-auto max-w-5xl">
    <p class="font-mono text-xs uppercase tracking-[0.1em] mb-8" style="color: var(--color-forest);">
      More from Insights
    </p>
    <div class="grid md:grid-cols-2 gap-6">
      {otherCategories.map(cat => (
        <a
          href={`/insights/${cat.slug}`}
          class="group block p-8 rounded-lg transition-all duration-300 hover:shadow-md"
          style="border: 1px solid var(--color-structure); background: white;"
        >
          <div class="flex items-center justify-between mb-3">
            <span class="font-mono text-[10px] uppercase tracking-[0.12em] px-2.5 py-1 rounded-full" style="color: var(--color-forest); background: rgba(15,76,58,0.06);">
              {cat.title}
            </span>
            <span class="font-mono text-[10px] uppercase tracking-[0.08em]" style="color: var(--color-neutral-400);">
              {cat.count} {cat.count === 1 ? 'article' : 'articles'}
            </span>
          </div>
          <p class="font-sans text-base leading-relaxed" style="color: var(--color-neutral-600);">
            {cat.description}
          </p>
          <p class="mt-4 font-mono text-xs uppercase tracking-[0.08em] transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);">
            Browse {cat.title.toLowerCase()} →
          </p>
        </a>
      ))}
    </div>
  </div>
</section>
