---
import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import SiteHeader from '@/components/layout/SiteHeader.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'

export async function getStaticPaths() {
  const insights = await getCollection('insights')
  return insights.map((article) => ({
    params: { slug: article.id.replace(/\.md$/, '') },
    props: { article },
  }))
}

const { article } = Astro.props
const { Content } = await article.render()
const { title, excerpt, category, industry, heroImage, author, publishDate, readingTime, tags } = article.data

// Get related articles (same industry or category, excluding current)
const allInsights = await getCollection('insights')
const related = allInsights
  .filter(a => a.id !== article.id && (a.data.industry === industry || a.data.category === category))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3)

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<BaseLayout
  title={`${title} — Quatro Insights`}
  description={excerpt}
  lang="en"
>
  <SiteHeader lang="en" />

  <!-- Article header -->
  <article class="pt-32 lg:pt-40 pb-16 lg:pb-20">

    <!-- Meta + Title -->
    <header class="px-6 mb-12 lg:mb-16">
      <div class="mx-auto max-w-3xl">
        <div class="flex items-center gap-3 mb-6">
          <a href="/insights" class="font-mono text-[10px] uppercase tracking-[0.1em] transition-colors duration-200 hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);">
            ← Insights
          </a>
        </div>
        <div class="flex items-center gap-3 mb-6">
          <span class="font-mono text-[10px] uppercase tracking-[0.12em] px-2.5 py-1 rounded-full" style="color: var(--color-forest); background: rgba(15,76,58,0.06);">
            {category.replace('-', ' ')}
          </span>
          {industry && (
            <span class="font-mono text-[10px] uppercase tracking-[0.08em]" style="color: var(--color-neutral-400);">
              {industry}
            </span>
          )}
        </div>
        <h1 class="font-sans font-light text-3xl sm:text-4xl lg:text-5xl leading-[1.15] tracking-tight" style="color: var(--color-neutral-800);">
          {title}
        </h1>
        <p class="mt-6 font-sans text-lg leading-relaxed" style="color: var(--color-neutral-500);">
          {excerpt}
        </p>
        <div class="mt-8 flex items-center gap-6 pb-8" style="border-bottom: 1px solid var(--color-structure);">
          <span class="font-mono text-[11px] uppercase tracking-[0.08em]" style="color: var(--color-neutral-400);">
            {author}
          </span>
          <span class="font-mono text-[11px] uppercase tracking-[0.08em]" style="color: var(--color-neutral-400);">
            {formattedDate}
          </span>
          {readingTime && (
            <span class="font-mono text-[11px] uppercase tracking-[0.08em]" style="color: var(--color-neutral-400);">
              {readingTime}
            </span>
          )}
        </div>
      </div>
    </header>

    <!-- Hero image -->
    {heroImage && (
      <div class="px-6 mb-12 lg:mb-16">
        <div class="mx-auto max-w-4xl">
          <div class="relative overflow-hidden rounded-lg aspect-[2/1]" style="background: var(--color-neutral-50);">
            <img src={heroImage} alt="" class="w-full h-full object-cover img-technical" />
          </div>
        </div>
      </div>
    )}

    <!-- Article body -->
    <div class="px-6">
      <div class="mx-auto max-w-3xl prose prose-neutral
        prose-headings:font-sans prose-headings:font-light prose-headings:tracking-tight
        prose-h2:text-2xl prose-h2:lg:text-3xl prose-h2:mt-12 prose-h2:mb-4
        prose-h3:text-lg prose-h3:lg:text-xl prose-h3:mt-8 prose-h3:mb-3
        prose-p:text-base prose-p:leading-[1.8] prose-p:mb-6
        prose-strong:font-medium
        prose-a:text-[var(--color-forest)] prose-a:no-underline hover:prose-a:underline
        prose-li:text-base prose-li:leading-[1.8]
        prose-blockquote:border-l-[var(--color-forest)] prose-blockquote:font-sans prose-blockquote:not-italic
      " style="color: var(--color-neutral-600); --tw-prose-headings: var(--color-neutral-800);">
        <Content />
      </div>
    </div>

    <!-- Tags -->
    {tags && tags.length > 0 && (
      <div class="px-6 mt-12">
        <div class="mx-auto max-w-3xl flex flex-wrap gap-2 pt-8" style="border-top: 1px solid var(--color-structure);">
          {tags.map(tag => (
            <span class="font-mono text-[10px] uppercase tracking-[0.1em] px-3 py-1.5 rounded-full" style="color: var(--color-neutral-500); border: 1px solid var(--color-structure);">
              {tag}
            </span>
          ))}
        </div>
      </div>
    )}
  </article>

  <!-- CTA Banner -->
  <section class="py-16 lg:py-20 px-6" style="background: var(--color-neutral-50); border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-sans text-2xl lg:text-3xl font-light tracking-tight" style="color: var(--color-neutral-800);">
        See it on your infrastructure.
      </h2>
      <p class="mt-4 font-sans text-base leading-relaxed" style="color: var(--color-neutral-500);">
        Start with the outcome that matters. We connect the systems. Your team works from the model.
      </p>
      <a
        href="/contact/demo"
        class="inline-flex items-center gap-2 mt-8 font-mono text-xs uppercase tracking-[0.08em] px-8 py-4 rounded-full transition-all duration-300 ease-out hover:scale-105"
        style="background-color: var(--color-forest); color: white;"
      >
        Schedule an Assessment
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </section>

  <!-- Related articles -->
  {related.length > 0 && (
    <section class="py-16 lg:py-20 px-6" style="border-top: 1px solid var(--color-structure);">
      <div class="mx-auto max-w-5xl">
        <p class="font-mono text-xs uppercase tracking-[0.1em] mb-8" style="color: var(--color-forest);">Related</p>
        <div class="grid md:grid-cols-3 gap-8">
          {related.map(rel => (
            <a href={`/insights/${rel.id.replace(/\.md$/, '')}`} class="group">
              <span class="font-mono text-[10px] uppercase tracking-[0.12em]" style="color: var(--color-neutral-400);">
                {rel.data.category.replace('-', ' ')}
              </span>
              <h3 class="mt-2 font-sans text-base font-light leading-[1.3] tracking-tight transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">
                {rel.data.title}
              </h3>
              <p class="mt-2 font-mono text-[10px] uppercase tracking-[0.08em]" style="color: var(--color-neutral-400);">
                {rel.data.readingTime}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <SiteFooter lang="en" />
</BaseLayout>
