---
import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import SiteHeader from '@/components/layout/SiteHeader.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
import DualCta from '@/components/marketing/DualCta.astro'
import { categoryMeta } from '@/lib/category-meta'

export async function getStaticPaths() {
  const insights = await getCollection('insights')
  return insights.map((article) => ({
    params: { slug: article.id.replace(/\.md$/, '') },
    props: { article },
  }))
}

const { article } = Astro.props
const { Content } = await article.render()
const { title, excerpt, category, industry, heroImage, author, publishDate, readingTime, tags } = article.data

// Get related articles (same industry or category, excluding current)
const allInsights = await getCollection('insights')
const related = allInsights
  .filter(a => a.id !== article.id && (a.data.industry === industry || a.data.category === category))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3)

const formattedDate = publishDate.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

const articleHref = (a: any) => `/insights/${a.id.replace(/\.md$/, '')}`
---

<BaseLayout
  title={`${title} — Quatro Insights`}
  description={excerpt}
  lang="en"
>
  <SiteHeader lang="en" />

  <article>
    <!-- Article header -->
    <header class="pt-[max(14vh,160px)] lg:pt-[max(16vh,192px)] pb-10 lg:pb-14 px-6">
      <div class="mx-auto max-w-3xl">
        <!-- Breadcrumb -->
        <div class="flex items-center gap-3 mb-8">
          <a href="/insights" class="font-mono text-[10px] uppercase tracking-[0.1em] transition-colors duration-200 hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);">
            Insights
          </a>
          <span class="font-mono text-[10px]" style="color: var(--color-neutral-300);">/</span>
          <a href={`/insights/${category}`} class="font-mono text-[10px] uppercase tracking-[0.1em] transition-colors duration-200 hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);">
            {categoryMeta[category]?.title || category.replace(/-/g, ' ')}
          </a>
        </div>

        <!-- Category + Industry -->
        <div class="flex items-center gap-3 mb-6">
          <span class="font-mono text-[10px] uppercase tracking-[0.12em]" style="color: var(--color-forest);">
            {category.replace(/-/g, ' ')}
          </span>
          {industry && (
            <span class="font-mono text-[10px] uppercase tracking-[0.08em]" style="color: var(--color-neutral-400);">
              {industry}
            </span>
          )}
        </div>

        <!-- Title — large, readable -->
        <h1 class="font-light text-4xl sm:text-5xl lg:text-6xl leading-[1.1] tracking-tight" style="font-family: var(--font-sans); color: var(--color-neutral-800);">
          {title}
        </h1>

        <!-- Excerpt — acts as article lede -->
        <p class="mt-8 text-xl lg:text-2xl leading-[1.5] font-light" style="font-family: var(--font-sans); color: var(--color-neutral-500);">
          {excerpt}
        </p>

        <!-- Meta line -->
        <div class="mt-10 flex items-center gap-6 pb-10" style="border-bottom: 1px solid var(--color-structure);">
          <span class="font-mono text-[10px] uppercase tracking-[0.08em]" style="color: var(--color-neutral-400);">
            {author}
          </span>
          <span class="font-mono text-[10px] uppercase tracking-[0.08em]" style="color: var(--color-neutral-400);">
            {formattedDate}
          </span>
          {readingTime && (
            <span class="font-mono text-[10px] uppercase tracking-[0.08em]" style="color: var(--color-neutral-400);">
              {readingTime}
            </span>
          )}
        </div>
      </div>
    </header>

    <!-- Hero image — full-bleed -->
    {heroImage && (
      <div class="mb-16 lg:mb-20">
        <div class="mx-auto max-w-7xl px-6 lg:px-0">
          <div class="relative overflow-hidden aspect-[21/9]" style="background: var(--color-neutral-100);">
            <img src={heroImage} alt="" class="w-full h-full object-cover" />
          </div>
        </div>
      </div>
    )}

    <!-- Article body — optimized for long-form reading -->
    <div class="px-6">
      <div class="mx-auto max-w-3xl prose prose-neutral lg:prose-lg prose-article
        prose-headings:tracking-tight
        prose-headings:text-[var(--color-neutral-800)]
        prose-h2:text-2xl prose-h2:lg:text-3xl prose-h2:font-light prose-h2:mt-20 prose-h2:mb-8 prose-h2:pt-10
        prose-h3:text-xl prose-h3:lg:text-2xl prose-h3:font-light prose-h3:mt-14 prose-h3:mb-6
        prose-p:text-lg prose-p:lg:text-xl prose-p:leading-[1.8] prose-p:mb-8 prose-p:text-[var(--color-neutral-600)]
        prose-strong:font-semibold prose-strong:text-[var(--color-neutral-800)]
        prose-a:text-[var(--color-forest)] prose-a:no-underline hover:prose-a:underline
        prose-li:text-lg prose-li:lg:text-xl prose-li:leading-[1.8] prose-li:text-[var(--color-neutral-600)]
        prose-blockquote:not-italic prose-blockquote:pl-6 prose-blockquote:text-xl prose-blockquote:lg:text-2xl prose-blockquote:leading-[1.6] prose-blockquote:text-[var(--color-neutral-500)]
      " style="font-family: var(--font-sans);">
        <Content />
      </div>
    </div>

    <!-- Tags -->
    {tags && tags.length > 0 && (
      <div class="px-6 mt-16">
        <div class="mx-auto max-w-3xl flex flex-wrap gap-2 pt-10" style="border-top: 1px solid var(--color-structure);">
          {tags.map(tag => (
            <span class="font-mono text-[10px] uppercase tracking-[0.1em] px-3 py-1.5" style="color: var(--color-neutral-500); border: 1px solid var(--color-structure);">
              {tag}
            </span>
          ))}
        </div>
      </div>
    )}
  </article>

  <!-- Related articles — magazine card style -->
  {related.length > 0 && (
    <section class="py-20 lg:py-28 px-6" style="border-top: 1px solid var(--color-structure);">
      <div class="mx-auto max-w-7xl">
        <p class="font-mono text-[10px] uppercase tracking-[0.1em] mb-10 lg:mb-12" style="color: var(--color-forest);">Continue reading</p>
        <div class="grid sm:grid-cols-2 lg:grid-cols-3 gap-6 lg:gap-8">
          {related.map(rel => (
            <a href={articleHref(rel)} class="group block">
              {rel.data.heroImage && (
                <div class="relative overflow-hidden aspect-[3/2] mb-4" style="background: var(--color-neutral-100);">
                  <img src={rel.data.heroImage} alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03] img-technical" loading="lazy" />
                </div>
              )}
              <div class="flex items-center gap-3 mb-2">
                <span class="font-mono text-[10px] uppercase tracking-[0.12em]" style="color: var(--color-forest);">
                  {rel.data.category.replace(/-/g, ' ')}
                </span>
                <span class="font-mono text-[10px] uppercase tracking-[0.08em]" style="color: var(--color-neutral-400);">
                  {rel.data.readingTime}
                </span>
              </div>
              <h3 class="text-lg lg:text-xl font-light leading-[1.25] tracking-tight transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="font-family: var(--font-sans); color: var(--color-neutral-800);">
                {rel.data.title}
              </h3>
              <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.08em] transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);">
                Read article →
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- CTA -->
  <DualCta
    title={`See what <span style="color: var(--color-forest);">operational intelligence</span> looks like on your infrastructure.`}
    description="Pick one challenge. We deploy on your systems in 4 weeks. You see the value before you commit."
    primaryCta={{ label: 'Schedule an Assessment', href: '/contact/demo' }}
    secondaryCta={{ label: 'Talk to an Engineer', href: '/contact/sales' }}
    microcopy="4-week proof of value · Credited toward annual contract"
  />

  <SiteFooter lang="en" />
</BaseLayout>
