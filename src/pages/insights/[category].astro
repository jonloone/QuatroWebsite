---
import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import SiteHeader from '@/components/layout/SiteHeader.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
import CategoryCrossLinks from '@/components/insights/CategoryCrossLinks.astro'
import { categoryMeta, getValidCategories } from '@/lib/category-meta'

export async function getStaticPaths() {
  const categories = getValidCategories()
  return categories.map(category => ({
    params: { category },
    props: { category },
  }))
}

const { category } = Astro.props
const meta = categoryMeta[category]

const articles = (await getCollection('insights'))
  .filter(a => a.data.category === category)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())

const lead = articles[0]
const rest = articles.slice(1)

const formatDate = (d: Date) => d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })
const articleHref = (a: any) => `/insights/${a.id.replace(/\.md$/, '')}`
---

<BaseLayout
  title={`${meta.title} — Quatro Insights`}
  description={meta.description}
  lang="en"
>
  <SiteHeader lang="en" />

  <!-- Hero -->
  <section class="pt-32 pb-16 lg:pt-40 lg:pb-20 px-6" style="border-bottom: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-5xl">
      <div class="flex items-center gap-3 mb-6">
        <a href="/insights" class="font-mono text-[10px] uppercase tracking-[0.1em] transition-colors duration-200 hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);">
          Insights
        </a>
        <span class="font-mono text-[10px]" style="color: var(--color-neutral-300);">/</span>
        <span class="font-mono text-[10px] uppercase tracking-[0.1em]" style="color: var(--color-forest);">
          {meta.title}
        </span>
      </div>
      <h1 class="font-sans font-light text-4xl sm:text-5xl lg:text-6xl leading-[1.1] tracking-tight whitespace-pre-line" style="color: var(--color-neutral-800);">
        {meta.headline}
      </h1>
      <p class="mt-6 font-sans text-lg leading-relaxed max-w-2xl" style="color: var(--color-neutral-500);">
        {meta.description}
      </p>
    </div>
  </section>

  {/* ═══ MAGAZINE LAYOUT (Industry Trends) ═══ */}
  {meta.layout === 'magazine' && (
    <>
      {/* Lead article — full-width image hero with dither */}
      {lead && (
        <section class="px-6 py-8" style="border-bottom: 1px solid var(--color-structure);">
          <div class="mx-auto max-w-6xl">
            <a href={articleHref(lead)} class="group block relative overflow-hidden rounded-xl" style="background: #0a0a0a;" data-dither-section>
              {lead.data.heroImage && (
                <div class="relative aspect-[16/9] lg:aspect-[21/9]">
                  <img src={lead.data.heroImage} alt="" class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.03]" loading="eager" />
                </div>
              )}
              <!-- Dither canvas overlay — covers entire card -->
              <canvas
                class="absolute inset-0 w-full h-full z-[1] opacity-50"
                data-dither-canvas
                data-image-src={lead.data.heroImage}
                data-pixel-size="3"
                data-base-speed="0.06"
                data-hover-speed="0.3"
                data-green-blend="0.35"
              ></canvas>
              <div class="absolute inset-0 z-[2]" style="background: linear-gradient(to top, rgba(0,0,0,0.75) 0%, rgba(0,0,0,0.55) 30%, rgba(0,0,0,0.2) 50%, transparent 70%);"></div>
              <svg style="position:absolute;width:0;height:0;">
                <filter id="cat-grain">
                  <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
                  <feColorMatrix type="saturate" values="0" />
                </filter>
              </svg>
              <div class="absolute inset-0 z-[3] pointer-events-none opacity-[0.04]" style="filter: url(#cat-grain);"></div>
              <div class="absolute bottom-0 left-0 right-0 p-6 lg:p-10 z-[4]">
                <div class="flex items-center gap-3 mb-3">
                  {lead.data.industry && (
                    <span class="font-mono text-[10px] uppercase tracking-[0.12em] px-2.5 py-1 rounded-full" style="background: rgba(255,255,255,0.12); backdrop-filter: blur(8px); color: white; border: 1px solid rgba(255,255,255,0.1);">
                      {lead.data.industry}
                    </span>
                  )}
                  <span class="font-mono text-[10px] uppercase tracking-[0.08em]" style="color: rgba(255,255,255,0.7);">
                    {lead.data.readingTime}
                  </span>
                </div>
                <h2 class="font-sans text-2xl sm:text-3xl lg:text-4xl font-light leading-[1.15] tracking-tight text-white max-w-3xl">
                  {lead.data.title}
                </h2>
                <p class="mt-3 font-sans text-sm lg:text-base leading-relaxed max-w-2xl hidden sm:block" style="color: rgba(255,255,255,0.85);">
                  {lead.data.excerpt}
                </p>
                <p class="mt-4 font-mono text-xs uppercase tracking-[0.08em]" style="color: rgba(255,255,255,0.7);">
                  Read article →
                </p>
              </div>
            </a>
          </div>
        </section>
      )}

      {/* Remaining articles — 2 column grid */}
      {rest.length > 0 && (
        <section class="py-16 lg:py-20 px-6">
          <div class="mx-auto max-w-5xl">
            <div class="grid md:grid-cols-2 gap-10 lg:gap-12">
              {rest.map(article => (
                <a href={articleHref(article)} class="group">
                  {article.data.heroImage && (
                    <div class="relative overflow-hidden rounded-lg aspect-[4/3] mb-5" style="background: var(--color-neutral-50);">
                      <img src={article.data.heroImage} alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 img-technical" loading="lazy" />
                    </div>
                  )}
                  <div class="flex items-center gap-3 mb-3">
                    {article.data.industry && (
                      <span class="font-mono text-[10px] uppercase tracking-[0.08em]" style="color: var(--color-neutral-400);">
                        {article.data.industry}
                      </span>
                    )}
                    <span class="font-mono text-[10px] uppercase tracking-[0.08em]" style="color: var(--color-neutral-400);">
                      {article.data.readingTime}
                    </span>
                  </div>
                  <h3 class="font-sans text-xl font-light leading-[1.25] tracking-tight transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">
                    {article.data.title}
                  </h3>
                  <p class="mt-3 font-sans text-sm leading-relaxed line-clamp-3" style="color: var(--color-neutral-500);">
                    {article.data.excerpt}
                  </p>
                  <p class="mt-4 font-mono text-[10px] uppercase tracking-[0.08em]" style="color: var(--color-neutral-400);">
                    {formatDate(article.data.publishDate)}
                  </p>
                </a>
              ))}
            </div>
          </div>
        </section>
      )}
    </>
  )}

  {/* ═══ SCENARIO LAYOUT (Use Cases) ═══ */}
  {meta.layout === 'scenario' && (
    <section class="py-16 lg:py-20 px-6">
      <div class="mx-auto max-w-5xl">
        <div class="grid gap-y-12 lg:gap-y-16">
          {articles.map((article, i) => (
            <a
              href={articleHref(article)}
              class="group grid lg:grid-cols-[1fr_2fr] gap-6 lg:gap-12 items-start"
              style={i > 0 ? 'border-top: 1px solid var(--color-structure); padding-top: 3rem;' : ''}
            >
              {article.data.heroImage && (
                <div class="relative overflow-hidden rounded-lg aspect-[4/3]" style="background: var(--color-neutral-50);">
                  <img src={article.data.heroImage} alt="" class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105 img-technical" loading="lazy" />
                </div>
              )}
              <div>
                <div class="flex items-center gap-3 mb-3">
                  {article.data.industry && (
                    <span class="font-mono text-[10px] uppercase tracking-[0.12em] px-2.5 py-1 rounded-full" style="color: var(--color-forest); background: rgba(15,76,58,0.06);">
                      {article.data.industry}
                    </span>
                  )}
                  <span class="font-mono text-[10px] uppercase tracking-[0.08em]" style="color: var(--color-neutral-400);">
                    {article.data.readingTime}
                  </span>
                </div>
                <h3 class="font-sans text-xl lg:text-2xl font-light leading-[1.25] tracking-tight transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">
                  {article.data.title}
                </h3>
                <p class="mt-3 font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">
                  {article.data.excerpt}
                </p>
                <div class="mt-4 flex items-center gap-4">
                  <span class="font-mono text-[10px] uppercase tracking-[0.08em]" style="color: var(--color-neutral-400);">
                    {formatDate(article.data.publishDate)}
                  </span>
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  {/* ═══ TECHNICAL LAYOUT (Platform) ═══ */}
  {meta.layout === 'technical' && (
    <section class="py-16 lg:py-20 px-6">
      <div class="mx-auto max-w-3xl">
        <div class="grid gap-0">
          {articles.map((article, i) => (
            <a
              href={articleHref(article)}
              class="group grid grid-cols-[3rem_1fr] gap-6 py-10"
              style={i > 0 ? 'border-top: 1px solid var(--color-structure);' : ''}
            >
              <span class="font-mono text-sm tabular-nums pt-1" style="color: var(--color-neutral-300);">
                {String(i + 1).padStart(2, '0')}
              </span>
              <div>
                <h3 class="font-sans text-xl lg:text-2xl font-light leading-[1.25] tracking-tight transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">
                  {article.data.title}
                </h3>
                <p class="mt-3 font-sans text-base leading-relaxed" style="color: var(--color-neutral-500);">
                  {article.data.excerpt}
                </p>
                <div class="mt-4 flex items-center gap-4">
                  <span class="font-mono text-[10px] uppercase tracking-[0.08em]" style="color: var(--color-neutral-400);">
                    {formatDate(article.data.publishDate)}
                  </span>
                  {article.data.readingTime && (
                    <span class="font-mono text-[10px] uppercase tracking-[0.08em]" style="color: var(--color-neutral-400);">
                      {article.data.readingTime}
                    </span>
                  )}
                </div>
              </div>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}

  <!-- Cross-links to other categories -->
  <CategoryCrossLinks currentCategory={category} />

  <!-- CTA -->
  <section class="py-16 lg:py-20 px-6" style="border-top: 1px solid var(--color-structure); background: var(--color-neutral-50, #f8fafc);">
    <div class="mx-auto max-w-2xl text-center">
      <h2 class="font-sans text-2xl lg:text-3xl font-light tracking-tight" style="color: var(--color-neutral-800);">
        See it on your infrastructure.
      </h2>
      <p class="mt-4 font-sans text-base leading-relaxed" style="color: var(--color-neutral-500);">
        Start with the outcome that matters. We connect the systems. Your team works from the model.
      </p>
      <a
        href="/contact/demo"
        class="inline-flex items-center gap-2 mt-8 font-mono text-xs uppercase tracking-[0.08em] px-8 py-4 rounded-full transition-all duration-300 ease-out hover:scale-105"
        style="background-color: var(--color-forest); color: white;"
      >
        Schedule an Assessment
        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
      </a>
    </div>
  </section>

  <SiteFooter lang="en" />

  <!-- Bayer 4×4 dither engine — matches HeroCanvas treatment -->
  <script>
    const bayer4x4 = [
      [ 0/16,  8/16,  2/16, 10/16],
      [12/16,  4/16, 14/16,  6/16],
      [ 3/16, 11/16,  1/16,  9/16],
      [15/16,  7/16, 13/16,  5/16]
    ];

    function initDither(canvas: HTMLCanvasElement) {
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      const imageSrc = canvas.dataset.imageSrc || '/images/hero-bg.png';
      const pixelSize = parseInt(canvas.dataset.pixelSize || '3', 10);
      const baseSpeed = parseFloat(canvas.dataset.baseSpeed || '0.06');
      const hoverSpeed = parseFloat(canvas.dataset.hoverSpeed || '0.3');
      const greenBlend = parseFloat(canvas.dataset.greenBlend || '0.35');

      const card = canvas.closest('[data-dither-section]') as HTMLElement;
      let isHovered = false;
      let animId: number;
      let startTime = performance.now();

      const bgImg = new Image();
      bgImg.crossOrigin = 'anonymous';
      bgImg.src = imageSrc;

      const offscreen = document.createElement('canvas');
      const offCtx = offscreen.getContext('2d')!;
      let imgLoaded = false;

      bgImg.onload = () => { imgLoaded = true; };

      function resize() {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;
      }

      function render(time: number) {
        if (!ctx) return;
        const w = canvas.width;
        const h = canvas.height;
        if (w === 0 || h === 0) { animId = requestAnimationFrame(render); return; }

        const elapsed = (time - startTime) / 1000;
        const speed = isHovered ? hoverSpeed : baseSpeed;
        const t = elapsed * speed;

        let srcPixels: Uint8ClampedArray | null = null;
        if (imgLoaded) {
          offscreen.width = w;
          offscreen.height = h;
          offCtx.drawImage(bgImg, 0, 0, w, h);
          srcPixels = offCtx.getImageData(0, 0, w, h).data;
        }

        const imageData = ctx.createImageData(w, h);
        const data = imageData.data;
        const cols = Math.ceil(w / pixelSize);
        const rows = Math.ceil(h / pixelSize);

        for (let row = 0; row < rows; row++) {
          for (let col = 0; col < cols; col++) {
            const centerX = col * pixelSize + (pixelSize >> 1);
            const centerY = row * pixelSize + (pixelSize >> 1);

            let imgBrightness = 0.3;
            if (srcPixels && centerX < w && centerY < h) {
              const sIdx = (centerY * w + centerX) * 4;
              imgBrightness = (srcPixels[sIdx] * 0.299 + srcPixels[sIdx+1] * 0.587 + srcPixels[sIdx+2] * 0.114) / 255;
            }

            const cx = col / cols;
            const cy = row / rows;

            const warpX = 0.12 * Math.sin(cy * 5.0 + t * 1.3) + 0.08 * Math.cos(cx * 4.0 + t * 0.9);
            const warpY = 0.12 * Math.cos(cx * 5.0 + t * 1.1) + 0.08 * Math.sin(cy * 4.0 + t * 1.5);

            const wx = cx + warpX;
            const wy = cy + warpY;
            const d1 = Math.sqrt((wx - 0.5) ** 2 + (wy - 0.5) ** 2);
            const warpIntensity = 0.3 + 0.25 * Math.sin(d1 * 8.0 - t * 2.0) + 0.15 * Math.cos((wx + wy) * 6.0 + t);

            let intensity = imgBrightness * 0.7 + warpIntensity * 0.5;
            intensity = Math.max(0, Math.min(1, intensity));

            const threshold = bayer4x4[row % 4][col % 4];
            const on = intensity > threshold;

            let r: number, g: number, b: number, a: number;
            if (on) {
              if (srcPixels && centerX < w && centerY < h) {
                const sIdx = (centerY * w + centerX) * 4;
                const blend = greenBlend + (1 - greenBlend) * 0.5 * warpIntensity;
                r = Math.round(srcPixels[sIdx]     * (1 - blend) + 15  * blend);
                g = Math.round(srcPixels[sIdx + 1] * (1 - blend) + 76  * blend);
                b = Math.round(srcPixels[sIdx + 2] * (1 - blend) + 58  * blend);
              } else {
                r = 15; g = 76; b = 58;
              }
              a = Math.round(intensity * 220 + 35);
            } else {
              r = 0; g = 0; b = 0; a = 0;
            }

            for (let py = 0; py < pixelSize; py++) {
              for (let px = 0; px < pixelSize; px++) {
                const x = col * pixelSize + px;
                const y = row * pixelSize + py;
                if (x >= w || y >= h) continue;
                const idx = (y * w + x) * 4;
                data[idx]     = r;
                data[idx + 1] = g;
                data[idx + 2] = b;
                data[idx + 3] = a;
              }
            }
          }
        }

        ctx.putImageData(imageData, 0, 0);
        animId = requestAnimationFrame(render);
      }

      if (card) {
        card.addEventListener('mouseenter', () => { isHovered = true; });
        card.addEventListener('mouseleave', () => { isHovered = false; });
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            resize();
            startTime = performance.now();
            animId = requestAnimationFrame(render);
          } else {
            cancelAnimationFrame(animId);
          }
        });
      }, { threshold: 0.1 });

      window.addEventListener('resize', resize);
      observer.observe(canvas);
    }

    document.querySelectorAll<HTMLCanvasElement>('[data-dither-canvas]').forEach(initDither);
  </script>
</BaseLayout>
