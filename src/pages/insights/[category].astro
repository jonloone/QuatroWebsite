---
import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import SiteHeader from '@/components/layout/SiteHeader.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
import CategoryCrossLinks from '@/components/insights/CategoryCrossLinks.astro'
import DualCta from '@/components/marketing/DualCta.astro'
import { categoryMeta, getValidCategories } from '@/lib/category-meta'

export async function getStaticPaths() {
  const categories = getValidCategories()
  return categories.map(category => ({
    params: { category },
    props: { category },
  }))
}

const { category } = Astro.props
const meta = categoryMeta[category]

const articles = (await getCollection('insights'))
  .filter(a => a.data.category === category)
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())

const lead = articles[0]
const rest = articles.slice(1)

const articleHref = (a: any) => `/insights/${a.id.replace(/\.md$/, '')}`

const formatDate = (d: Date) => d.toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

// Determine section style based on category position
const categoryKeys = Object.keys(categoryMeta)
const catIdx = categoryKeys.indexOf(category)

const sectionStyles = [
  { bg: '#0a0a0a', text: 'white', muted: 'rgba(255,255,255,0.5)', accent: 'var(--color-forest)', label: 'rgba(255,255,255,0.4)', border: 'rgba(255,255,255,0.06)', headerBg: '#0a0a0a', headerText: 'white', headerMuted: 'rgba(255,255,255,0.5)' },
  { bg: 'rgb(206,210,198)', text: '#1a1a1a', muted: 'rgba(26,26,26,0.55)', accent: 'var(--color-forest)', label: 'rgba(26,26,26,0.45)', border: 'rgba(26,26,26,0.1)', headerBg: 'rgb(206,210,198)', headerText: '#1a1a1a', headerMuted: 'rgba(26,26,26,0.55)' },
  { bg: 'var(--color-paper)', text: 'var(--color-neutral-800)', muted: 'var(--color-neutral-500)', accent: 'var(--color-forest)', label: 'var(--color-neutral-400)', border: 'var(--color-structure)', headerBg: 'var(--color-paper)', headerText: 'var(--color-neutral-800)', headerMuted: 'var(--color-neutral-500)' },
]

const style = sectionStyles[catIdx % sectionStyles.length]
const isDark = catIdx % 3 === 0
const isSage = catIdx % 3 === 1
---

<BaseLayout
  title={`${meta.title} — Quatro Insights`}
  description={meta.description}
  lang="en"
>
  <SiteHeader lang="en" />

  <!-- Editorial Header — inherits section color -->
  <header class="relative overflow-hidden pt-[max(14vh,160px)] pb-12 lg:pt-[max(16vh,192px)] lg:pb-16 px-8 lg:px-16" style={`background: ${style.headerBg};`}>
    {(isDark || isSage) && (
      <>
        <svg style="position:absolute;width:0;height:0;">
          <filter id="header-grain">
            <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
            <feColorMatrix type="saturate" values="0" />
          </filter>
        </svg>
        <div class="absolute inset-0 pointer-events-none" style={`opacity: ${isDark ? '0.03' : '0.04'}; filter: url(#header-grain);`}></div>
      </>
    )}
    <div class="relative z-10 mx-auto max-w-[1400px]">
      <div class="flex items-center gap-3 mb-6">
        <a href="/insights" class="font-mono text-[10px] uppercase tracking-[0.1em] transition-colors duration-200 hover:opacity-70" style={`color: ${style.label};`}>
          Insights
        </a>
        <span class="font-mono text-[10px]" style={`color: ${style.label}; opacity: 0.5;`}>/</span>
        <span class="font-mono text-[10px] uppercase tracking-[0.1em]" style={`color: ${style.accent};`}>
          {meta.title}
        </span>
      </div>
      <h1 class="font-light text-4xl sm:text-5xl lg:text-7xl leading-[1.05] tracking-tight whitespace-pre-line" style={`font-family: var(--font-sans); color: ${style.headerText};`}>
        {meta.headline}
      </h1>
      <p class="mt-6 text-lg lg:text-xl leading-relaxed max-w-2xl" style={`font-family: var(--font-sans); color: ${style.headerMuted};`}>
        {meta.description}
      </p>
    </div>
  </header>

  <!-- Category nav tabs -->
  <nav class="px-8 lg:px-16 mb-0" style={`background: ${style.headerBg};`}>
    <div class="mx-auto max-w-[1400px] flex items-center gap-8 lg:gap-12 pb-4 overflow-x-auto" style={`border-bottom: 1px solid ${style.border};`}>
      <a
        href="/insights"
        class="font-mono text-[10px] uppercase tracking-[0.1em] pb-4 whitespace-nowrap transition-opacity duration-200 hover:opacity-70"
        style={`color: ${style.label};`}
      >
        All
      </a>
      {Object.entries(categoryMeta).map(([slug, cat]) => (
        slug === category ? (
          <span
            class="font-mono text-[10px] uppercase tracking-[0.1em] pb-4 whitespace-nowrap"
            style={`color: ${style.headerText}; border-bottom: 2px solid var(--color-forest); margin-bottom: -1px;`}
          >
            {cat.title}
          </span>
        ) : (
          <a
            href={`/insights/${slug}`}
            class="font-mono text-[10px] uppercase tracking-[0.1em] pb-4 whitespace-nowrap transition-opacity duration-200 hover:opacity-70"
            style={`color: ${style.label};`}
          >
            {cat.title}
          </a>
        )
      ))}
    </div>
  </nav>

  <!-- Lead article -->
  {lead && (
    <section class="relative overflow-hidden" style={`background: ${style.bg};`}>
      {(isDark || isSage) && (
        <>
          <svg style="position:absolute;width:0;height:0;">
            <filter id="lead-grain">
              <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
              <feColorMatrix type="saturate" values="0" />
            </filter>
          </svg>
          <div class="absolute inset-0 pointer-events-none" style={`opacity: ${isDark ? '0.03' : '0.04'}; filter: url(#lead-grain);`}></div>
        </>
      )}

      <div class="relative z-10 pt-16 lg:pt-20">
        {isDark || isSage ? (
          /* Dark/Sage: full-bleed image with text overlay */
          <a href={articleHref(lead)} class="group block relative overflow-hidden" style={`background: ${isDark ? '#111' : 'rgba(26,26,26,0.1)'};`} data-dither-section>
            {lead.data.heroImage && (
              <div class="relative w-full" style="aspect-ratio: 21/9; min-height: 400px;">
                <img
                  src={lead.data.heroImage}
                  alt=""
                  class={`w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.02] ${isSage ? 'grayscale contrast-[0.85] brightness-[1.1]' : 'img-technical'}`}
                  loading="eager"
                />
              </div>
            )}
            {isSage && (
              <>
                <div class="absolute inset-0" style="background: rgba(180,190,170,0.55); mix-blend-mode: multiply;"></div>
                <div class="absolute inset-0" style="background: rgba(210,215,200,0.3); mix-blend-mode: screen;"></div>
              </>
            )}
            {isDark && (
              <canvas
                class="absolute inset-0 w-full h-full z-[1] opacity-50"
                data-dither-canvas
                data-image-src={lead.data.heroImage}
                data-pixel-size="3"
                data-base-speed="0.06"
                data-hover-speed="0.3"
                data-green-blend="0.35"
              ></canvas>
            )}
            <div class="absolute inset-0 z-[2]" style={`background: linear-gradient(to top, ${isDark ? 'rgba(10,10,10,0.9) 0%, rgba(10,10,10,0.6) 35%, transparent 65%' : 'rgba(26,26,26,0.7) 0%, rgba(26,26,26,0.35) 35%, transparent 60%'});`}></div>
            <svg style="position:absolute;width:0;height:0;">
              <filter id="cat-grain">
                <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
                <feColorMatrix type="saturate" values="0" />
              </filter>
            </svg>
            <div class="absolute inset-0 z-[3] pointer-events-none opacity-[0.04]" style="filter: url(#cat-grain);"></div>
            <div class="absolute bottom-0 left-0 right-0 p-8 lg:p-16 z-[4]">
              <div class="mx-auto max-w-[1400px]">
                <div class="flex items-center gap-4 mb-4">
                  {lead.data.industry && (
                    <span class="font-mono text-[10px] uppercase tracking-[0.12em]" style="color: rgba(255,255,255,0.5);">
                      {lead.data.industry}
                    </span>
                  )}
                  <span class="font-mono text-[10px] uppercase tracking-[0.08em]" style="color: rgba(255,255,255,0.35);">
                    {lead.data.readingTime}
                  </span>
                </div>
                <h2 class="font-light text-3xl sm:text-4xl lg:text-5xl leading-[1.08] tracking-tight text-white max-w-4xl" style="font-family: var(--font-sans);">
                  {lead.data.title}
                </h2>
                <p class="mt-4 text-base lg:text-lg leading-relaxed max-w-2xl" style="font-family: var(--font-sans); color: rgba(255,255,255,0.6);">
                  {lead.data.excerpt}
                </p>
                <p class="mt-6 font-mono text-[10px] uppercase tracking-[0.08em]" style="color: rgba(255,255,255,0.5);">
                  → Read article
                </p>
              </div>
            </div>
          </a>
        ) : (
          /* Light: image above, text below */
          <div class="px-8 lg:px-16">
            <a href={articleHref(lead)} class="group block mx-auto max-w-[1400px]">
              {lead.data.heroImage && (
                <div class="relative overflow-hidden w-full mb-6" style="aspect-ratio: 21/9; background: var(--color-neutral-100);">
                  <img
                    src={lead.data.heroImage}
                    alt=""
                    class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-[1.02] img-technical"
                    loading="eager"
                  />
                </div>
              )}
              <div class="flex items-center gap-4 mb-2">
                {lead.data.industry && (
                  <span class="font-mono text-[10px] uppercase tracking-[0.08em]" style={`color: ${style.label};`}>
                    {lead.data.industry}
                  </span>
                )}
                <span class="font-mono text-[10px] uppercase tracking-[0.08em]" style={`color: ${style.label};`}>
                  {lead.data.readingTime}
                </span>
              </div>
              <h2 class="font-light text-3xl sm:text-4xl lg:text-5xl leading-[1.08] tracking-tight max-w-4xl transition-colors duration-300 group-hover:text-[var(--color-forest)]" style={`font-family: var(--font-sans); color: ${style.text};`}>
                {lead.data.title}
              </h2>
              <p class="mt-4 text-base lg:text-lg leading-relaxed max-w-2xl" style={`font-family: var(--font-sans); color: ${style.muted};`}>
                {lead.data.excerpt}
              </p>
              <p class="mt-6 font-mono text-[10px] uppercase tracking-[0.08em] transition-colors duration-300 group-hover:text-[var(--color-forest)]" style={`color: ${style.label};`}>
                → Read article
              </p>
            </a>
          </div>
        )}
      </div>
    </section>
  )}

  <!-- Remaining articles — two-column grid -->
  {rest.length > 0 && (
    <section class="relative overflow-hidden" style={`background: ${style.bg};`}>
      {(isDark || isSage) && (
        <>
          <svg style="position:absolute;width:0;height:0;">
            <filter id="rest-grain">
              <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" stitchTiles="stitch" />
              <feColorMatrix type="saturate" values="0" />
            </filter>
          </svg>
          <div class="absolute inset-0 pointer-events-none" style={`opacity: ${isDark ? '0.03' : '0.04'}; filter: url(#rest-grain);`}></div>
        </>
      )}

      <div class="relative z-10 px-8 lg:px-16 py-20 lg:py-28">
        <div class="mx-auto max-w-[1400px]">
          <div class="grid md:grid-cols-2 gap-x-8 lg:gap-x-12 gap-y-14 lg:gap-y-20">
            {rest.map(article => (
              <a href={articleHref(article)} class="group block">
                <p class="font-mono text-[10px] uppercase tracking-[0.08em] mb-3" style={`color: ${style.label};`}>
                  {formatDate(article.data.publishDate)}
                </p>
                {article.data.heroImage && (
                  <div class="relative overflow-hidden mb-5" style={`aspect-ratio: 3/2; background: ${isDark ? '#111' : isSage ? 'rgba(26,26,26,0.08)' : 'var(--color-neutral-100)'};`}>
                    <img
                      src={article.data.heroImage}
                      alt=""
                      class={`w-full h-full object-cover transition-transform duration-500 group-hover:scale-[1.03] ${isSage ? 'grayscale contrast-[0.85] brightness-[1.1]' : 'img-technical'}`}
                      loading="lazy"
                    />
                    {isSage && (
                      <>
                        <div class="absolute inset-0" style="background: rgba(180,190,170,0.4); mix-blend-mode: multiply;"></div>
                        <div class="absolute inset-0" style="background: rgba(210,215,200,0.2); mix-blend-mode: screen;"></div>
                      </>
                    )}
                  </div>
                )}
                {article.data.industry && (
                  <span class="font-mono text-[10px] uppercase tracking-[0.08em]" style={`color: ${style.label};`}>
                    {article.data.industry}
                  </span>
                )}
                <h3 class="mt-2 font-light text-lg lg:text-xl leading-[1.25] tracking-tight transition-opacity duration-300 group-hover:opacity-70" style={`font-family: var(--font-sans); color: ${style.text};`}>
                  {article.data.title}
                </h3>
                <p class="mt-3 font-mono text-[10px] uppercase tracking-[0.08em] transition-opacity duration-300 group-hover:opacity-70" style={`color: ${style.muted};`}>
                  → View article
                </p>
              </a>
            ))}
          </div>
        </div>
      </div>
    </section>
  )}

  <!-- Cross-links to other categories -->
  <CategoryCrossLinks currentCategory={category} />

  <!-- CTA -->
  <DualCta
    title={`See what <span style="color: var(--color-forest);">operational intelligence</span> looks like on your infrastructure.`}
    description="Pick one challenge. We deploy on your systems in 4 weeks. You see the value before you commit."
    primaryCta={{ label: 'Schedule an Assessment', href: '/contact/demo' }}
    secondaryCta={{ label: 'Talk to an Engineer', href: '/contact/sales' }}
    microcopy="4-week proof of value · Credited toward annual contract"
  />

  <SiteFooter lang="en" />

  <!-- Bayer 4×4 dither engine (for dark category sections) -->
  {isDark && (
    <script>
      const bayer4x4 = [
        [ 0/16,  8/16,  2/16, 10/16],
        [12/16,  4/16, 14/16,  6/16],
        [ 3/16, 11/16,  1/16,  9/16],
        [15/16,  7/16, 13/16,  5/16]
      ];

      function initDither(canvas: HTMLCanvasElement) {
        const ctx = canvas.getContext('2d');
        if (!ctx) return;

        const imageSrc = canvas.dataset.imageSrc || '/images/hero-bg.png';
        const pixelSize = parseInt(canvas.dataset.pixelSize || '3', 10);
        const baseSpeed = parseFloat(canvas.dataset.baseSpeed || '0.06');
        const hoverSpeed = parseFloat(canvas.dataset.hoverSpeed || '0.3');
        const greenBlend = parseFloat(canvas.dataset.greenBlend || '0.35');

        const card = canvas.closest('[data-dither-section]') as HTMLElement;
        let isHovered = false;
        let animId: number;
        let startTime = performance.now();

        const bgImg = new Image();
        bgImg.crossOrigin = 'anonymous';
        bgImg.src = imageSrc;

        const offscreen = document.createElement('canvas');
        const offCtx = offscreen.getContext('2d')!;
        let imgLoaded = false;

        bgImg.onload = () => { imgLoaded = true; };

        function resize() {
          const rect = canvas.getBoundingClientRect();
          canvas.width = rect.width;
          canvas.height = rect.height;
        }

        function render(time: number) {
          if (!ctx) return;
          const w = canvas.width;
          const h = canvas.height;
          if (w === 0 || h === 0) { animId = requestAnimationFrame(render); return; }

          const elapsed = (time - startTime) / 1000;
          const speed = isHovered ? hoverSpeed : baseSpeed;
          const t = elapsed * speed;

          let srcPixels: Uint8ClampedArray | null = null;
          if (imgLoaded) {
            offscreen.width = w;
            offscreen.height = h;
            offCtx.drawImage(bgImg, 0, 0, w, h);
            srcPixels = offCtx.getImageData(0, 0, w, h).data;
          }

          const imageData = ctx.createImageData(w, h);
          const data = imageData.data;
          const cols = Math.ceil(w / pixelSize);
          const rows = Math.ceil(h / pixelSize);

          for (let row = 0; row < rows; row++) {
            for (let col = 0; col < cols; col++) {
              const centerX = col * pixelSize + (pixelSize >> 1);
              const centerY = row * pixelSize + (pixelSize >> 1);

              let imgBrightness = 0.3;
              if (srcPixels && centerX < w && centerY < h) {
                const sIdx = (centerY * w + centerX) * 4;
                imgBrightness = (srcPixels[sIdx] * 0.299 + srcPixels[sIdx+1] * 0.587 + srcPixels[sIdx+2] * 0.114) / 255;
              }

              const cx = col / cols;
              const cy = row / rows;
              const warpX = 0.12 * Math.sin(cy * 5.0 + t * 1.3) + 0.08 * Math.cos(cx * 4.0 + t * 0.9);
              const warpY = 0.12 * Math.cos(cx * 5.0 + t * 1.1) + 0.08 * Math.sin(cy * 4.0 + t * 1.5);

              const wx = cx + warpX;
              const wy = cy + warpY;
              const d1 = Math.sqrt((wx - 0.5) ** 2 + (wy - 0.5) ** 2);
              const warpIntensity = 0.3 + 0.25 * Math.sin(d1 * 8.0 - t * 2.0) + 0.15 * Math.cos((wx + wy) * 6.0 + t);

              let intensity = imgBrightness * 0.7 + warpIntensity * 0.5;
              intensity = Math.max(0, Math.min(1, intensity));

              const threshold = bayer4x4[row % 4][col % 4];
              const on = intensity > threshold;

              let r: number, g: number, b: number, a: number;
              if (on) {
                if (srcPixels && centerX < w && centerY < h) {
                  const sIdx = (centerY * w + centerX) * 4;
                  const blend = greenBlend + (1 - greenBlend) * 0.5 * warpIntensity;
                  r = Math.round(srcPixels[sIdx]     * (1 - blend) + 15  * blend);
                  g = Math.round(srcPixels[sIdx + 1] * (1 - blend) + 76  * blend);
                  b = Math.round(srcPixels[sIdx + 2] * (1 - blend) + 58  * blend);
                } else {
                  r = 15; g = 76; b = 58;
                }
                a = Math.round(intensity * 220 + 35);
              } else {
                r = 0; g = 0; b = 0; a = 0;
              }

              for (let py = 0; py < pixelSize; py++) {
                for (let px = 0; px < pixelSize; px++) {
                  const x = col * pixelSize + px;
                  const y = row * pixelSize + py;
                  if (x >= w || y >= h) continue;
                  const idx = (y * w + x) * 4;
                  data[idx]     = r;
                  data[idx + 1] = g;
                  data[idx + 2] = b;
                  data[idx + 3] = a;
                }
              }
            }
          }

          ctx.putImageData(imageData, 0, 0);
          animId = requestAnimationFrame(render);
        }

        if (card) {
          card.addEventListener('mouseenter', () => { isHovered = true; });
          card.addEventListener('mouseleave', () => { isHovered = false; });
        }

        const observer = new IntersectionObserver((entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              resize();
              startTime = performance.now();
              animId = requestAnimationFrame(render);
            } else {
              cancelAnimationFrame(animId);
            }
          });
        }, { threshold: 0.1 });

        window.addEventListener('resize', resize);
        observer.observe(canvas);
      }

      document.querySelectorAll<HTMLCanvasElement>('[data-dither-canvas]').forEach(initDither);
    </script>
  )}
</BaseLayout>
