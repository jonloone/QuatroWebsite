---
import { getCollection } from 'astro:content'
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import Hero from '@/components/marketing/Hero.astro'
import StatStrip from '@/components/marketing/StatStrip.astro'
import Section from '@/components/marketing/Section.astro'
import FeatureGrid from '@/components/marketing/FeatureGrid.astro'
import CtaBanner from '@/components/marketing/CtaBanner.astro'
import ProofPointCard from '@/components/marketing/ProofPointCard.astro'
import BentoUseCases from '@/components/marketing/BentoUseCases.astro'
import EditorialCapability from '@/components/marketing/EditorialCapability.astro'

export async function getStaticPaths() {
  const solutions = await getCollection('solutions')
  return solutions.map((solution) => ({
    params: { slug: solution.id.replace(/\.md$/, '') },
    props: { solution },
  }))
}

const { solution } = Astro.props
const { Content } = await solution.render()
const { title, tagline, description, hero, heroImage, challenges, capabilities, stats, platformMapping, proofPoint, cta } = solution.data

const featuredCapabilities = capabilities.filter((c: any) => c.featured)
const nonFeaturedCapabilities = capabilities.filter((c: any) => !c.featured)
const hasFeatured = featuredCapabilities.length > 0

// Default CTA values
const ctaPrimary = cta?.primary || { label: 'Schedule an Assessment', href: '/contact/demo' }
const ctaSecondary = cta?.secondary || { label: 'Talk to an Engineer', href: '/contact/sales' }
---

<MarketingLayout
  title={`${title} — ${tagline}`}
  description={description}
>
  <Hero
    variant="dark"
    eyebrow={hero.eyebrow}
    title={hero.title}
    description={hero.description}
    primaryCta={hero.primaryCta}
    secondaryCta={hero.secondaryCta}
    backgroundImage={heroImage}
  />

  <StatStrip stats={stats} />

  <!-- Challenges Grid -->
  <Section divider>
    <FeatureGrid
      title="The Challenge"
      subtitle="The operational challenges this solution eliminates."
      features={challenges.map(c => ({ name: c.title, description: c.description }))}
      columns={challenges.length === 4 ? 4 : challenges.length === 3 ? 3 : 2}
    />
  </Section>

  <!-- Capabilities Section -->
  {hasFeatured ? (
    <Section divider dark>
      <BentoUseCases
        title="Key Capabilities"
        subtitle={`Everything you need for ${title.toLowerCase()}.`}
        capabilities={capabilities}
      />
    </Section>
  ) : (
    <Section divider dark>
      <FeatureGrid
        dark
        title="Key Capabilities"
        subtitle={`Everything you need for ${title.toLowerCase()}.`}
        features={capabilities.map(c => ({ name: c.name, description: c.description, icon: c.icon }))}
        columns={3}
      />
    </Section>
  )}

  <!-- Editorial Capabilities (non-featured) -->
  {nonFeaturedCapabilities.length > 0 && (
    <Section divider>
      <div class="mx-auto max-w-7xl px-6 lg:px-8 mb-12 text-center">
        <h2 class="font-display text-2xl font-bold tracking-tight text-neutral-800 sm:text-3xl">More Capabilities</h2>
        <p class="mt-4 text-lg text-neutral-600">Additional capabilities for {title.toLowerCase()}.</p>
      </div>
      {nonFeaturedCapabilities.map((cap: any, i: number) => (
        <EditorialCapability
          name={cap.name}
          description={cap.description}
          outcome={cap.outcome}
          image={cap.image}
          reverse={i % 2 === 1}
        />
      ))}
    </Section>
  )}

  <!-- Proof Point — hidden until real case studies are available -->

  <CtaBanner
    title={`See ${title} on Your Infrastructure`}
    description={`Pick one challenge. We deploy on your systems in 4 weeks. You see the value before you commit.`}
    primaryCta={ctaPrimary}
    secondaryCta={ctaSecondary}
    microcopy={cta?.microcopy}
  />
</MarketingLayout>
