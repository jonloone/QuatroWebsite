---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import Hero from '@/components/marketing/Hero.astro'
import Section from '@/components/marketing/Section.astro'
import CtaBanner from '@/components/marketing/CtaBanner.astro'

const domains = [
  {
    name: 'Space & SATCOM',
    description: 'Unified fleet health, ground segment operations, and revenue assurance for satellite operators. Quatro connects telemetry, antenna systems, and service-level data into one operational picture — across LEO, MEO, and GEO constellations.',
    href: '/industries/space-satcom',
    solutions: [
      { name: 'Teleport Operations', href: '/solutions/teleport-operations' },
      { name: 'Fleet Health', href: '/solutions/fleet-health' },
      { name: 'Satellite Revenue Assurance', href: '/solutions/satellite-revenue-assurance' },
      { name: 'Space Domain Awareness', href: '/solutions/space-domain-awareness' },
    ],
  },
  {
    name: 'Broadcast & Media',
    description: 'Live production monitoring, signal chain intelligence, and SLA compliance for broadcast operations. From contribution feeds to distribution endpoints — real-time visibility across the entire signal path.',
    href: '/industries/broadcast-media',
    solutions: [
      { name: 'Network Operations', href: '/solutions/network-operations' },
      { name: 'Asset Monitoring', href: '/solutions/asset-monitoring' },
    ],
  },
]
---

<MarketingLayout
  title="Networks — Satellite, Telecom & Broadcast Intelligence"
  description="Operational intelligence for the convergence of satellite, telecom, and broadcast infrastructure. Fleet health, signal chain, and revenue assurance at scale."
>
  <Hero
    variant="dark"
    eyebrow="Networks"
    title="Intelligence for the Infrastructure That Connects Everything"
    description="Satellite constellations, telecom networks, broadcast chains — Quatro delivers unified operational intelligence across the convergence of connectivity infrastructure."
    primaryCta={{ label: 'Schedule an Assessment', href: '/contact/demo' }}
  />

  <Section>
    <div class="space-y-16">
      {domains.map((domain) => (
        <div class="rounded-2xl border border-neutral-200 bg-white p-8 lg:p-10 shadow-sm">
          <div class="lg:flex lg:gap-12 lg:items-start">
            <div class="flex-1">
              <h2 class="font-display text-2xl font-bold text-neutral-800">{domain.name}</h2>
              <p class="mt-4 text-neutral-600 leading-relaxed">{domain.description}</p>
              <a
                href={domain.href}
                class="mt-6 inline-flex items-center font-display text-sm font-semibold text-brand-500 hover:underline"
              >
                Explore {domain.name} &rarr;
              </a>
            </div>
            <div class="mt-8 lg:mt-0 lg:w-72 flex-shrink-0">
              <h3 class="font-display text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-3">
                Solutions
              </h3>
              <ul class="space-y-2">
                {domain.solutions.map((sol) => (
                  <li>
                    <a
                      href={sol.href}
                      class="group flex items-center gap-2 text-sm text-neutral-700 hover:text-brand-600"
                    >
                      <span class="h-1.5 w-1.5 rounded-full bg-brand-400 group-hover:bg-brand-600" />
                      {sol.name}
                    </a>
                  </li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      ))}
    </div>
  </Section>

  <!-- Network convergence callout -->
  <Section divider dark>
    <div class="mx-auto max-w-3xl text-center">
      <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-white/60 mb-4">Convergence</p>
      <h2 class="font-display text-2xl font-bold text-white sm:text-3xl">
        One Platform for Every Signal Path
      </h2>
      <p class="mt-4 text-lg text-white/70 leading-relaxed">
        Satellite telemetry, fiber backhaul, broadcast contribution feeds — Quatro normalizes data across protocols and vendors into a single operational view. 8,000+ connectors, zero vendor lock-in.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-6 text-sm text-white/50">
        <span>DVB-S2 / DVB-T2</span>
        <span>&middot;</span>
        <span>SNMP / MQTT / gRPC</span>
        <span>&middot;</span>
        <span>CCSDS Telemetry</span>
      </div>
    </div>
  </Section>

  <CtaBanner
    title="See Quatro for Network Operations"
    description="Pick one challenge. We deploy on your systems in 4 weeks. You see the value before you commit."
    primaryCta={{ label: 'Schedule an Assessment', href: '/contact/demo' }}
    secondaryCta={{ label: 'Talk to an Engineer', href: '/contact/sales' }}
  />
</MarketingLayout>
