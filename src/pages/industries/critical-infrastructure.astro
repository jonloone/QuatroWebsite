---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import Hero from '@/components/marketing/Hero.astro'
import Section from '@/components/marketing/Section.astro'
import CtaBanner from '@/components/marketing/CtaBanner.astro'

const domains = [
  {
    name: 'Cities & Municipal',
    description: 'Unified operational intelligence for smart city operations — traffic management, public safety, utilities coordination, and municipal service delivery. Connect siloed city systems into a single command picture.',
    href: '/industries/cities',
    solutions: [
      { name: 'Operational Intelligence', href: '/solutions/operational-intelligence' },
      { name: 'Physical Security', href: '/solutions/physical-security' },
      { name: 'Asset Monitoring', href: '/solutions/asset-monitoring' },
    ],
  },
  {
    name: 'Water & Environment',
    description: 'Leak detection, water quality monitoring, and environmental compliance intelligence. Quatro connects SCADA, IoT sensors, and regulatory systems to protect water networks and natural resources.',
    href: '/industries/water-environment',
    solutions: [
      { name: 'Water Systems', href: '/solutions/water-systems' },
      { name: 'Environmental Compliance', href: '/solutions/environmental-compliance' },
    ],
  },
  {
    name: 'Transportation',
    description: 'Port, airport, and corridor intelligence — unified visibility across cargo flows, passenger operations, and transportation networks. Real-time situational awareness for the systems that move people and goods.',
    href: '/industries/transportation',
    solutions: [
      { name: 'Port Operations', href: '/solutions/port-operations' },
      { name: 'Airport Operations', href: '/solutions/airport-operations' },
      { name: 'Corridor Intelligence', href: '/solutions/corridor-intelligence' },
    ],
  },
  {
    name: 'Infrastructure',
    description: 'Critical infrastructure protection for utilities, telecommunications, and essential services. Quatro provides unified monitoring, threat detection, and compliance across distributed infrastructure assets.',
    href: '/industries/infrastructure',
    solutions: [
      { name: 'Pipeline Security', href: '/solutions/pipeline-security' },
      { name: 'Asset Monitoring', href: '/solutions/asset-monitoring' },
      { name: 'Fleet & Logistics', href: '/solutions/fleet-logistics' },
    ],
  },
]
---

<MarketingLayout
  title="Critical Infrastructure — Cities, Water, Transportation & Built Environment"
  description="Intelligence for the systems cities and nations depend on — water networks, transportation corridors, municipal operations, and the built environment."
>
  <Hero
    variant="dark"
    eyebrow="Critical Infrastructure"
    title="Intelligence for the Systems That Cities Depend On"
    description="Water networks, transportation corridors, municipal operations — Quatro connects the siloed systems that keep critical infrastructure running."
    primaryCta={{ label: 'Schedule an Assessment', href: '/contact/demo' }}
  />

  <Section>
    <div class="grid gap-8 md:grid-cols-2">
      {domains.map((domain) => (
        <div class="rounded-2xl border border-neutral-200 bg-white p-8 shadow-sm flex flex-col">
          <h2 class="font-display text-xl font-bold text-neutral-800">{domain.name}</h2>
          <p class="mt-3 text-sm text-neutral-600 leading-relaxed flex-1">{domain.description}</p>
          <div class="mt-6">
            <h3 class="font-display text-xs font-semibold text-neutral-400 uppercase tracking-wider mb-2">
              Solutions
            </h3>
            <ul class="space-y-1.5">
              {domain.solutions.map((sol) => (
                <li>
                  <a
                    href={sol.href}
                    class="group flex items-center gap-2 text-sm text-neutral-700 hover:text-brand-600"
                  >
                    <span class="h-1.5 w-1.5 rounded-full bg-brand-400 group-hover:bg-brand-600" />
                    {sol.name}
                  </a>
                </li>
              ))}
            </ul>
          </div>
          <a
            href={domain.href}
            class="mt-6 inline-flex items-center font-display text-sm font-semibold text-brand-500 hover:underline"
          >
            Explore {domain.name} &rarr;
          </a>
        </div>
      ))}
    </div>
  </Section>

  <!-- Public sector callout -->
  <Section divider dark>
    <div class="mx-auto max-w-3xl text-center">
      <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-white/60 mb-4">Public Sector</p>
      <h2 class="font-display text-2xl font-bold text-white sm:text-3xl">
        Built for Regulated Environments
      </h2>
      <p class="mt-4 text-lg text-white/70 leading-relaxed">
        On-premise or sovereign cloud. Compliance-ready architecture for municipal, state, and federal requirements. Quatro integrates with your existing SCADA, GIS, and BMS systems — no rip-and-replace.
      </p>
      <div class="mt-8 flex flex-wrap justify-center gap-6 text-sm text-white/50">
        <span>NERC CIP Ready</span>
        <span>&middot;</span>
        <span>SOC 2 Type II</span>
        <span>&middot;</span>
        <span>On-Premise Deployment</span>
      </div>
    </div>
  </Section>

  <CtaBanner
    title="See Quatro for Critical Infrastructure"
    description="Pick one challenge. We deploy on your systems in 4 weeks. You see the value before you commit."
    primaryCta={{ label: 'Schedule an Assessment', href: '/contact/demo' }}
    secondaryCta={{ label: 'Talk to an Engineer', href: '/contact/sales' }}
  />
</MarketingLayout>
