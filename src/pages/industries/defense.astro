---
import { getCollection } from 'astro:content'
import BaseLayout from '@/layouts/BaseLayout.astro'
import SiteHeader from '@/components/layout/SiteHeader.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'

const allIndustries = await getCollection('industries')
const industry = allIndustries.find((i) => i.id === 'defense' || i.id === 'defense.md')
if (!industry) throw new Error('Defense industry content not found')

const { title, tagline, description, hero, heroImage, capabilities, challenges, platformMapping, programs, cta } = industry.data

const ctaPrimary = cta?.primary || { label: 'Talk to Our Team', href: '/contact/demo' }
const ctaSecondary = cta?.secondary || { label: 'Request a Brief', href: '/contact/sales' }

// Related insights
const allInsights = await getCollection('insights')
const relatedInsights = allInsights
  .filter(i => i.data.industry === 'defense' || i.data.tags?.includes('defense') || i.data.tags?.includes('national-security'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 3)
---

<BaseLayout
  title={`${title} — ${tagline}`}
  description={description}
  lang="en"
>
  <SiteHeader lang="en" />

  <!-- ═══════════════════════════════════════════════════════════════
       1. HERO — Dither canvas, full-bleed (matching [slug].astro)
       ═══════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden" style="height: clamp(520px, 75vh, 780px); background: #0f2e24;" data-dither-section data-nav-dark>

    <!-- Bayer 4×4 dither canvas — full bleed background -->
    <canvas
      class="absolute inset-0 w-full h-full z-[1]"
      data-dither-canvas
      data-image-src={heroImage || '/images/hero-bg.png'}
      data-pixel-size="1"
      data-base-speed="0.06"
      data-hover-speed="0.06"
      data-green-blend="0.25"
    ></canvas>

    <!-- Full overlay — base darkening -->
    <div class="absolute inset-0 pointer-events-none z-[2]" style="background: rgba(10,30,22,0.45);"></div>
    <!-- Center radial for text contrast -->
    <div class="absolute inset-0 pointer-events-none z-[3]" style="background: radial-gradient(ellipse 80% 55% at 50% 42%, rgba(10,30,22,0.55) 0%, transparent 70%);"></div>
    <!-- Bottom gradient -->
    <div class="absolute inset-0 pointer-events-none z-[4]" style="background: linear-gradient(to top, rgba(10,30,22,0.6) 0%, rgba(10,30,22,0.2) 20%, transparent 40%);"></div>

    <!-- Centered content -->
    <div class="relative z-10 flex flex-col items-center justify-center h-full pt-20 px-8 lg:px-16 text-center">
      <div class="max-w-4xl">
        <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-white/60 mb-8">
          {hero.eyebrow}
        </p>
        <h1 class="font-sans font-light text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl leading-[1.05] tracking-tight text-white">
          {hero.title}
        </h1>
        <p class="mt-8 font-display text-lg lg:text-xl leading-relaxed text-white/90 max-w-2xl mx-auto">
          {hero.description}
        </p>
        <div class="mt-10">
          <a href={ctaPrimary.href} class="group inline-flex items-center gap-3 font-mono text-xs uppercase tracking-[0.08em] px-8 py-4 rounded-full transition-all duration-300 ease-out hover:scale-[1.03] hover:shadow-lg" style="background-color: var(--color-forest); color: white;">
            {ctaPrimary.label}
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       2. THE INTELLIGENCE GAP — Light editorial 35/65
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-24 lg:py-32 px-8 lg:px-12">
    <div class="mx-auto max-w-5xl">

      <div class="grid grid-cols-1 lg:grid-cols-[35%_1fr] gap-12 lg:gap-20 fade-up">
        <div>
          <p class="font-mono text-[10px] uppercase tracking-[0.1em]" style="color: var(--color-forest);">The Intelligence Gap</p>
        </div>
        <div>
          <h2 class="font-sans font-light text-2xl lg:text-3xl leading-[1.2] tracking-tight mb-6" style="color: var(--color-neutral-800);">
            {challenges[0]?.title}
          </h2>
          <p class="font-sans text-base lg:text-lg leading-relaxed" style="color: var(--color-neutral-500);">
            {challenges[0]?.description}
          </p>
        </div>
      </div>

      <div class="my-16 lg:my-20" style="border-top: 1px solid var(--color-structure);"></div>

      <div class="grid grid-cols-1 lg:grid-cols-[35%_1fr] gap-12 lg:gap-20 fade-up">
        <div>
          <p class="font-mono text-[10px] uppercase tracking-[0.1em]" style="color: var(--color-forest);">What Operators Face</p>
        </div>
        <div class="space-y-8">
          {challenges.slice(1).map((challenge, i) => (
            <div class="grid grid-cols-1 sm:grid-cols-[40px_1fr] gap-4 items-start">
              <p class="font-mono text-[10px] uppercase tracking-[0.1em] pt-1" style="color: var(--color-forest);">
                {String(i + 1).padStart(2, '0')}
              </p>
              <div>
                <h3 class="font-sans text-lg font-medium tracking-tight mb-2" style="color: var(--color-neutral-800);">{challenge.title}</h3>
                <p class="font-sans text-base leading-relaxed" style="color: var(--color-neutral-500);">{challenge.description}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       3. INTELLIGENCE DOMAINS — Each domain as editorial row with image
       ═══════════════════════════════════════════════════════════════ -->
  {programs && programs.length > 0 && (
    <section class="py-24 lg:py-32 px-8 lg:px-12" style="background: var(--color-paper); border-top: 1px solid var(--color-structure);">
      <div class="mx-auto max-w-5xl">

        <div class="grid grid-cols-1 lg:grid-cols-[35%_1fr] gap-12 lg:gap-20 mb-16 lg:mb-24 fade-up">
          <div>
            <p class="font-mono text-[10px] uppercase tracking-[0.1em]" style="color: var(--color-forest);">Intelligence Domains</p>
          </div>
          <div>
            <h2 class="font-sans font-light text-2xl lg:text-4xl leading-[1.2] tracking-tight mb-6" style="color: var(--color-neutral-800);">
              Health. Safety. Sustainability.
            </h2>
            <p class="font-sans text-base lg:text-lg leading-relaxed" style="color: var(--color-neutral-500);">
              Each domain delivers intelligence from day one — independently. As they connect through a shared sovereign model, a national picture emerges: community signals inform territorial operations, environmental intelligence feeds back into public safety, and every domain compounds the value of every other.
            </p>
          </div>
        </div>

        {programs.map((program, i) => (
          <div
            class={`grid grid-cols-1 lg:grid-cols-2 gap-10 lg:gap-16 items-center fade-up ${i > 0 ? 'mt-16 lg:mt-20 pt-16 lg:pt-20' : ''}`}
            style={i > 0 ? 'border-top: 1px solid var(--color-structure);' : ''}
          >
            <!-- Image — sage-green monotone treatment -->
            <div class={`relative overflow-hidden ${i % 2 === 1 ? 'lg:order-2' : ''}`}>
              {program.image ? (
                <div class="relative aspect-[4/3] overflow-hidden">
                  <img
                    src={program.image}
                    alt=""
                    class="absolute inset-0 w-full h-full object-cover"
                    style="filter: grayscale(100%) contrast(0.75) brightness(1.05);"
                    loading="lazy"
                    aria-hidden="true"
                  />
                  <div class="absolute inset-0" style="background-color: rgba(180, 190, 170, 0.55); mix-blend-mode: multiply;"></div>
                  <div class="absolute inset-0" style="background-color: rgba(210, 215, 200, 0.25); mix-blend-mode: screen;"></div>
                  <div class="absolute inset-0 opacity-[0.04] pointer-events-none"
                    style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%270 0 256 256%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cfilter id=%27noise%27%3E%3CfeTurbulence type=%27fractalNoise%27 baseFrequency=%270.65%27 numOctaves=%273%27 stitchTiles=%27stitch%27/%3E%3C/filter%3E%3Crect width=%27100%25%27 height=%27100%25%27 filter=%27url(%23noise)%27/%3E%3C/svg%3E');"></div>
                </div>
              ) : (
                <div class="aspect-[4/3]" style="background: var(--color-neutral-100);"></div>
              )}
            </div>

            <!-- Text -->
            <div class={`flex flex-col justify-center ${i % 2 === 1 ? 'lg:order-1' : ''}`}>
              <span class="font-mono text-[10px] uppercase tracking-[0.12em] mb-5" style="color: var(--color-forest);">
                Domain {String(i + 1).padStart(2, '0')}
              </span>
              <h3 class="font-sans font-light text-2xl lg:text-3xl tracking-tight leading-[1.15] mb-5" style="color: var(--color-neutral-800);">
                {program.name}
              </h3>
              <p class="font-sans text-base lg:text-lg leading-relaxed mb-5" style="color: var(--color-neutral-500);">
                {program.description}
              </p>
              {program.domains && (
                <p class="font-mono text-[10px] uppercase tracking-[0.1em]" style="color: var(--color-neutral-400);">
                  {program.domains}
                </p>
              )}
            </div>
          </div>
        ))}

      </div>
    </section>
  )}


  <!-- ═══════════════════════════════════════════════════════════════
       4. EDITORIAL PHOTO BREAK — Dither canvas with quote
       ═══════════════════════════════════════════════════════════════ -->
  <section class="relative overflow-hidden" style="height: clamp(400px, 50vh, 600px); background: #0f2e24;" data-dither-section data-nav-dark>
    <canvas
      class="absolute inset-0 w-full h-full z-[1]"
      data-dither-canvas
      data-image-src={heroImage || '/images/hero-bg.png'}
      data-pixel-size="1"
      data-base-speed="0.04"
      data-hover-speed="0.04"
      data-green-blend="0.3"
    ></canvas>
    <div class="absolute inset-0 pointer-events-none z-[2]" style="background: rgba(10,30,22,0.55);"></div>
    <div class="absolute inset-0 pointer-events-none z-[3]" style="background: linear-gradient(to bottom, rgba(10,30,22,0.7) 0%, rgba(10,30,22,0.3) 50%, rgba(10,30,22,0.5) 100%);"></div>

    <div class="relative z-10 h-full flex items-center px-8 lg:px-12">
      <div class="mx-auto max-w-5xl w-full grid grid-cols-1 lg:grid-cols-[35%_1fr] gap-8 lg:gap-20">
        <div>
          <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-white/50">The Integrator Approach</p>
        </div>
        <div>
          <p class="font-sans font-light text-xl lg:text-2xl leading-relaxed text-white/90" style="max-width: 520px;">
            We don't replace your systems. We connect them — hardware, software, and domain expertise — into one sovereign model that makes every system more intelligent than it could ever be alone.
          </p>
        </div>
      </div>
    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       5. SOVEREIGN INFRASTRUCTURE — Light editorial with capabilities
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-24 lg:py-32 px-8 lg:px-12">
    <div class="mx-auto max-w-5xl">

      <div class="grid grid-cols-1 lg:grid-cols-[35%_1fr] gap-12 lg:gap-20 fade-up">
        <div>
          <p class="font-mono text-[10px] uppercase tracking-[0.1em]" style="color: var(--color-forest);">Sovereign Infrastructure</p>
        </div>
        <div>
          <h2 class="font-sans font-light text-2xl lg:text-3xl leading-[1.2] tracking-tight mb-10" style="color: var(--color-neutral-800);">
            What makes every domain sovereign.
          </h2>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-8">
            {capabilities.map((cap) => (
              <div>
                <h3 class="font-sans text-base font-medium tracking-tight mb-2" style="color: var(--color-neutral-800);">{cap.name}</h3>
                <p class="font-sans text-sm leading-relaxed mb-2" style="color: var(--color-neutral-500);">{cap.description}</p>
                {cap.outcome && (
                  <p class="font-display text-xs font-semibold" style="color: var(--color-forest);">{cap.outcome}</p>
                )}
              </div>
            ))}
          </div>
        </div>
      </div>

    </div>
  </section>


  <!-- ═══════════════════════════════════════════════════════════════
       6. HOW IT WORKS — Connect / Understand / Act
       ═══════════════════════════════════════════════════════════════ -->
  {platformMapping && (
    <section class="py-24 lg:py-32 px-8 lg:px-12" style="border-top: 1px solid var(--color-structure);">
      <div class="mx-auto max-w-5xl">
        <div class="grid grid-cols-1 lg:grid-cols-[35%_1fr] gap-12 lg:gap-20 fade-up">
          <div>
            <p class="font-mono text-[10px] uppercase tracking-[0.1em]" style="color: var(--color-forest);">How It Works</p>
          </div>
          <div>
            <h2 class="font-sans font-light text-2xl lg:text-3xl leading-[1.2] tracking-tight mb-10" style="color: var(--color-neutral-800);">
              Connect. Understand. Act.
            </h2>

            <div class="space-y-10">
              <div class="grid grid-cols-1 sm:grid-cols-[40px_1fr] gap-4 items-start">
                <p class="font-mono text-[10px] uppercase tracking-[0.1em] pt-1" style="color: var(--color-forest);">01</p>
                <div>
                  <h3 class="font-sans text-base font-medium tracking-tight mb-2" style="color: var(--color-neutral-800);">Connect</h3>
                  <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">{platformMapping.see}</p>
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-[40px_1fr] gap-4 items-start">
                <p class="font-mono text-[10px] uppercase tracking-[0.1em] pt-1" style="color: var(--color-forest);">02</p>
                <div>
                  <h3 class="font-sans text-base font-medium tracking-tight mb-2" style="color: var(--color-neutral-800);">Understand</h3>
                  <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">{platformMapping.understand}</p>
                </div>
              </div>

              <div class="grid grid-cols-1 sm:grid-cols-[40px_1fr] gap-4 items-start">
                <p class="font-mono text-[10px] uppercase tracking-[0.1em] pt-1" style="color: var(--color-forest);">03</p>
                <div>
                  <h3 class="font-sans text-base font-medium tracking-tight mb-2" style="color: var(--color-neutral-800);">Act</h3>
                  <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">{platformMapping.orchestrate}</p>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </section>
  )}


  <!-- ═══════════════════════════════════════════════════════════════
       7. RELATED INSIGHTS
       ═══════════════════════════════════════════════════════════════ -->
  {relatedInsights.length > 0 && (
    <section class="py-20 lg:py-28 px-6 lg:px-12" style="border-top: 1px solid var(--color-structure);">
      <div class="mx-auto max-w-6xl">
        <div class="flex items-baseline justify-between mb-12 fade-up">
          <div>
            <p class="font-mono text-[10px] uppercase tracking-[0.12em] mb-3" style="color: var(--color-neutral-400);">From Our Thinking</p>
            <h2 class="font-display text-2xl font-bold sm:text-3xl tracking-tight" style="color: var(--color-neutral-800);">
              {title} Intelligence
            </h2>
          </div>
          <a href="/insights" class="font-mono text-xs uppercase tracking-[0.05em] hidden sm:inline-flex items-center gap-2 transition-colors hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);">
            All Insights &rarr;
          </a>
        </div>

        <div class={`grid grid-cols-1 ${relatedInsights.length >= 3 ? 'sm:grid-cols-3' : relatedInsights.length === 2 ? 'sm:grid-cols-2' : ''} gap-6`}>
          {relatedInsights.map((insight) => (
            <a
              href={`/insights/${insight.id.replace(/\.md$/, '')}`}
              class="group block fade-up"
            >
              {insight.data.heroImage && (
                <div class="relative aspect-[16/10] overflow-hidden mb-4">
                  <img
                    src={insight.data.heroImage}
                    alt=""
                    class="absolute inset-0 w-full h-full object-cover"
                    style="filter: grayscale(100%) contrast(0.75) brightness(1.05);"
                    loading="lazy"
                    aria-hidden="true"
                  />
                  <div class="absolute inset-0" style="background-color: rgba(180, 190, 170, 0.55); mix-blend-mode: multiply;"></div>
                  <div class="absolute inset-0" style="background-color: rgba(210, 215, 200, 0.25); mix-blend-mode: screen;"></div>
                </div>
              )}
              <p class="font-mono text-[10px] uppercase tracking-[0.1em] mb-2" style="color: var(--color-forest);">
                {insight.data.category.replace('-', ' ')}
                {insight.data.readingTime && <span class="text-neutral-400 ml-2">· {insight.data.readingTime}</span>}
              </p>
              <h3 class="font-display text-base font-semibold leading-snug mb-2 transition-colors group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">
                {insight.data.title}
              </h3>
              <p class="font-sans text-sm leading-relaxed line-clamp-2" style="color: var(--color-neutral-500);">
                {insight.data.excerpt}
              </p>
            </a>
          ))}
        </div>
      </div>
    </section>
  )}


  <!-- ═══════════════════════════════════════════════════════════════
       8. CTA — Clean, light (Partners style)
       ═══════════════════════════════════════════════════════════════ -->
  <section class="relative py-32 lg:py-44 px-8 lg:px-12 overflow-hidden">
    <div class="absolute inset-0 opacity-[0.025] pointer-events-none"
      style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%270 0 256 256%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cfilter id=%27noise%27%3E%3CfeTurbulence type=%27fractalNoise%27 baseFrequency=%270.65%27 numOctaves=%273%27 stitchTiles=%27stitch%27/%3E%3C/filter%3E%3Crect width=%27100%25%27 height=%27100%25%27 filter=%27url(%23noise)%27/%3E%3C/svg%3E');"></div>
    <div class="relative z-10 mx-auto max-w-5xl fade-up">

      <h2 class="font-sans font-light text-3xl sm:text-4xl lg:text-6xl leading-[1.1] tracking-tight mb-8" style="color: var(--color-neutral-800);">
        See what national intelligence<br />looks like when the systems<br />that matter are connected.
      </h2>

      <p class="font-sans text-base lg:text-lg leading-relaxed max-w-2xl mb-10" style="color: var(--color-neutral-500);">
        Tell us what your nation needs to protect. We connect the systems that hold the answer — health, safety, sustainability — into one sovereign model your team owns from day one.
      </p>

      <div class="flex flex-col sm:flex-row items-start gap-4">
        <a href={ctaPrimary.href} class="group inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.08em] px-8 py-4 rounded-full transition-all duration-300 ease-out hover:scale-105" style="background-color: var(--color-forest); color: white;">
          {ctaPrimary.label}
          <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
        <a href={ctaSecondary.href} class="group inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.08em] px-8 py-4 rounded-full transition-all duration-300 ease-out hover:scale-105" style="border: 1px solid var(--color-structure); color: var(--color-neutral-600);">
          {ctaSecondary.label}
          <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
        </a>
      </div>

      <p class="mt-6 font-mono text-[10px] uppercase tracking-[0.1em]" style="color: var(--color-neutral-400);">
        {cta?.microcopy || 'Intelligence in weeks · Your team owns it from day one'}
      </p>

    </div>
  </section>

  <SiteFooter lang="en" />

  <!-- Bayer 4×4 dither engine — auto-initializes [data-dither-canvas] -->
  <script>
    const bayer4x4 = [
      [ 0/16,  8/16,  2/16, 10/16],
      [12/16,  4/16, 14/16,  6/16],
      [ 3/16, 11/16,  1/16,  9/16],
      [15/16,  7/16, 13/16,  5/16]
    ];

    function initDither(canvas: HTMLCanvasElement) {
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      const imageSrc = canvas.dataset.imageSrc || '/images/hero-bg.png';
      const pixelSize = parseInt(canvas.dataset.pixelSize || '2', 10);
      const baseSpeed = parseFloat(canvas.dataset.baseSpeed || '0.06');
      const hoverSpeed = parseFloat(canvas.dataset.hoverSpeed || '0.3');
      const greenBlend = parseFloat(canvas.dataset.greenBlend || '0.25');

      const card = canvas.closest('[data-dither-section]') as HTMLElement;
      let isHovered = false;
      let animId: number;
      let startTime = performance.now();

      const bgImg = new Image();
      bgImg.crossOrigin = 'anonymous';
      bgImg.src = imageSrc;

      const offscreen = document.createElement('canvas');
      const offCtx = offscreen.getContext('2d')!;
      let imgLoaded = false;
      bgImg.onload = () => { imgLoaded = true; };

      function resize() {
        const rect = canvas.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;
      }

      function render(time: number) {
        if (!ctx) return;
        const w = canvas.width;
        const h = canvas.height;
        if (w === 0 || h === 0) { animId = requestAnimationFrame(render); return; }

        const elapsed = (time - startTime) / 1000;
        const speed = isHovered ? hoverSpeed : baseSpeed;
        const t = elapsed * speed;

        let srcPixels: Uint8ClampedArray | null = null;
        if (imgLoaded) {
          offscreen.width = w;
          offscreen.height = h;
          // Cover-fit
          const imgAspect = bgImg.naturalWidth / bgImg.naturalHeight;
          const canvasAspect = w / h;
          let sx = 0, sy = 0, sw = bgImg.naturalWidth, sh = bgImg.naturalHeight;
          if (imgAspect > canvasAspect) {
            sw = bgImg.naturalHeight * canvasAspect;
            sx = (bgImg.naturalWidth - sw) / 2;
          } else {
            sh = bgImg.naturalWidth / canvasAspect;
            sy = (bgImg.naturalHeight - sh) / 2;
          }
          offCtx.drawImage(bgImg, sx, sy, sw, sh, 0, 0, w, h);
          srcPixels = offCtx.getImageData(0, 0, w, h).data;
        }

        const imageData = ctx.createImageData(w, h);
        const data = imageData.data;
        const cols = Math.ceil(w / pixelSize);
        const rows = Math.ceil(h / pixelSize);

        for (let row = 0; row < rows; row++) {
          for (let col = 0; col < cols; col++) {
            const centerX = col * pixelSize + (pixelSize >> 1);
            const centerY = row * pixelSize + (pixelSize >> 1);

            let sR = 0, sG = 0, sB = 0;
            let imgBrightness = 0.3;

            if (srcPixels && centerX < w && centerY < h) {
              const sIdx = (centerY * w + centerX) * 4;
              sR = srcPixels[sIdx]; sG = srcPixels[sIdx+1]; sB = srcPixels[sIdx+2];
              imgBrightness = (sR * 0.299 + sG * 0.587 + sB * 0.114) / 255;
            }

            const cx = col / cols;
            const cy = row / rows;

            const warpX = 0.12 * Math.sin(cy * 5.0 + t * 1.3) + 0.08 * Math.cos(cx * 4.0 + t * 0.9);
            const warpY = 0.12 * Math.cos(cx * 5.0 + t * 1.1) + 0.08 * Math.sin(cy * 4.0 + t * 1.5);
            const wx = cx + warpX;
            const wy = cy + warpY;
            const d1 = Math.sqrt((wx - 0.5) ** 2 + (wy - 0.5) ** 2);
            const warpIntensity = 0.3 + 0.25 * Math.sin(d1 * 8.0 - t * 2.0) + 0.15 * Math.cos((wx + wy) * 6.0 + t);

            let intensity = imgBrightness * 0.85 + warpIntensity * 0.35;
            intensity = Math.max(0, Math.min(1, intensity));

            const threshold = bayer4x4[row % 4][col % 4];
            const on = intensity > threshold;

            let r: number, g: number, b: number, a: number;
            if (on) {
              const blend = greenBlend + (1 - greenBlend) * 0.2 * warpIntensity;
              r = Math.round(sR * (1 - blend) + 80  * blend);
              g = Math.round(sG * (1 - blend) + 185 * blend);
              b = Math.round(sB * (1 - blend) + 140 * blend);
              a = Math.round(intensity * 160 + 95);
            } else {
              r = 0; g = 0; b = 0; a = 0;
            }

            for (let py = 0; py < pixelSize; py++) {
              for (let px = 0; px < pixelSize; px++) {
                const x = col * pixelSize + px;
                const y = row * pixelSize + py;
                if (x >= w || y >= h) continue;
                const idx = (y * w + x) * 4;
                data[idx]     = r;
                data[idx + 1] = g;
                data[idx + 2] = b;
                data[idx + 3] = a;
              }
            }
          }
        }

        ctx.putImageData(imageData, 0, 0);
        animId = requestAnimationFrame(render);
      }

      if (card) {
        card.addEventListener('mouseenter', () => { isHovered = true; });
        card.addEventListener('mouseleave', () => { isHovered = false; });
      }

      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            resize();
            startTime = performance.now();
            animId = requestAnimationFrame(render);
          } else {
            cancelAnimationFrame(animId);
          }
        });
      }, { threshold: 0.1 });

      window.addEventListener('resize', resize);
      observer.observe(canvas);
    }

    document.querySelectorAll<HTMLCanvasElement>('[data-dither-canvas]').forEach(initDither);
  </script>

</BaseLayout>
