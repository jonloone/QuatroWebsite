---
import { getCollection } from 'astro:content'
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import HeroCanvas from '@/components/marketing/HeroCanvas.astro'
import StatStrip from '@/components/marketing/StatStrip.astro'
import Section from '@/components/marketing/Section.astro'
import FeatureGrid from '@/components/marketing/FeatureGrid.astro'
import DualCta from '@/components/marketing/DualCta.astro'
import PlatformMapSection from '@/components/marketing/PlatformMapSection.astro'
import ProofPointCard from '@/components/marketing/ProofPointCard.astro'

export async function getStaticPaths() {
  const useCases = await getCollection('use-cases')
  return useCases.map((useCase) => ({
    params: {
      industry: useCase.data.parentIndustry,
      slug: useCase.id.replace(/\.md$/, ''),
    },
    props: { useCase },
  }))
}

const { useCase } = Astro.props
const { Content } = await useCase.render()
const {
  title,
  tagline,
  description,
  parentIndustry,
  hero,
  pain,
  capabilities,
  stats,
  platformMapping,
  proofPoint,
  objections,
  adjacentSolutions,
  crossVertical,
  cta,
} = useCase.data

const ctaPrimary = cta?.primary || { label: 'Talk to Our Team', href: '/contact/demo' }
const ctaSecondary = cta?.secondary || { label: 'Talk to an Engineer', href: '/contact/sales' }

// Get sibling use cases for the same industry
const allUseCases = await getCollection('use-cases')
const siblings = allUseCases
  .filter((uc) => uc.data.parentIndustry === parentIndustry && uc.id !== useCase.id)
  .sort((a, b) => a.data.order - b.data.order)
---

<MarketingLayout
  title={`${title} — ${tagline}`}
  description={description}
>
  <HeroCanvas
    badge={hero.eyebrow}
    title={hero.title}
    body={hero.description}
    ctaLabel={hero.primaryCta?.label || 'Talk to Our Team'}
    ctaHref={hero.primaryCta?.href || '/contact/demo'}
  />

  <StatStrip stats={stats} />

  <!-- Pain Section — PAS Narrative with Quantified Metrics -->
  <Section divider>
    <div class="mx-auto max-w-3xl">
      <h2 class="font-display text-2xl font-bold tracking-tight text-neutral-800 sm:text-3xl">
        The Challenge
      </h2>
      <div class="mt-6 prose prose-neutral max-w-none text-neutral-600 leading-relaxed">
        <p>{pain.narrative}</p>
      </div>

      {pain.quantified.length > 0 && (
        <div class="mt-8 overflow-hidden rounded-xl border border-neutral-200">
          <table class="w-full text-left text-sm">
            <thead>
              <tr class="border-b border-neutral-200 bg-neutral-50">
                <th class="px-4 py-3 font-display font-semibold text-neutral-800">Metric</th>
                <th class="px-4 py-3 font-display font-semibold text-neutral-800">Before Quatro</th>
                <th class="px-4 py-3 font-display font-semibold text-brand-600">With Quatro</th>
              </tr>
            </thead>
            <tbody>
              {pain.quantified.map((row, i) => (
                <tr class={i % 2 === 0 ? 'bg-white' : 'bg-neutral-50'}>
                  <td class="px-4 py-3 font-medium text-neutral-700">{row.metric}</td>
                  <td class="px-4 py-3 text-neutral-500">{row.before}</td>
                  <td class="px-4 py-3 font-semibold text-brand-600">{row.after}</td>
                </tr>
              ))}
            </tbody>
          </table>
        </div>
      )}
    </div>
  </Section>

  <!-- Capabilities — What Changes Day-to-Day -->
  <Section divider dark>
    <FeatureGrid
      dark
      title="How Quatro Solves This"
      subtitle={`Capabilities purpose-built for ${title.toLowerCase()}.`}
      features={capabilities.map(c => ({ name: c.name, description: c.description, icon: c.icon || '⚡' }))}
      columns={3}
    />
  </Section>

  <!-- Platform Mapping -->
  {platformMapping && (
    <PlatformMapSection
      see={platformMapping.see}
      understand={platformMapping.understand}
      orchestrate={platformMapping.orchestrate}
    />
  )}

  <!-- Proof Point — hidden until real case studies are available -->

  <!-- Objection Handling — Woven Into Narrative -->
  {objections && objections.length > 0 && (
    <Section divider>
      <div class="mx-auto max-w-3xl space-y-6">
        {objections.map((obj) => (
          <div class="rounded-xl border border-neutral-200 bg-neutral-50 p-6">
            <p class="text-sm font-medium text-neutral-500 italic">"{obj.concern}"</p>
            <p class="mt-3 text-base text-neutral-800 font-medium">{obj.response}</p>
          </div>
        ))}
      </div>
    </Section>
  )}

  <!-- Cross-Vertical Credibility -->
  {crossVertical && crossVertical.length > 0 && (
    <Section divider>
      <div class="mx-auto max-w-4xl">
        <h3 class="font-display text-lg font-bold text-neutral-800 mb-6 text-center">
          This Pattern Works Across Industries
        </h3>
        <div class="grid gap-4 md:grid-cols-3">
          {crossVertical.map((cv) => (
            <div class="rounded-lg border border-neutral-200 bg-white p-4">
              <span class="text-xs font-mono font-bold uppercase tracking-wider text-brand-500">{cv.industry}</span>
              <p class="mt-2 text-sm text-neutral-600">{cv.result}</p>
            </div>
          ))}
        </div>
      </div>
    </Section>
  )}

  <!-- Adjacent Solutions — "If You're Solving This, You'll Also Want..." -->
  {adjacentSolutions && adjacentSolutions.length > 0 && (
    <Section divider>
      <div class="mx-auto max-w-4xl">
        <h3 class="font-display text-xl font-bold text-neutral-800 mb-2 text-center">
          If You're Solving This, You'll Also Want...
        </h3>
        <p class="text-center text-sm text-neutral-500 mb-8">
          Every capability connects to a unified operational picture. The more you connect, the more you see.
        </p>
        <div class="grid gap-6 md:grid-cols-3">
          {adjacentSolutions.map((adj) => (
            <a
              href={adj.href}
              class="group flex flex-col rounded-xl border border-neutral-200 bg-white p-5 transition-all hover:border-brand-300 hover:shadow-md"
            >
              <h4 class="font-display text-base font-bold text-neutral-800 group-hover:text-brand-600">
                {adj.title}
              </h4>
              <p class="mt-2 flex-1 text-sm text-neutral-600">{adj.description}</p>
              <span class="mt-3 text-sm font-semibold text-brand-500 group-hover:underline">
                Explore solution &rarr;
              </span>
            </a>
          ))}
        </div>
      </div>
    </Section>
  )}

  <!-- More From This Industry -->
  {siblings.length > 0 && (
    <Section divider>
      <div class="mx-auto max-w-4xl">
        <h3 class="font-display text-xl font-bold text-neutral-800 mb-6 text-center">
          More Solutions for This Industry
        </h3>
        <div class="grid gap-6 md:grid-cols-{siblings.length}">
          {siblings.map((sib) => (
            <a
              href={`/industries/${sib.data.parentIndustry}/${sib.id.replace(/\.md$/, '')}`}
              class="group flex flex-col rounded-xl border border-neutral-200 bg-white p-5 transition-all hover:border-brand-300 hover:shadow-md"
            >
              <h4 class="font-display text-base font-bold text-neutral-800 group-hover:text-brand-600">
                {sib.data.title}
              </h4>
              <p class="mt-2 flex-1 text-sm text-neutral-600">{sib.data.tagline}</p>
              <span class="mt-3 text-sm font-semibold text-brand-500 group-hover:underline">
                Explore solution &rarr;
              </span>
            </a>
          ))}
        </div>
      </div>
    </Section>
  )}

  <DualCta
    title={`See ${title} on Your Infrastructure`}
    description={`Tell us the outcome that matters. We connect the systems that hold the answer. Your team starts working from the model.`}
    primaryCta={ctaPrimary}
    secondaryCta={ctaSecondary}
    microcopy={cta?.microcopy || 'Intelligence in weeks · Your team owns it from day one'}
  />
</MarketingLayout>
