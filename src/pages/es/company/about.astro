---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import Hero from '@/components/marketing/Hero.astro'
import Section from '@/components/marketing/Section.astro'
import DualCta from '@/components/marketing/DualCta.astro'
import Placeholder from '@/components/marketing/Placeholder.astro'
---

<MarketingLayout
  lang="es"
  title="Nosotros — Nuestra Misión, Visión y Valores"
  description="Conozca la misión de Quatro: ofrecer inteligencia operacional a la velocidad de las operaciones."
>
  <Hero
    eyebrow="Sobre Quatro"
    title="Inteligencia Operacional a la Velocidad de las Operaciones"
    description="Estamos construyendo la utilidad de inteligencia operacional que permite a las organizaciones conectar, operar y comandar sus operaciones más críticas."
  />

  <Section>
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <h2 class="font-display text-2xl font-bold text-neutral-800">Nuestra Misión</h2>
        <p class="mt-4 text-lg text-neutral-600">
          Ofrecer inteligencia operacional que permita a las organizaciones ver todo, actuar más rápido y comandar con confianza.
        </p>
      </div>
      <Placeholder label="Company Image" class="min-h-[300px]" />
    </div>
  </Section>

  <DualCta
    title={`Vea cómo la <span style="color: var(--color-forest);">inteligencia operacional</span> funciona en su operación.`}
    description="Elija un desafío. Desplegamos en sus sistemas en 4 semanas. Vea el valor antes de comprometerse."
    primaryCta={{ label: 'Solicitar Evaluación', href: '/es/contact/demo' }}
    secondaryCta={{ label: 'Hablar con un Ingeniero', href: '/es/contact/sales' }}
    microcopy="Prueba de valor de 4 semanas · Acreditado en contrato anual"
  />
</MarketingLayout>
