---
import { getCollection } from 'astro:content'
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import Hero from '@/components/marketing/Hero.astro'
import Section from '@/components/marketing/Section.astro'
import StatStrip from '@/components/marketing/StatStrip.astro'
import DualCta from '@/components/marketing/DualCta.astro'

export async function getStaticPaths() {
  const caseStudies = await getCollection('case-studies-es')
  return caseStudies.map((caseStudy) => ({
    params: { slug: caseStudy.id.replace(/\.md$/, '') },
    props: { caseStudy },
  }))
}

const { caseStudy } = Astro.props
const { Content } = await caseStudy.render()
const { title, industryLabel, headline, excerpt, stats } = caseStudy.data
---

<MarketingLayout
  lang="es"
  title={`${title} — Caso de Éxito`}
  description={excerpt}
>
  <Hero
    eyebrow={industryLabel}
    title={headline}
    description={excerpt}
    primaryCta={{ label: 'Agende una Evaluación', href: '/es/contact/demo' }}
  />

  {stats && stats.length > 0 && <StatStrip stats={stats} />}

  <Section>
    <div class="prose prose-neutral mx-auto max-w-3xl prose-headings:font-display prose-headings:text-neutral-800 prose-h2:text-2xl prose-h3:text-lg prose-p:text-neutral-600 prose-strong:text-neutral-800 prose-ul:text-neutral-600 prose-li:text-neutral-600">
      <Content />
    </div>
  </Section>

  <DualCta
    title={`Vea cómo la <span style="color: var(--color-forest);">inteligencia operacional</span> funciona en su operación.`}
    description="Elija un desafío. Desplegamos en sus sistemas en 4 semanas. Vea el valor antes de comprometerse."
    primaryCta={{ label: 'Solicitar Evaluación', href: '/es/contact/demo' }}
    secondaryCta={{ label: 'Hablar con un Ingeniero', href: '/es/contact/sales' }}
    microcopy="Prueba de valor de 4 semanas · Acreditado en contrato anual"
  />
</MarketingLayout>
