---
import { getCollection } from 'astro:content'
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import Hero from '@/components/marketing/Hero.astro'
import Section from '@/components/marketing/Section.astro'
import DualCta from '@/components/marketing/DualCta.astro'

const caseStudies = (await getCollection('case-studies-es')).sort((a, b) => (a.data.order ?? 99) - (b.data.order ?? 99))
---

<MarketingLayout
  lang="es"
  title="Casos de Éxito — Historias de Clientes"
  description="Conozca cómo líderes operativos en diversas industrias han transformado sus operaciones con Quatro."
>
  <Hero
    eyebrow="Casos de Éxito"
    title="Resultados Reales. Operaciones Reales."
    description="Conozca cómo líderes operativos en energía, defensa, manufactura e infraestructura han transformado sus operaciones con Quatro."
    primaryCta={{ label: 'Agende una Evaluación', href: '/es/contact/demo' }}
  />

  <Section>
    <div class="grid gap-8 lg:grid-cols-2">
      {caseStudies.map((caseStudy) => (
        <a
          href={`/es/resources/case-studies/${caseStudy.id.replace(/\.md$/, '')}`}
          class="group flex flex-col rounded-2xl border border-neutral-200 bg-white p-8 transition-all hover:border-brand-300 hover:shadow-lg"
        >
          <span class="inline-block w-fit rounded-full bg-brand-100 px-3 py-1 text-xs font-normal text-brand-700">
            {caseStudy.data.industryLabel}
          </span>
          <h3 class="mt-4 font-display text-xl font-bold text-neutral-800 group-hover:text-brand-600">
            {caseStudy.data.headline}
          </h3>
          <p class="mt-3 flex-1 text-sm text-neutral-600">{caseStudy.data.excerpt}</p>
          {caseStudy.data.stats && (
            <div class="mt-6 flex flex-wrap gap-4">
              {caseStudy.data.stats.slice(0, 3).map((stat) => (
                <div class="text-center">
                  <div class="font-display text-lg font-bold text-brand-500">{stat.value}</div>
                  <div class="text-xs text-neutral-500">{stat.label}</div>
                </div>
              ))}
            </div>
          )}
          <span class="mt-6 text-sm font-normal text-brand-500 group-hover:underline">
            Leer la historia completa &rarr;
          </span>
        </a>
      ))}
    </div>
  </Section>

  <DualCta
    title={`Vea cómo la <span style="color: var(--color-forest);">inteligencia operacional</span> funciona en su operación.`}
    description="Elija un desafío. Desplegamos en sus sistemas en 4 semanas. Vea el valor antes de comprometerse."
    primaryCta={{ label: 'Solicitar Evaluación', href: '/es/contact/demo' }}
    secondaryCta={{ label: 'Hablar con un Ingeniero', href: '/es/contact/sales' }}
    microcopy="Prueba de valor de 4 semanas · Acreditado en contrato anual"
  />
</MarketingLayout>
