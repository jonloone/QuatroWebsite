---
import { getCollection } from 'astro:content'
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import Hero from '@/components/marketing/Hero.astro'
import Section from '@/components/marketing/Section.astro'
import CtaBanner from '@/components/marketing/CtaBanner.astro'

const industries = (await getCollection('industries-es')).sort((a, b) => a.data.order - b.data.order)
---

<MarketingLayout
  lang="es"
  title="Industrias — Inteligencia Operacional en Todos los Sectores"
  description="Quatro ofrece inteligencia operacional en entornos de energía, defensa, manufactura, infraestructura y ciudades inteligentes."
>
  <Hero
    variant="dark"
    eyebrow="Industrias"
    title="Construido para las Industrias que Construyen el Mundo"
    description="Desde energía hasta defensa, manufactura hasta ciudades inteligentes — Quatro ofrece inteligencia operacional adaptada a los desafíos únicos de su sector."
    primaryCta={{ label: 'Agende una Evaluación', href: '/es/contact/demo' }}
  />

  <Section>
    <div class="mb-12 text-center">
      <h2 class="font-display text-2xl font-bold tracking-tight text-neutral-800 sm:text-3xl">
        Explore Soluciones por Industria
      </h2>
    </div>

    <div class="grid gap-6 md:grid-cols-2 lg:grid-cols-3">
      {industries.map((industry) => (
        <a
          href={`/es/industries/${industry.id.replace(/\.md$/, '')}`}
          class="group flex flex-col rounded-2xl border border-neutral-200 bg-white p-6 transition-all hover:border-brand-300 hover:shadow-lg"
        >
          <h3 class="font-display text-xl font-bold text-neutral-800 group-hover:text-brand-600">
            {industry.data.title}
          </h3>
          <p class="mt-2 text-sm font-medium text-brand-500">{industry.data.hero.title}</p>
          <p class="mt-3 flex-1 text-sm text-neutral-600">{industry.data.description}</p>
          <div class="mt-4 flex flex-wrap gap-2">
            {industry.data.stats.slice(0, 2).map((stat) => (
              <span class="rounded-full bg-neutral-100 px-3 py-1 text-xs font-medium text-neutral-700">
                {stat.value} {stat.label}
              </span>
            ))}
          </div>
          <span class="mt-4 font-display text-sm font-semibold text-brand-500 group-hover:underline">
            Explorar soluciones &rarr;
          </span>
        </a>
      ))}
    </div>
  </Section>

  <CtaBanner
    title="Vea la Inteligencia Operacional en Su Industria"
    description="Descubra cómo Quatro responde a los desafíos únicos de su sector."
    primaryCta={{ label: 'Agende una Evaluación', href: '/es/contact/demo' }}
    secondaryCta={{ label: 'Hable con un Ingeniero', href: '/es/contact/sales' }}
  />
</MarketingLayout>
