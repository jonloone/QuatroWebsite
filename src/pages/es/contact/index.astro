---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
---

<MarketingLayout
  lang="es"
  title="Contacto — Cómo Empieza — Quatro"
  description="Díganos el desafío operacional que más importa. Conectamos los sistemas que tienen la respuesta."
>
  <!-- Dark hero with background image -->
  <section class="relative overflow-hidden bg-neutral-900" data-nav-dark>
    <div class="absolute inset-0">
      <img src="/images/hero-contact.png" alt="" class="h-full w-full object-cover" />
      <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(10,17,40,0.5) 0%, rgba(10,17,40,0.7) 60%, rgba(10,17,40,0.9) 100%);"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-8 lg:px-16 pt-32 sm:pt-40 pb-40 sm:pb-52 text-center">
      <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-white/40 mb-6">Cómo Empieza</p>
      <h1 class="font-sans font-light text-4xl sm:text-5xl lg:text-6xl xl:text-7xl leading-[1.05] tracking-tight text-white max-w-4xl mx-auto">
        Usted define el resultado.
      </h1>
      <p class="mt-6 font-display text-lg lg:text-xl leading-relaxed text-white/60 max-w-2xl mx-auto">
        Díganos el desafío operacional que más importa. Conectamos los sistemas que tienen la respuesta.
      </p>
    </div>
  </section>

  <!-- Cards overlapping upward into hero -->
  <div class="relative z-20 -mt-24 sm:-mt-32 pb-16 sm:pb-24">
    <div class="mx-auto max-w-4xl px-8 lg:px-16">
      <div class="grid gap-6 sm:grid-cols-3">
        <a href="/es/contact/demo" class="bg-white rounded-sm border border-neutral-200 shadow-xl p-8 hover:border-neutral-400 transition-all duration-150">
          <h3 class="font-display text-lg font-bold text-neutral-800">Empiece con un resultado</h3>
          <p class="mt-3 font-sans text-sm text-neutral-500 leading-relaxed">Nombre el desafío. Mapeamos los sistemas y mostramos cómo fluye la inteligencia.</p>
        </a>
        <a href="/es/contact/sales" class="bg-white rounded-sm border border-neutral-200 shadow-xl p-8 hover:border-neutral-400 transition-all duration-150">
          <h3 class="font-display text-lg font-bold text-neutral-800">Hable con un Ingeniero</h3>
          <p class="mt-3 font-sans text-sm text-neutral-500 leading-relaxed">Traiga su arquitectura y restricciones. Le mostramos cómo sus sistemas se conectan en un solo modelo.</p>
        </a>
        <a href="/es/contact/support" class="bg-white rounded-sm border border-neutral-200 shadow-xl p-8 hover:border-neutral-400 transition-all duration-150">
          <h3 class="font-display text-lg font-bold text-neutral-800">Obtener Soporte</h3>
          <p class="mt-3 font-sans text-sm text-neutral-500 leading-relaxed">¿Ya opera con Quatro? Le ayudamos a extender y escalar lo que ha construido.</p>
        </a>
      </div>
    </div>
  </div>
</MarketingLayout>
