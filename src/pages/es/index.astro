---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SiteHeader from '@/components/layout/SiteHeader.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
---

<BaseLayout
  title="Quatro — Inteligencia Operacional para Infraestructura Crítica"
  description="Quatro conecta más de 8,000 sistemas en una utilidad de inteligencia operacional — desplegable en semanas, no años. Diseñada para la infraestructura y la realidad operativa de América Latina."
  lang="es"
>

  <SiteHeader lang="es" />

  <!-- ═══════════════════════════════════════════════════════════════
       1. HERO — Full-screen background image
       ═══════════════════════════════════════════════════════════════ -->
  <section data-hero class="relative min-h-[85vh] lg:min-h-[90vh] flex items-end overflow-hidden px-6 pb-20 lg:pb-28">
    <!-- Background image -->
    <div class="absolute inset-0">
      <img src="/images/hero-bg.png" alt="" class="h-full w-full object-cover" />
      <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.5) 100%);"></div>
    </div>

    <!-- connect.png — bottom right graphic, overflows right edge -->
    <img src="/images/connect.png" alt="" class="absolute bottom-0 w-[90%] lg:w-[70%] object-contain pointer-events-none select-none" style="right: -20%;" />

    <div class="relative z-10 mx-auto max-w-5xl w-full text-left pt-16">
      <!-- Status badge -->
      <div class="inline-flex items-center gap-2.5 px-4 py-2 mb-10" style="background: rgba(255,255,255,0.1); backdrop-filter: blur(8px);">
        <div class="w-2 h-2 rounded-full pulse-dot" style="background-color: var(--color-forest);"></div>
        <span class="font-mono text-xs uppercase tracking-[0.05em] text-white/80">
          Plataforma v4.2 — Operacional
        </span>
      </div>

      <!-- Eyebrow -->
      <p class="font-mono text-xs uppercase tracking-[0.05em] text-white/60 mb-8">
        Para equipos de operaciones en infraestructura crítica
      </p>

      <!-- H1 — Reckless Light -->
      <h1 class="font-sans font-light text-4xl sm:text-5xl lg:text-7xl leading-[1.1] text-white">
        Vea Todo.<br />
        Entienda Por Qué.<br />
        Actúe Antes de que Importe.
      </h1>

      <!-- Subhead -->
      <p class="mt-8 font-sans text-base lg:text-lg text-white/60 max-w-xl leading-relaxed">
        Quatro conecta más de 8,000 sistemas en una utilidad de inteligencia operacional — desplegable en semanas, no años. Diseñada para América Latina.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a
          href="/es/contact/demo"
          class="font-mono text-xs uppercase tracking-[0.05em] px-8 py-4 text-white transition-colors duration-300 ease-linear"
          style="background-color: var(--color-forest);"
        >
          Agende una Evaluación
        </a>
        <a
          href="/es/platform"
          class="font-mono text-xs uppercase tracking-[0.05em] px-8 py-4 text-white transition-colors duration-300 ease-linear hover:bg-white/10"
          style="border: 1px solid rgba(255,255,255,0.2);"
        >
          Conozca la utilidad &rarr;
        </a>
      </div>

      <!-- Microcopy -->
      <p class="mt-4 font-mono text-xs text-white/40">
        Prueba de valor en 4 semanas · Acreditada al contrato
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       2. REGIONAL COMMITMENT — Pattern A (Grid Section)
       ═══════════════════════════════════════════════════════════════ -->
  <section class="px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-0">
        <!-- Sidebar label -->
        <div class="pt-20 lg:pt-28 lg:pb-28 lg:col-span-3 lg:border-r lg:pr-8" style="border-color: var(--color-structure);">
          <span class="lg:sticky lg:top-32 inline-block font-mono text-[12px] font-bold uppercase tracking-[0.2em]" style="color: var(--color-neutral-500);">Presencia</span>
        </div>
        <!-- Main content -->
        <div class="pb-20 lg:py-28 lg:col-span-9 lg:pl-8">
          <h2 class="font-display text-5xl lg:text-7xl font-bold leading-[0.95]" style="color: var(--color-forest);">
            Presencia<br />Compromiso<br />Regional
          </h2>
          <!-- Card grid -->
          <div class="mt-12 grid md:grid-cols-3" style="border-top: 1px solid var(--color-structure); border-left: 1px solid var(--color-structure);">
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">01</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Equipos en América Latina</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Ingenieros y consultores que conocen su industria y hablan su idioma.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">02</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Sus datos en su país</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Arquitectura edge-first con soberanía de datos regional garantizada.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">03</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Soporte en su idioma</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Documentación, capacitación y soporte técnico en español y portugués.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       3. PROBLEM STATEMENT — Pattern A (Grid Section)
       ═══════════════════════════════════════════════════════════════ -->
  <section class="px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-0">
        <!-- Sidebar label -->
        <div class="pt-20 lg:pt-28 lg:pb-28 lg:col-span-3 lg:border-r lg:pr-8" style="border-color: var(--color-structure);">
          <span class="lg:sticky lg:top-32 inline-block font-mono text-[12px] font-bold uppercase tracking-[0.2em]" style="color: var(--color-neutral-500);">Desafío</span>
        </div>
        <!-- Main content -->
        <div class="pb-20 lg:py-28 lg:col-span-9 lg:pl-8">
          <h2 class="font-display text-5xl lg:text-7xl font-bold leading-[0.95]" style="color: var(--color-forest);">
            Desafío<br />Operativo<br />Real
          </h2>
          <p class="mt-8 font-sans text-base leading-relaxed max-w-2xl" style="color: var(--color-neutral-500);">
            Su operación merece tecnología diseñada para su infraestructura. Los sistemas heredados de proveedores extranjeros no fueron pensados para las distancias, la conectividad ni la realidad regulatoria de América Latina.
          </p>
          <!-- Card grid -->
          <div class="mt-12 grid md:grid-cols-3" style="border-top: 1px solid var(--color-structure); border-left: 1px solid var(--color-structure);">
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">01</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Dependencia de proveedores extranjeros</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Licencias en dólares, soporte en otro huso horario y actualizaciones que no consideran su contexto operativo.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">02</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Operaciones remotas sin visibilidad</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Activos distribuidos en miles de kilómetros con conectividad intermitente. Los datos llegan tarde — o no llegan.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">03</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">El conocimiento se está yendo</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Los operadores con décadas de experiencia se están retirando. Su conocimiento vive en sus cabezas, no en sus sistemas.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       4. DATA SOVEREIGNTY — Pattern A (Grid Section)
       ═══════════════════════════════════════════════════════════════ -->
  <section class="px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-0">
        <!-- Sidebar label -->
        <div class="pt-20 lg:pt-28 lg:pb-28 lg:col-span-3 lg:border-r lg:pr-8" style="border-color: var(--color-structure);">
          <span class="lg:sticky lg:top-32 inline-block font-mono text-[12px] font-bold uppercase tracking-[0.2em]" style="color: var(--color-neutral-500);">Soberanía</span>
        </div>
        <!-- Main content -->
        <div class="pb-20 lg:py-28 lg:col-span-9 lg:pl-8">
          <h2 class="font-display text-5xl lg:text-7xl font-bold leading-[0.95]" style="color: var(--color-forest);">
            Sus<br />Datos<br />Su Control
          </h2>
          <!-- Card grid -->
          <div class="mt-12 grid md:grid-cols-3" style="border-top: 1px solid var(--color-structure); border-left: 1px solid var(--color-structure);">
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">01</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Arquitectura Edge-First</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Procesamiento local en cada sitio. Los datos se analizan donde se generan — con o sin conexión a la nube.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">02</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Despliegue Flexible</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">On-premise, nube privada, híbrido o air-gapped. Se adapta a sus requisitos de seguridad y regulación.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">03</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Formatos Abiertos</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">APIs abiertas y formatos estándar. Sus datos son suyos — siempre exportables, siempre accesibles.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       5. THE PLATFORM — Pattern B (Palantir Vertical List)
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-20 lg:py-28 px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <!-- Editorial intro -->
      <p class="font-sans text-2xl lg:text-4xl font-light leading-snug max-w-4xl" style="color: var(--color-neutral-800);">
        Nuestra utilidad de inteligencia conecta más de 8,000 fuentes de datos en un modelo operacional unificado — visibilidad, operaciones e inteligencia en capas <span style="color: var(--color-forest);">progresivas</span>.
      </p>

      <!-- Sub-heading -->
      <h2 class="font-display text-xl font-bold mt-16 mb-8" style="color: var(--color-forest);">
        Nuestra Plataforma
      </h2>

      <!-- Connect -->
      <a href="/es/platform/connect" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center" style="border-top: 1px solid var(--color-structure);">
        <div>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Visibilidad — Integren sus datos. Más de 8,000 conectores industriales. Conectividad universal para toda su infraestructura.</p>
          <span class="font-mono text-xs mt-3 inline-block" style="color: var(--color-forest);">/0.1</span>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-bold transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Connect</span>
        </div>
      </a>

      <!-- Operate -->
      <a href="/es/platform/operate" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center" style="border-top: 1px solid var(--color-structure);">
        <div>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Operaciones — Operen con inteligencia. Detección de anomalías, mantenimiento predictivo y automatización de procesos.</p>
          <span class="font-mono text-xs mt-3 inline-block" style="color: var(--color-forest);">/0.2</span>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-bold transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Operate</span>
        </div>
      </a>

      <!-- Command -->
      <a href="/es/platform/command" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center" style="border-top: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
        <div>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Inteligencia — Orquesten a escala. Centro de comando unificado para operaciones distribuidas.</p>
          <span class="font-mono text-xs mt-3 inline-block" style="color: var(--color-forest);">/0.3</span>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-bold transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Command</span>
        </div>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       6. WHY QUATRO — Pattern A (Grid Section, Dark)
       ═══════════════════════════════════════════════════════════════ -->
  <section class="relative px-6 overflow-hidden" style="border-top: 1px solid var(--color-structure);">
    <!-- Background image -->
    <div class="absolute inset-0">
      <img src="/images/bg.png" alt="" class="h-full w-full object-cover" />
      <div class="absolute inset-0" style="background: rgba(0,0,0,0.8);"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-6xl">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-0">
        <!-- Sidebar label -->
        <div class="pt-20 lg:pt-28 lg:pb-28 lg:col-span-3 lg:border-r lg:pr-8" style="border-color: rgba(255,255,255,0.1);">
          <span class="lg:sticky lg:top-32 inline-block font-mono text-[12px] font-bold uppercase tracking-[0.2em]" style="color: var(--color-neutral-500);">Por Qué</span>
        </div>
        <!-- Main content -->
        <div class="pb-20 lg:py-28 lg:col-span-9 lg:pl-8">
          <h2 class="font-display text-5xl lg:text-7xl font-bold leading-[0.95] text-white">
            Regional<br />Diseñado<br />Suyo
          </h2>
          <!-- Card grid — 2 rows of 3 -->
          <div class="mt-12 grid md:grid-cols-3" style="border-top: 1px solid rgba(255,255,255,0.1); border-left: 1px solid rgba(255,255,255,0.1);">
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-white/20" style="background: rgba(255,255,255,0.05); border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
              <span class="font-mono text-xs text-white/60">01</span>
              <h3 class="font-display text-lg font-bold mt-2 text-white">Presencia Regional</h3>
              <p class="mt-2 font-sans text-sm text-white/50">Equipos de ingeniería y soporte en la región. Implementación con contexto local.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-white/20" style="background: rgba(255,255,255,0.05); border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
              <span class="font-mono text-xs text-white/60">02</span>
              <h3 class="font-display text-lg font-bold mt-2 text-white">Soberanía de Datos</h3>
              <p class="mt-2 font-sans text-sm text-white/50">Sus datos operativos se quedan en su país. Cumplimiento con regulaciones locales.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-white/20" style="background: rgba(255,255,255,0.05); border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
              <span class="font-mono text-xs text-white/60">03</span>
              <h3 class="font-display text-lg font-bold mt-2 text-white">Inversión Flexible</h3>
              <p class="mt-2 font-sans text-sm text-white/50">CAPEX, OPEX o modelos híbridos. Facturación en moneda local cuando es posible.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-white/20" style="background: rgba(255,255,255,0.05); border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
              <span class="font-mono text-xs text-white/60">04</span>
              <h3 class="font-display text-lg font-bold mt-2 text-white">Diseñado para Su Infraestructura</h3>
              <p class="mt-2 font-sans text-sm text-white/50">Funciona con conectividad intermitente, equipos legacy y condiciones reales.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-white/20" style="background: rgba(255,255,255,0.05); border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
              <span class="font-mono text-xs text-white/60">05</span>
              <h3 class="font-display text-lg font-bold mt-2 text-white">Integración con Sistemas Existentes</h3>
              <p class="mt-2 font-sans text-sm text-white/50">No reemplacen su SCADA. Quatro se integra sobre lo que ya tienen.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-white/20" style="background: rgba(255,255,255,0.05); border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
              <span class="font-mono text-xs text-white/60">06</span>
              <h3 class="font-display text-lg font-bold mt-2 text-white">Soporte en Su Idioma</h3>
              <p class="mt-2 font-sans text-sm text-white/50">Documentación, UI, capacitación y soporte técnico en español y portugués.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       7. INDUSTRIES — Pattern B (Palantir Vertical List)
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-20 lg:py-28 px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <!-- Editorial intro -->
      <p class="font-sans text-2xl lg:text-4xl font-light leading-snug max-w-4xl" style="color: var(--color-neutral-800);">
        Construida para las industrias que mueven <span style="color: var(--color-forest);">América Latina</span> — desde el subsuelo hasta la última milla.
      </p>

      <!-- Sub-heading -->
      <h2 class="font-display text-xl font-bold mt-16 mb-8" style="color: var(--color-forest);">
        Nuestras Industrias
      </h2>

      <!-- Energía -->
      <a href="/es/industries/energy" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center" style="border-top: 1px solid var(--color-structure);">
        <div>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Monitoreo de ductos, modernización SCADA y respuesta ante tormentas — sin reemplazar infraestructura de control.</p>
          <span class="font-mono text-xs mt-3 inline-block" style="color: var(--color-forest);">/0.1</span>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-bold transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Energía</span>
        </div>
      </a>

      <!-- Defensa -->
      <a href="/es/industries/defense" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center" style="border-top: 1px solid var(--color-structure);">
        <div>
