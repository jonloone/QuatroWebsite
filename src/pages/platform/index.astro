---
import { getCollection } from 'astro:content'
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import HeroCanvas from '@/components/marketing/HeroCanvas.astro'
import Section from '@/components/marketing/Section.astro'
import DualCta from '@/components/marketing/DualCta.astro'

const products = (await getCollection('products')).sort((a, b) => a.data.order - b.data.order)
---

<MarketingLayout
  title="Platform — Operational Intelligence from Edge to Enterprise"
  description="The Quatro Intelligence Utility delivers operational intelligence through three progressive tiers: Visibility, Operations, and Intelligence. 8,000+ integrations. Deploy anywhere."
>
  <HeroCanvas
    badge="The Quatro Intelligence Utility"
    title="Operational Intelligence from Edge to Enterprise"
    body="Three tiers of progressive value. Start with visibility, grow to operations, scale to intelligence — 8,000+ integrations from 1,000+ vendors. Deploy your way."
    ctaLabel="Talk to Our Team"
    ctaHref="/contact/demo"
  />

  <Section>
    <div class="mb-12 text-center">
      <h2 class="font-display text-2xl font-bold tracking-tight text-neutral-800 sm:text-3xl">
        Progressive Operational Intelligence
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-base text-neutral-600">
        Each tier builds on the last. Start with visibility, grow into automated operations, and scale to full orchestration — no rip-and-replace.
      </p>
    </div>

    <div class="space-y-6">
      {products.map((product, index) => (
        <a
          href={`/platform/${product.id.replace(/\.md$/, '')}`}
          class="group block rounded-2xl border border-neutral-200 bg-white p-8 transition-all hover:border-brand-300 hover:shadow-lg"
        >
          <div class="flex flex-col gap-6 lg:flex-row lg:items-center lg:justify-between">
            <div class="flex-1">
              <div class="flex items-center gap-3">
                <span class="flex h-8 w-8 items-center justify-center rounded-full bg-brand-500 font-mono text-sm font-bold text-neutral-800">
                  {index + 1}
                </span>
                <h3 class="font-display text-xl font-bold text-neutral-800 group-hover:text-brand-600">
                  {product.data.title}
                </h3>
              </div>
              <p class="mt-3 text-lg font-medium text-neutral-700">{product.data.tagline}</p>
              <p class="mt-2 text-base text-neutral-600">{product.data.description}</p>
            </div>
            <div class="flex items-center gap-4 lg:flex-shrink-0">
              <div class="grid grid-cols-2 gap-4 text-center">
                {product.data.stats.slice(0, 2).map((stat) => (
                  <div>
                    <div class="font-display text-lg font-bold text-brand-500">{stat.value}</div>
                    <div class="text-xs text-neutral-500">{stat.label}</div>
                  </div>
                ))}
              </div>
              <span class="text-brand-500 transition-transform group-hover:translate-x-1">
                &rarr;
              </span>
            </div>
          </div>
        </a>
      ))}
    </div>
  </Section>

  <DualCta
    title="See Operational Intelligence on Your Infrastructure"
    description="Pick one challenge. We deploy on your systems in 4 weeks. You see the value before you commit."
    primaryCta={{ label: 'Talk to Our Team', href: '/contact/demo' }}
    secondaryCta={{ label: 'Talk to an Engineer', href: '/contact/sales' }}
  />
</MarketingLayout>
