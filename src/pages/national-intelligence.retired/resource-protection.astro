---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SiteHeader from '@/components/layout/SiteHeader.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
---

<BaseLayout
  title="Resource Protection — Quatro National Intelligence Platform"
  description="Satellite, ground sensor, and AI-powered detection of illegal mining, pipeline theft, deforestation, and environmental destruction — with automated enforcement targeting and evidence-grade audit trails."
  lang="en"
>

  <SiteHeader lang="en" />

  <!-- ═══════════════════════════════════════════════════════════════
       1. HERO
       ═══════════════════════════════════════════════════════════════ -->
  <section data-hero class="relative min-h-[85vh] lg:min-h-[90vh] flex items-end overflow-hidden px-6 pb-20 lg:pb-28">
    <div class="absolute inset-0">
      <img src="/images/ni-resource-protection.png" alt="" class="h-full w-full object-cover" />
      <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(0,0,0,0.4) 0%, rgba(0,0,0,0.7) 100%);"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-5xl w-full text-left pt-16">
      <div class="inline-flex items-center gap-2.5 px-4 py-2 mb-10" style="background: rgba(255,255,255,0.1); backdrop-filter: blur(8px);">
        <div class="w-2 h-2 rounded-full pulse-dot" style="background-color: var(--color-forest);"></div>
        <span class="font-mono text-xs uppercase tracking-[0.05em] text-white/80">
          Resource Defense Intelligence
        </span>
      </div>

      <p class="font-mono text-xs uppercase tracking-[0.05em] text-white/60 mb-8">
        Natural Resource Protection
      </p>

      <h1 class="font-sans font-light text-4xl sm:text-5xl lg:text-7xl leading-[1.1] text-white">
        Detect Extraction.<br />
        Protect Resources.<br />
        Enforce Sovereignty.
      </h1>

      <p class="mt-8 font-sans text-base lg:text-lg text-white/60 max-w-xl leading-relaxed">
        Multi-source intelligence that detects illegal mining, pipeline theft, and environmental destruction in real time — fusing satellite imagery, ground sensors, and AI-powered change detection into actionable enforcement intelligence.
      </p>

      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a
          href="/contact/demo"
          class="font-mono text-xs uppercase tracking-[0.05em] px-8 py-4 text-white transition-colors duration-300 ease-linear"
          style="background-color: var(--color-forest);"
        >
          Request a Briefing
        </a>
        <a
          href="/national-intelligence"
          class="font-mono text-xs uppercase tracking-[0.05em] px-8 py-4 text-white transition-colors duration-300 ease-linear hover:bg-white/10"
          style="border: 1px solid rgba(255,255,255,0.2);"
        >
          &larr; All Programs
        </a>
      </div>

      <p class="mt-4 font-mono text-xs text-white/40">
        Daily satellite surveillance &middot; Automated change detection &middot; Evidence-grade audit trail
      </p>

      <div class="mt-10 pt-6 flex flex-wrap items-center gap-8" style="border-top: 1px solid rgba(255,255,255,0.1);">
        <div>
          <span class="font-mono text-xs text-white/40 block">Satellite Cadence</span>
          <span class="font-display text-lg font-bold text-white">Daily</span>
        </div>
        <div>
          <span class="font-mono text-xs text-white/40 block">Detection</span>
          <span class="font-display text-lg font-bold text-white">AI-Powered</span>
        </div>
        <div>
          <span class="font-mono text-xs text-white/40 block">Coverage</span>
          <span class="font-display text-lg font-bold text-white">National</span>
        </div>
        <div>
          <span class="font-mono text-xs text-white/40 block">Response</span>
          <span class="font-display text-lg font-bold text-white">&lt;30 sec</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       2. THE THREAT — Pattern A (Grid Section)
       ═══════════════════════════════════════════════════════════════ -->
  <section class="px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-0">
        <div class="pt-20 lg:pt-28 lg:pb-28 lg:col-span-3 lg:border-r lg:pr-8" style="border-color: var(--color-structure);">
          <span class="lg:sticky lg:top-32 inline-block font-mono text-[12px] font-bold uppercase tracking-[0.2em]" style="color: var(--color-neutral-500);">The Threat</span>
        </div>
        <div class="pb-20 lg:py-28 lg:col-span-9 lg:pl-8">
          <h2 class="font-display text-5xl lg:text-7xl font-bold leading-[0.95]" style="color: var(--color-forest);">
            Invisible<br />Extraction<br />National Cost
          </h2>
          <div class="mt-8 max-w-2xl space-y-6">
            <p class="font-sans text-base leading-relaxed" style="color: var(--color-neutral-500);">
              Illegal mining operations strip natural resources and devastate ecosystems across remote territories. Clandestine pipeline tapping extracts crude oil from national infrastructure. Deforestation accelerates in protected areas. The environmental damage is severe — but the fiscal damage is equally devastating.
            </p>
            <p class="font-sans text-base leading-relaxed" style="color: var(--color-neutral-700);">
              These operations fund the same criminal networks that traffic drugs, launder money, and recruit youth. Illegal mining in particular has become a primary revenue source for transnational criminal organizations — financing operations that extend far beyond the extraction site itself.
            </p>
            <p class="font-sans text-base leading-relaxed" style="color: var(--color-neutral-500);">
              Traditional enforcement is reactive: a patrol discovers a site that has been operating for months. By then, the damage is done, the operators have moved, and the evidence is degraded. What's needed is persistent surveillance — the ability to detect new activity within hours, not months.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       3. DETECTION CAPABILITIES — Pattern A (Card Grid)
       ═══════════════════════════════════════════════════════════════ -->
  <section class="px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-0">
        <div class="pt-20 lg:pt-28 lg:pb-28 lg:col-span-3 lg:border-r lg:pr-8" style="border-color: var(--color-structure);">
          <span class="lg:sticky lg:top-32 inline-block font-mono text-[12px] font-bold uppercase tracking-[0.2em]" style="color: var(--color-neutral-500);">Detection</span>
        </div>
        <div class="pb-20 lg:py-28 lg:col-span-9 lg:pl-8">
          <h2 class="font-display text-5xl lg:text-7xl font-bold leading-[0.95]" style="color: var(--color-forest);">
            See It<br />Map It<br />Stop It
          </h2>
          <div class="mt-12 grid md:grid-cols-3" style="border-top: 1px solid var(--color-structure); border-left: 1px solid var(--color-structure);">
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">01</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Satellite Change Detection</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Daily satellite earth observation with AI-powered change detection. Identifies new mining activity, deforestation, and unauthorized construction within hours of occurrence.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">02</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Pipeline Integrity Intelligence</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Vibration detection, pressure analysis, and hydraulic anomaly monitoring that identifies clandestine tapping and theft events in real time. Evidence-grade detection for regulatory and law enforcement handoff.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">03</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Environmental Monitoring</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Real-time sensor networks for water quality, air quality, and soil contamination. Automated compliance monitoring across extraction sites and protected areas.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">04</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Dark Vessel Detection</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">AIS/VMS tracking with satellite correlation identifies vessels operating without transponders. Route prediction and enforcement targeting for IUU fishing and maritime resource theft.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">05</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Deforestation Tracking</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Satellite-based canopy loss detection across protected areas and buffer zones. Automated alerts when clearing exceeds permitted thresholds. Evidence packages for regulatory enforcement.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">06</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Enforcement Intelligence</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Detection events correlated with criminal network intelligence. Maps who operates each site, how resources are transported, and where proceeds enter the financial system.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       4. SENSOR NETWORK — Dark Section
       ═══════════════════════════════════════════════════════════════ -->
  <section class="relative px-6 overflow-hidden" style="border-top: 1px solid var(--color-structure);">
    <div class="absolute inset-0">
      <img src="/images/bg.png" alt="" class="h-full w-full object-cover" />
      <div class="absolute inset-0" style="background: rgba(0,0,0,0.8);"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-6xl">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-0">
        <div class="pt-20 lg:pt-28 lg:pb-28 lg:col-span-3 lg:border-r lg:pr-8" style="border-color: rgba(255,255,255,0.1);">
          <span class="lg:sticky lg:top-32 inline-block font-mono text-[12px] font-bold uppercase tracking-[0.2em]" style="color: var(--color-neutral-500);">Sensors</span>
        </div>
        <div class="pb-20 lg:py-28 lg:col-span-9 lg:pl-8">
          <h2 class="font-display text-5xl lg:text-7xl font-bold leading-[0.95] text-white">
            Multi-Source<br />Intelligence<br />Fusion
          </h2>
          <div class="mt-12 grid md:grid-cols-3" style="border-top: 1px solid rgba(255,255,255,0.1); border-left: 1px solid rgba(255,255,255,0.1);">
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-white/20" style="background: rgba(255,255,255,0.05); border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
              <span class="font-mono text-xs text-white/60">Space</span>
              <h3 class="font-display text-lg font-bold mt-2 text-white">Satellite EO</h3>
              <p class="mt-2 font-sans text-sm text-white/50">Daily revisit optical and SAR imagery. AI change detection trained on mining, deforestation, and construction signatures. Multi-spectral analysis for environmental contamination.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-white/20" style="background: rgba(255,255,255,0.05); border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
              <span class="font-mono text-xs text-white/60">Ground</span>
              <h3 class="font-display text-lg font-bold mt-2 text-white">SCADA & IoT Sensors</h3>
              <p class="mt-2 font-sans text-sm text-white/50">Pipeline vibration, pressure, flow rate. Environmental sensors for water and air quality. Fiber optic intrusion detection along pipeline corridors.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-white/20" style="background: rgba(255,255,255,0.05); border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
              <span class="font-mono text-xs text-white/60">Maritime</span>
              <h3 class="font-display text-lg font-bold mt-2 text-white">AIS/VMS & Radar</h3>
              <p class="mt-2 font-sans text-sm text-white/50">Vessel tracking, transponder gap analysis, dark vessel identification. Correlation with satellite imagery for vessels operating without identification.</p>
            </div>
          </div>

          <div class="mt-12 p-8" style="background: rgba(255,255,255,0.05); border: 1px solid rgba(255,255,255,0.1);">
            <h3 class="font-display text-lg font-bold text-white">Partner Ecosystem</h3>
            <p class="mt-3 font-sans text-sm text-white/50 max-w-2xl">
              NOVI Space for satellite earth observation and environmental monitoring. ECR Platform X for DevSafeOps — E-RTTM hydraulic detection, predictive analytics, and operational decisioning for pipeline integrity. Each partner provides domain-specific sensing that Quatro fuses into a single intelligence picture.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       5. EVIDENCE-GRADE OUTPUT — Pattern A (Card Grid)
       ═══════════════════════════════════════════════════════════════ -->
  <section class="px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-0">
        <div class="pt-20 lg:pt-28 lg:pb-28 lg:col-span-3 lg:border-r lg:pr-8" style="border-color: var(--color-structure);">
          <span class="lg:sticky lg:top-32 inline-block font-mono text-[12px] font-bold uppercase tracking-[0.2em]" style="color: var(--color-neutral-500);">Evidence</span>
        </div>
        <div class="pb-20 lg:py-28 lg:col-span-9 lg:pl-8">
          <h2 class="font-display text-5xl lg:text-7xl font-bold leading-[0.95]" style="color: var(--color-forest);">
            Evidence-Grade<br />Output
          </h2>
          <div class="mt-12 grid md:grid-cols-2" style="border-top: 1px solid var(--color-structure); border-left: 1px solid var(--color-structure);">
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">01</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Full Audit Trail</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">From detection event through investigation to enforcement action. Timestamp, sensor source, confidence level, analyst assessment, and action taken — logged for every event.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">02</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Regulatory Compliance</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Evidence packages formatted for compliance with national regulatory frameworks across energy, hydrocarbon, water resources, and environmental sectors.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">03</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Chain-of-Custody</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Detection records, analysis reports, and intelligence assessments packaged for prosecution. Every step documented, tamper-evident, admissible.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">04</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Prosecution-Ready Reports</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Connect detection events to operators, networks, financial flows, and organizational structure. Not just proof that extraction occurred — proof of who did it.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       6. DATA SOVEREIGNTY — Pattern A (Grid Section)
       ═══════════════════════════════════════════════════════════════ -->
  <section class="px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-0">
        <div class="pt-20 lg:pt-28 lg:pb-28 lg:col-span-3 lg:border-r lg:pr-8" style="border-color: var(--color-structure);">
          <span class="lg:sticky lg:top-32 inline-block font-mono text-[12px] font-bold uppercase tracking-[0.2em]" style="color: var(--color-neutral-500);">Sovereignty</span>
        </div>
        <div class="pb-20 lg:py-28 lg:col-span-9 lg:pl-8">
          <h2 class="font-display text-5xl lg:text-7xl font-bold leading-[0.95]" style="color: var(--color-forest);">
            Sovereign<br />by Design
          </h2>
          <div class="mt-8 max-w-2xl space-y-6">
            <p class="font-sans text-base leading-relaxed" style="color: var(--color-neutral-500);">
              All data remains under national government control. Satellite imagery, sensor data, detection events, and intelligence products are stored on sovereign infrastructure with end-to-end encryption. Air-gapped deployments supported for classified environments.
            </p>
            <p class="font-sans text-base leading-relaxed" style="color: var(--color-neutral-700);">
              Environmental and resource intelligence is particularly sensitive — it involves national resource valuation, extraction activity data, and enforcement operations that directly affect national revenue. Sovereign control is not optional. It is the baseline requirement.
            </p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       7. ADJACENT PROGRAMS
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-20 lg:py-28 px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <p class="font-sans text-2xl lg:text-4xl font-light leading-snug max-w-4xl" style="color: var(--color-neutral-800);">
        Resource protection intelligence compounds with every other domain. Illegal mining sites map to <span style="color: var(--color-forest);">cartel networks</span>. Pipeline theft correlates with <span style="color: var(--color-forest);">financial flows</span>.
      </p>

      <h2 class="font-display text-xl font-bold mt-16 mb-8" style="color: var(--color-forest);">
        Related Programs
      </h2>

      <a href="/national-intelligence/counter-cartel-operations" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center" style="border-top: 1px solid var(--color-structure);">
        <div>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Criminal network mapping connects extraction operations to the organizations that fund and protect them.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-4xl lg:text-7xl font-bold transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Counter-Cartel</span>
        </div>
      </a>

      <a href="/national-intelligence/youth-vulnerability-index" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center" style="border-top: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
        <div>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Mining communities are recruitment hotspots. YVI intelligence identifies vulnerable youth in resource extraction regions.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-4xl lg:text-7xl font-bold transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Youth Vulnerability</span>
        </div>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       8. FINAL CTA
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-12 lg:py-20 px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="relative mx-auto max-w-6xl py-16 lg:py-24 px-8 lg:px-16 overflow-hidden" style="background-color: var(--color-forest);">
      <div class="absolute inset-0">
        <img src="/images/cta.png" alt="" class="h-full w-full object-cover" />
        <div class="absolute inset-0" style="background: rgba(0,0,0,0.75);"></div>
      </div>
      <div class="relative z-10">
        <div class="mx-auto max-w-2xl text-center">
          <h2 class="font-sans text-3xl lg:text-5xl font-light text-white leading-tight">
            Protect national resources with persistent intelligence.
          </h2>
          <p class="mt-6 font-sans text-lg text-white/70 leading-relaxed">
            Satellite surveillance. Ground sensors. AI detection. Evidence-grade enforcement intelligence — from the first anomaly to the courtroom.
          </p>
          <div class="mt-10 flex flex-wrap items-center justify-center gap-4">
            <a
              href="/contact/demo"
              class="font-mono text-xs uppercase tracking-[0.05em] px-8 py-4 transition-colors duration-300 ease-linear"
              style="background-color: white; color: var(--color-forest);"
            >
              Request a Briefing
            </a>
            <a
              href="/contact/sales"
              class="font-mono text-xs uppercase tracking-[0.05em] px-8 py-4 text-white transition-colors duration-300 ease-linear hover:bg-white/10"
              style="border: 1px solid rgba(255,255,255,0.2);"
            >
              Talk to an Engineer
            </a>
          </div>
