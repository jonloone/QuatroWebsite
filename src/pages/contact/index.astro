---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
---

<MarketingLayout
  title="Contact — How It Starts — Quatro"
  description="Tell us the operational challenge that matters most. We connect the systems that hold the answer."
>
  <!-- Dark hero with background image -->
  <section class="relative overflow-hidden bg-neutral-900" data-nav-dark>
    <div class="absolute inset-0">
      <img src="/images/hero-contact.png" alt="" class="h-full w-full object-cover" />
      <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(10,17,40,0.5) 0%, rgba(10,17,40,0.7) 60%, rgba(10,17,40,0.9) 100%);"></div>
    </div>

    <div class="relative z-10 mx-auto max-w-7xl px-8 lg:px-16 pt-32 sm:pt-40 pb-40 sm:pb-52 text-center">
      <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-white/40 mb-6">How It Starts</p>
      <h1 class="font-sans font-light text-4xl sm:text-5xl lg:text-6xl xl:text-7xl leading-[1.05] tracking-tight text-white max-w-4xl mx-auto">
        You Name the Outcome.
      </h1>
      <p class="mt-6 font-display text-lg lg:text-xl leading-relaxed text-white/60 max-w-2xl mx-auto">
        Tell us the operational challenge that matters most. We connect the systems that hold the answer.
      </p>
    </div>
  </section>

  <!-- Cards overlapping upward into hero -->
  <div class="relative z-20 -mt-24 sm:-mt-32 pb-16 sm:pb-24">
    <div class="mx-auto max-w-4xl px-8 lg:px-16">
      <div class="grid gap-6 sm:grid-cols-3">
        <a href="/contact/demo" class="bg-white rounded-sm border border-neutral-200 shadow-xl p-8 hover:border-neutral-400 transition-all duration-150">
          <h3 class="font-display text-lg font-bold text-neutral-800">Start With an Outcome</h3>
          <p class="mt-3 font-sans text-sm text-neutral-500 leading-relaxed">Name the challenge. We'll map the systems and show how intelligence starts flowing.</p>
        </a>
        <a href="/contact/sales" class="bg-white rounded-sm border border-neutral-200 shadow-xl p-8 hover:border-neutral-400 transition-all duration-150">
          <h3 class="font-display text-lg font-bold text-neutral-800">Talk to an Engineer</h3>
          <p class="mt-3 font-sans text-sm text-neutral-500 leading-relaxed">Bring your architecture and constraints. We'll show how your systems connect into one model.</p>
        </a>
        <a href="/contact/support" class="bg-white rounded-sm border border-neutral-200 shadow-xl p-8 hover:border-neutral-400 transition-all duration-150">
          <h3 class="font-display text-lg font-bold text-neutral-800">Get Support</h3>
          <p class="mt-3 font-sans text-sm text-neutral-500 leading-relaxed">Already operating with Quatro? We'll help you extend and scale what you've built.</p>
        </a>
      </div>
    </div>
  </div>
</MarketingLayout>
