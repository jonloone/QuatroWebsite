---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SiteHeader from '@/components/layout/SiteHeader.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
import HeroCanvas from '@/components/marketing/HeroCanvas.astro'
import FloatingPaths from '@/components/ui/FloatingPaths'
import { getCollection } from 'astro:content'
const insights = (await getCollection('insights'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 5)
---

<BaseLayout
  title="Quatro — Connect to Quatro. Your Operations Become Intelligent."
  description="Quatro is the operational intelligence utility. Connect your operations and get real-time visibility, predictive intelligence, and governed autonomous action — deployed your way."
  lang="en"
>

  <SiteHeader lang="en" />

  <!-- ═══════════════════════════════════════════════════════════════
       1. HERO — Dithering Card (via HeroCanvas component)
       ═══════════════════════════════════════════════════════════════ -->
  <HeroCanvas
    badge="Quatro"
    title='Connect to Quatro.<br/><span class="text-white/60">Your operations become intelligent.</span>'
    body="Every pipeline, grid, fleet, and facility generates data. But data isn't intelligence. Connect to Quatro and get real-time visibility, predictive reasoning, and governed autonomous action — deployed your way, governed for trust."
    ctaLabel="Schedule an Assessment"
    ctaHref="/contact/demo"
    imageSrc="/images/hero-bg.png"
    pixelSize={3}
    baseSpeed={0.1}
    hoverSpeed={0.5}
    greenBlend={0.75}
    canvasOpacity={85}
    minHeight="min-h-[480px] md:min-h-[560px]"
  />

  <!-- ═══════════════════════════════════════════════════════════════
       2. INDUSTRIES — Palantir-style vertical list
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-20 lg:py-28 px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <!-- Editorial intro — large type, frames the platform before listing industries -->
      <h2 class="font-sans font-light text-3xl sm:text-4xl lg:text-6xl xl:text-7xl leading-[1.15] tracking-tight fade-up" style="color: var(--color-neutral-800);">
        Operational intelligence for the industries that keep communities<br /><span style="color: var(--color-forest);">connected, powered, and safe</span>.
      </h2>

      <!-- Energy -->
      <a href="/industries/energy" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up mt-16" style="border-top: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Connect pipeline, grid, and production operations. Predictive intelligence on legacy SCADA — intelligence flowing in weeks, not years.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Energy</span>
        </div>
      </a>

      <!-- National Security -->
      <a href="/industries/national-security" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up" style="border-top: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Multi-domain operational intelligence with sovereign deployment. Air-gapped capable. Governed and auditable.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">National Security</span>
        </div>
      </a>

      <!-- Networks -->
      <a href="/industries/networks" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up" style="border-top: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Operational intelligence from ground to orbit. Terrestrial, satellite, and hybrid connectivity — one view, one intelligence layer.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Networks</span>
        </div>
      </a>

      <!-- Critical Infrastructure -->
      <a href="/industries/critical-infrastructure" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up" style="border-top: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 0h.008v.008h-.008V7.5z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Intelligence for the systems cities depend on — water, transportation, municipal operations, and the built environment.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Critical Infrastructure</span>
        </div>
      </a>

      <!-- Finance -->
      <a href="/industries/finance" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up" style="border-top: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Connect the 15–30 systems your institution already operates. Operational intelligence production-ready in weeks.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Finance</span>
        </div>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       3. THE UTILITY — Intelligence pillars, how it works, proof stories
       ═══════════════════════════════════════════════════════════════ -->
  <section class="relative py-24 lg:py-32 px-6 overflow-hidden" style="background: #0a0a0a;">
    <!-- Animated background paths -->
    <div class="absolute inset-0 opacity-60">
      <FloatingPaths client:visible />
    </div>
    <div class="relative z-10 mx-auto max-w-6xl">

      <!-- Editorial lead -->
      <p class="font-mono text-xs uppercase tracking-[0.1em] mb-8 fade-up" style="color: var(--color-forest);">The Intelligence Utility</p>
      <h2 class="font-sans font-light text-3xl sm:text-4xl lg:text-5xl xl:text-6xl leading-[1.15] tracking-tight text-white fade-up">
        You don't build your own intelligence stack.<br /><span class="text-white/40">You connect to one.</span>
      </h2>
      <p class="mt-6 font-sans text-lg lg:text-xl leading-relaxed max-w-3xl text-white/50 fade-up">
        Quatro connects to your existing infrastructure — SCADA, IoT, ERP, every operational system — and intelligence flows. Real-time visibility, predictive reasoning, governed autonomous action. Intelligence that compounds with every system you connect.
      </p>

      <!-- Intelligence pillars — what Quatro does, not what it connects to -->
      <div class="mt-20 lg:mt-24 grid grid-cols-1 sm:grid-cols-2 gap-y-16 gap-x-12 lg:gap-x-16 fade-up">
        <div>
          <svg class="w-8 h-8 mb-5" style="color: var(--color-forest);" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
          </svg>
          <h3 class="font-sans font-light text-2xl lg:text-3xl tracking-tight text-white leading-snug">
            Real-time visibility
          </h3>
          <p class="mt-4 font-sans text-base lg:text-lg leading-relaxed text-white/40 max-w-md">
            8,000+ integrations across 1,000+ vendors. Every signal validated, enriched, and contextualized. One screen instead of fifteen. Real-time instead of yesterday's report.
          </p>
        </div>
        <div>
          <svg class="w-8 h-8 mb-5" style="color: var(--color-forest);" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 1 0 0 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186 9.566-5.314m-9.566 7.5 9.566 5.314m0 0a2.25 2.25 0 1 0 3.935 2.186 2.25 2.25 0 0 0-3.935-2.186Zm0-12.814a2.25 2.25 0 1 0 3.933-2.185 2.25 2.25 0 0 0-3.933 2.185Z" />
          </svg>
          <h3 class="font-sans font-light text-2xl lg:text-3xl tracking-tight text-white leading-snug">
            Predictive intelligence
          </h3>
          <p class="mt-4 font-sans text-base lg:text-lg leading-relaxed text-white/40 max-w-md">
            Domain-trained intelligence models forecast failures before they happen. Automated root cause analysis. Intelligence grounded in your operational reality — not generic AI guesses.
          </p>
        </div>
        <div>
          <svg class="w-8 h-8 mb-5" style="color: var(--color-forest);" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
          </svg>
          <h3 class="font-sans font-light text-2xl lg:text-3xl tracking-tight text-white leading-snug">
            Governed autonomous action
          </h3>
          <p class="mt-4 font-sans text-base lg:text-lg leading-relaxed text-white/40 max-w-md">
            Cross the gap from copilot to autonomous operations. Every action bounded, auditable, and provably correct. Full accountability from data through reasoning through action.
          </p>
        </div>
        <div>
          <svg class="w-8 h-8 mb-5" style="color: var(--color-forest);" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
          </svg>
          <h3 class="font-sans font-light text-2xl lg:text-3xl tracking-tight text-white leading-snug">
            Intelligence compounds
          </h3>
          <p class="mt-4 font-sans text-base lg:text-lg leading-relaxed text-white/40 max-w-md">
            Each new system you connect makes every other system smarter. Production-grade intelligence in weeks, not quarters. Deploy cloud, hybrid, or air-gapped.
          </p>
        </div>
      </div>

      <!-- How it works — visual flow diagram card -->
      <div class="mt-20 lg:mt-24 fade-up rounded-2xl px-8 py-12 lg:px-12 lg:py-16" style="border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.04); backdrop-filter: blur(24px) saturate(1.2); -webkit-backdrop-filter: blur(24px) saturate(1.2); box-shadow: 0 8px 32px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.06);">
        <p class="font-mono text-[10px] uppercase tracking-[0.12em] mb-10" style="color: var(--color-forest);">How It Works</p>

        <!-- Flow diagram SVG -->
        <svg class="w-full h-auto mb-9" viewBox="0 0 1100 160" fill="none" xmlns="http://www.w3.org/2000/svg">
          <style>
            @keyframes hiw-flow { 0% { stroke-dashoffset: 16; } 100% { stroke-dashoffset: 0; } }
            @keyframes hiw-pulse { 0%, 100% { opacity: 0.2; } 50% { opacity: 0.7; } }
            .hiw-flow-dash { animation: hiw-flow 1.2s linear infinite; }
            .hiw-pulse-dot { animation: hiw-pulse 2.5s ease-in-out infinite; }
          </style>

          <!-- Source dots -->
          <circle cx="16" cy="30" r="2.5" fill="rgba(0,209,178,0.5)" class="hiw-pulse-dot"/>
          <circle cx="16" cy="55" r="2.5" fill="rgba(0,209,178,0.5)" class="hiw-pulse-dot" style="animation-delay:0.4s"/>
          <circle cx="16" cy="80" r="2.5" fill="rgba(0,209,178,0.5)" class="hiw-pulse-dot" style="animation-delay:0.8s"/>
          <circle cx="16" cy="105" r="2.5" fill="rgba(0,209,178,0.5)" class="hiw-pulse-dot" style="animation-delay:1.2s"/>
          <circle cx="16" cy="130" r="2.5" fill="rgba(0,209,178,0.5)" class="hiw-pulse-dot" style="animation-delay:1.6s"/>

          <!-- Converging dashed lines -->
          <line x1="20" y1="30" x2="330" y2="72" stroke="rgba(0,209,178,0.18)" stroke-width="1" stroke-dasharray="4,4" class="hiw-flow-dash"/>
          <line x1="20" y1="55" x2="330" y2="75" stroke="rgba(0,209,178,0.14)" stroke-width="1" stroke-dasharray="4,4" class="hiw-flow-dash" style="animation-delay:0.2s"/>
          <line x1="20" y1="80" x2="330" y2="80" stroke="rgba(0,209,178,0.22)" stroke-width="1" stroke-dasharray="4,4" class="hiw-flow-dash" style="animation-delay:0.4s"/>
          <line x1="20" y1="105" x2="330" y2="85" stroke="rgba(0,209,178,0.14)" stroke-width="1" stroke-dasharray="4,4" class="hiw-flow-dash" style="animation-delay:0.6s"/>
          <line x1="20" y1="130" x2="330" y2="88" stroke="rgba(0,209,178,0.18)" stroke-width="1" stroke-dasharray="4,4" class="hiw-flow-dash" style="animation-delay:0.8s"/>

          <!-- Model box -->
          <rect x="330" y="24" rx="6" ry="6" width="400" height="112" fill="rgba(0,209,178,0.03)" stroke="rgba(0,209,178,0.12)" stroke-width="1"/>

          <!-- Connect node on left edge -->
          <circle cx="330" cy="80" r="5.5" fill="rgba(0,209,178,0.25)" stroke="rgba(0,209,178,0.6)" stroke-width="1.5"/>

          <!-- Layer 1: Ingestion -->
          <line x1="330" y1="80" x2="390" y2="50" stroke="rgba(0,209,178,0.2)" stroke-width="1"/>
          <line x1="330" y1="80" x2="390" y2="80" stroke="rgba(0,209,178,0.25)" stroke-width="1"/>
          <line x1="330" y1="80" x2="390" y2="110" stroke="rgba(0,209,178,0.2)" stroke-width="1"/>
          <circle cx="390" cy="50" r="3" fill="rgba(0,209,178,0.15)" stroke="rgba(0,209,178,0.4)" stroke-width="1" class="hiw-pulse-dot"/>
          <circle cx="390" cy="80" r="3" fill="rgba(0,209,178,0.15)" stroke="rgba(0,209,178,0.4)" stroke-width="1" class="hiw-pulse-dot" style="animation-delay:0.3s"/>
          <circle cx="390" cy="110" r="3" fill="rgba(0,209,178,0.15)" stroke="rgba(0,209,178,0.4)" stroke-width="1" class="hiw-pulse-dot" style="animation-delay:0.6s"/>

          <!-- Layer 2: Semantic modeling (amber) -->
          <line x1="390" y1="50" x2="470" y2="55" stroke="rgba(244,162,97,0.2)" stroke-width="1"/>
          <line x1="390" y1="50" x2="470" y2="80" stroke="rgba(244,162,97,0.15)" stroke-width="1"/>
          <line x1="390" y1="80" x2="470" y2="55" stroke="rgba(244,162,97,0.15)" stroke-width="1"/>
          <line x1="390" y1="80" x2="470" y2="80" stroke="rgba(244,162,97,0.2)" stroke-width="1"/>
          <line x1="390" y1="80" x2="470" y2="105" stroke="rgba(244,162,97,0.15)" stroke-width="1"/>
          <line x1="390" y1="110" x2="470" y2="80" stroke="rgba(244,162,97,0.12)" stroke-width="1"/>
          <line x1="390" y1="110" x2="470" y2="105" stroke="rgba(244,162,97,0.2)" stroke-width="1"/>
          <line x1="470" y1="55" x2="470" y2="80" stroke="rgba(244,162,97,0.1)" stroke-width="1" stroke-dasharray="2,3"/>
          <line x1="470" y1="80" x2="470" y2="105" stroke="rgba(244,162,97,0.1)" stroke-width="1" stroke-dasharray="2,3"/>
          <circle cx="470" cy="55" r="3.5" fill="rgba(244,162,97,0.12)" stroke="rgba(244,162,97,0.4)" stroke-width="1"/>
          <circle cx="470" cy="80" r="4" fill="rgba(244,162,97,0.15)" stroke="rgba(244,162,97,0.5)" stroke-width="1.5"/>
          <circle cx="470" cy="105" r="3.5" fill="rgba(244,162,97,0.12)" stroke="rgba(244,162,97,0.4)" stroke-width="1"/>

          <!-- Layer 3: Governance (white) -->
          <line x1="470" y1="55" x2="560" y2="48" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
          <line x1="470" y1="55" x2="560" y2="72" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
          <line x1="470" y1="80" x2="560" y2="72" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
          <line x1="470" y1="80" x2="560" y2="96" stroke="rgba(255,255,255,0.12)" stroke-width="1"/>
          <line x1="470" y1="105" x2="560" y2="96" stroke="rgba(255,255,255,0.1)" stroke-width="1"/>
          <line x1="470" y1="105" x2="560" y2="116" stroke="rgba(255,255,255,0.08)" stroke-width="1"/>
          <line x1="560" y1="48" x2="560" y2="72" stroke="rgba(255,255,255,0.06)" stroke-width="1" stroke-dasharray="2,3"/>
          <line x1="560" y1="72" x2="560" y2="96" stroke="rgba(255,255,255,0.06)" stroke-width="1" stroke-dasharray="2,3"/>
          <line x1="560" y1="96" x2="560" y2="116" stroke="rgba(255,255,255,0.06)" stroke-width="1" stroke-dasharray="2,3"/>
          <circle cx="560" cy="48" r="2.5" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.25)" stroke-width="1" class="hiw-pulse-dot" style="animation-delay:1s"/>
          <circle cx="560" cy="72" r="3" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
          <circle cx="560" cy="96" r="3" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.3)" stroke-width="1"/>
          <circle cx="560" cy="116" r="2.5" fill="rgba(255,255,255,0.08)" stroke="rgba(255,255,255,0.25)" stroke-width="1" class="hiw-pulse-dot" style="animation-delay:1.5s"/>

          <!-- Layer 4: Convergence -->
          <line x1="560" y1="48" x2="650" y2="65" stroke="rgba(0,209,178,0.12)" stroke-width="1"/>
          <line x1="560" y1="72" x2="650" y2="65" stroke="rgba(244,162,97,0.12)" stroke-width="1"/>
          <line x1="560" y1="72" x2="650" y2="95" stroke="rgba(0,209,178,0.12)" stroke-width="1"/>
          <line x1="560" y1="96" x2="650" y2="95" stroke="rgba(244,162,97,0.12)" stroke-width="1"/>
          <line x1="560" y1="116" x2="650" y2="95" stroke="rgba(0,209,178,0.1)" stroke-width="1"/>
          <circle cx="650" cy="65" r="3" fill="rgba(0,209,178,0.1)" stroke="rgba(0,209,178,0.35)" stroke-width="1"/>
          <circle cx="650" cy="95" r="3" fill="rgba(244,162,97,0.1)" stroke="rgba(244,162,97,0.35)" stroke-width="1"/>

          <!-- Final convergence to exit node -->
          <line x1="650" y1="65" x2="730" y2="80" stroke="rgba(0,209,178,0.18)" stroke-width="1"/>
          <line x1="650" y1="95" x2="730" y2="80" stroke="rgba(244,162,97,0.18)" stroke-width="1"/>

