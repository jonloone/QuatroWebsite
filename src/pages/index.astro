              {insights[3].data.heroImage && <img alt="" src={insights[3].data.heroImage} class="h-80 object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />}
              <div class="p-10 pt-4">
                <span class="font-mono text-[10px] uppercase tracking-[0.12em]" style="color: var(--color-forest);">{insights[3].data.category.replace('-', ' ')}</span>
                <h3 class="mt-2 font-display text-lg font-bold tracking-tight transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">
                  {insights[3].data.title}
                </h3>
                <p class="mt-2 max-w-lg font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">
                  {insights[3].data.excerpt.slice(0, 100)}...
                </p>
              </div>
            </a>
            <div class="pointer-events-none absolute inset-0 rounded-lg shadow-sm" style="outline: 1px solid var(--color-structure);"></div>
          </div>
        )}

        {insights[4] && (
          <div class="relative lg:col-span-2">
            <div class="absolute inset-0 rounded-lg bg-white max-lg:rounded-b-[2rem] lg:rounded-br-[2rem]"></div>
            <a href={`/insights/${insights[4].id.replace(/\.md$/, '')}`} class="group relative flex h-full flex-col overflow-hidden rounded-[calc(0.5rem+1px)] max-lg:rounded-b-[calc(2rem+1px)] lg:rounded-br-[calc(2rem+1px)]">
              {insights[4].data.heroImage && <img alt="" src={insights[4].data.heroImage} class="h-80 object-cover transition-transform duration-500 group-hover:scale-105" loading="lazy" />}
              <div class="p-10 pt-4">
                <span class="font-mono text-[10px] uppercase tracking-[0.12em]" style="color: var(--color-forest);">{insights[4].data.category.replace('-', ' ')}</span>
                <h3 class="mt-2 font-display text-lg font-bold tracking-tight transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">
                  {insights[4].data.title}
                </h3>
                <p class="mt-2 max-w-lg font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">
                  {insights[4].data.excerpt.slice(0, 100)}...
                </p>
              </div>
            </a>
            <div class="pointer-events-none absolute inset-0 rounded-lg shadow-sm max-lg:rounded-b-[2rem] lg:rounded-br-[2rem]" style="outline: 1px solid var(--color-structure);"></div>
          </div>
        )}

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       7. FINAL CTA — Dithering Card
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-12 lg:py-20 px-4 md:px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="w-full max-w-7xl mx-auto relative" data-cta-card>
      <div class="relative overflow-hidden rounded-[32px] lg:rounded-[48px] min-h-[550px] md:min-h-[600px] flex flex-col items-center justify-center" style="border: 1px solid rgba(15,76,58,0.4); background: #0a0a0a;">

        <!-- Canvas dithering overlay -->
        <canvas id="cta-dither-canvas" class="absolute inset-0 w-full h-full z-[1] opacity-60" data-dither-canvas data-image-src="/images/cta-connected-bg.png" data-pixel-size="3" data-base-speed="0.12" data-hover-speed="0.5" data-green-blend="0.5"></canvas>

        <!-- Dark center vignette for text readability -->
        <div class="absolute inset-0 z-[2] pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(0,0,0,0.7) 0%, rgba(0,0,0,0.3) 50%, transparent 80%);"></div>

        <!-- Film grain -->
        <svg style="position:absolute;width:0;height:0;">
          <filter id="cta-grain-filter">
            <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" />
            <feColorMatrix type="saturate" values="0" />
          </filter>
        </svg>
        <div class="absolute inset-0 z-[3] pointer-events-none opacity-[0.08]" style="filter: url(#cta-grain-filter);"></div>

        <!-- Content -->
        <div class="relative z-10 flex flex-col items-center justify-center text-center px-6 py-16 lg:py-24 max-w-3xl mx-auto fade-up">
          <!-- Headline -->
          <h2 class="font-sans text-3xl md:text-5xl lg:text-6xl font-light text-white leading-[1.1] tracking-tight">
            Start with what matters.<br/>
            <span class="text-white/50">We connect the systems.</span>
          </h2>

          <!-- Description -->
          <p class="mt-6 font-sans text-base lg:text-lg text-white/50 leading-relaxed max-w-xl">
            Tell us the decision your team needs to make. We work backward to the data that matters, connect the systems that hold the answer, and give your team workflows, agents, and automations that compound with every use case.
          </p>

          <!-- Single CTA -->
          <div class="mt-10 flex flex-col items-center gap-3">
            <a
              href="/contact/demo"
              class="group inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.08em] px-8 py-4 rounded-full transition-all duration-300 ease-out hover:scale-105"
              style="background-color: var(--color-forest); color: white;"
            >
              Schedule an Assessment
              <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
            <p class="font-mono text-[11px] uppercase tracking-[0.12em] text-white/35">Your team works from the model.</p>
          </div>
        </div>

        <!-- Sovereignty signal -->
        <div class="relative z-10 w-full px-8 pb-8">
          <div class="pt-6 flex items-center justify-center" style="border-top: 1px solid rgba(255,255,255,0.08);">
            <p class="font-mono text-[11px] uppercase tracking-[0.12em] text-white/30 text-center">Deployed on your infrastructure.&nbsp; Air-gapped capable.&nbsp; Your data never leaves your control.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       FOOTER
       ═══════════════════════════════════════════════════════════════ -->
  <SiteFooter lang="en" />

</BaseLayout>
