---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SiteHeader from '@/components/layout/SiteHeader.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
import HeroCanvas from '@/components/marketing/HeroCanvas.astro'
import FloatingPaths from '@/components/ui/FloatingPaths'
import { getCollection } from 'astro:content'
const insights = (await getCollection('insights'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 5)
---

<BaseLayout
  title="Quatro — The Operational Intelligence Utility"
  description="Tell us the outcome that matters. We connect the systems that hold the answer. Your team gets workflows, agents, automations, and APIs — deployed your way, governed for trust."
  lang="en"
>

  <SiteHeader lang="en" />

  <!-- ═══════════════════════════════════════════════════════════════
       1. HERO — Dithering Card (via HeroCanvas component)
       ═══════════════════════════════════════════════════════════════ -->
  <HeroCanvas
    badge="Quatro"
    title='Systems That Think.<br/><span class="text-white/60">People Who Build.</span>'
    body="Your operations generate data across dozens of systems — but that data doesn't talk to itself. Quatro is the operational intelligence utility. Tell us the outcome that matters, and we connect the systems that hold the answer. Your team gets back workflows, agents, automations, and APIs — built on the data that matters, not all the data."
    ctaLabel="Schedule an Assessment"
    ctaHref="/contact/demo"
    imageSrc="/images/hero-bg.png"
    pixelSize={3}
    baseSpeed={0.1}
    hoverSpeed={0.5}
    greenBlend={0.75}
    canvasOpacity={85}
    minHeight="min-h-[480px] md:min-h-[560px]"
  />

  <!-- ═══════════════════════════════════════════════════════════════
       2. INDUSTRIES — Palantir-style vertical list
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-20 lg:py-28 px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <!-- Editorial intro — large type, frames the platform before listing industries -->
      <h2 class="font-sans font-light text-3xl sm:text-4xl lg:text-6xl xl:text-7xl leading-[1.15] tracking-tight fade-up" style="color: var(--color-neutral-800);">
        Operational intelligence for the industries that keep communities<br /><span style="color: var(--color-forest);">connected, powered, and safe</span>.
      </h2>

      <!-- Energy -->
      <a href="/industries/energy" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up mt-16" style="border-top: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Connect pipeline, grid, and production operations. Predictive intelligence on legacy SCADA — intelligence flowing in weeks, not years.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Energy</span>
        </div>
      </a>

      <!-- National Security -->
      <a href="/industries/national-security" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up" style="border-top: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Multi-domain operational intelligence with sovereign deployment. Air-gapped capable. Governed and auditable.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">National Security</span>
        </div>
      </a>

      <!-- Networks -->
      <a href="/industries/networks" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up" style="border-top: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Operational intelligence from ground to orbit. Terrestrial, satellite, and hybrid connectivity — one view, one intelligence layer.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Networks</span>
        </div>
      </a>

      <!-- Critical Infrastructure -->
      <a href="/industries/critical-infrastructure" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up" style="border-top: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 0h.008v.008h-.008V7.5z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Intelligence for the systems cities depend on — water, transportation, municipal operations, and the built environment.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Critical Infrastructure</span>
        </div>
      </a>

      <!-- Finance -->
      <a href="/industries/finance" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up" style="border-top: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Connect the 15–30 systems your institution already operates. Operational intelligence production-ready in weeks.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Finance</span>
        </div>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       3. THE UTILITY — Intelligence pillars, how it works, proof stories
       ═══════════════════════════════════════════════════════════════ -->
  <section class="relative py-24 lg:py-32 px-6 overflow-hidden" style="background: #0a0a0a;">
    <!-- Animated background paths -->
    <div class="absolute inset-0 opacity-60">
      <FloatingPaths client:visible />
    </div>
    <div class="relative z-10 mx-auto max-w-6xl">

      <!-- Editorial lead -->
      <p class="font-mono text-xs uppercase tracking-[0.1em] mb-8 fade-up" style="color: var(--color-forest);">The Intelligence Utility</p>
      <h2 class="font-sans font-light text-3xl sm:text-4xl lg:text-5xl xl:text-6xl leading-[1.15] tracking-tight text-white fade-up">
        Start with the outcome.<br /><span class="text-white/40">Connect only what matters.</span>
      </h2>
      <p class="mt-6 font-sans text-lg lg:text-xl leading-relaxed max-w-3xl text-white/50 fade-up">
        Tell us the decision your team needs to make. We work backward to the systems that hold the answer — not all your data, just the data that matters. Your team gets back workflows, agents, automations, and APIs built on a governed operating model that compounds with every use case.
      </p>

      <!-- How it works — visual flow diagram (moved up, bigger, bolder) -->
      <div class="mt-14 lg:mt-18 fade-up rounded-2xl px-6 py-10 lg:px-10 lg:py-14" style="border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.04); backdrop-filter: blur(24px) saturate(1.2); -webkit-backdrop-filter: blur(24px) saturate(1.2); box-shadow: 0 8px 32px rgba(0,0,0,0.3), inset 0 1px 0 rgba(255,255,255,0.06);">

        <!-- Right-to-left flow diagram SVG — bigger, bolder, thicker -->
        <svg class="w-full h-auto mb-10" viewBox="0 0 1100 240" fill="none" xmlns="http://www.w3.org/2000/svg">
          <style>
            @keyframes hiw-flow-rtl { 0% { stroke-dashoffset: 0; } 100% { stroke-dashoffset: 16; } }
            @keyframes hiw-pulse { 0%, 100% { opacity: 0.25; } 50% { opacity: 0.8; } }
            @keyframes hiw-feedback { 0% { stroke-dashoffset: 0; } 100% { stroke-dashoffset: -20; } }
            .hiw-flow-rtl { animation: hiw-flow-rtl 1.2s linear infinite; }
            .hiw-pulse-dot { animation: hiw-pulse 2.5s ease-in-out infinite; }
            .hiw-feedback-dash { animation: hiw-feedback 2s linear infinite; }
          </style>

          <!-- ===== LEFT: OUTCOME / USE CASE (bright, prominent) ===== -->

          <!-- Outcome node — large, bright green -->
          <circle cx="90" cy="105" r="12" fill="rgba(0,209,178,0.25)" stroke="rgba(0,209,178,0.7)" stroke-width="2.5"/>
          <circle cx="90" cy="105" r="4.5" fill="rgba(0,209,178,0.85)"/>

          <!-- Outcome label -->
          <text x="90" y="145" text-anchor="middle" fill="rgba(0,209,178,0.7)" font-family="monospace" font-size="11" font-weight="bold" letter-spacing="0.12em">USE CASE</text>

          <!-- Expanding outcome ripples (emanating left) -->
          <path d="M 65 105 Q 28 72, 5 105 Q 28 138, 65 105" fill="none" stroke="rgba(0,209,178,0.15)" stroke-width="1.5"/>
          <path d="M 58 105 Q 12 60, -15 105 Q 12 150, 58 105" fill="none" stroke="rgba(0,209,178,0.08)" stroke-width="1.5"/>

          <!-- Outcome dots (actions/decisions radiating left) -->
          <circle cx="40" cy="78" r="3.5" fill="rgba(0,209,178,0.55)" class="hiw-pulse-dot"/>
          <circle cx="40" cy="132" r="3.5" fill="rgba(0,209,178,0.55)" class="hiw-pulse-dot" style="animation-delay:0.8s"/>
          <circle cx="12" cy="65" r="2.5" fill="rgba(0,209,178,0.4)" class="hiw-pulse-dot" style="animation-delay:1.4s"/>
          <circle cx="12" cy="145" r="2.5" fill="rgba(0,209,178,0.4)" class="hiw-pulse-dot" style="animation-delay:0.5s"/>

          <!-- ===== Arrow: Outcome determines Metrics ===== -->
          <line x1="104" y1="105" x2="215" y2="105" stroke="rgba(0,209,178,0.3)" stroke-width="1.5" stroke-dasharray="5,5" class="hiw-flow-rtl"/>

          <!-- Metrics cluster -->
          <circle cx="240" cy="72" r="4" fill="rgba(0,209,178,0.18)" stroke="rgba(0,209,178,0.5)" stroke-width="1.5" class="hiw-pulse-dot"/>
          <circle cx="240" cy="105" r="5" fill="rgba(0,209,178,0.22)" stroke="rgba(0,209,178,0.55)" stroke-width="1.5"/>
          <circle cx="240" cy="138" r="4" fill="rgba(0,209,178,0.18)" stroke="rgba(0,209,178,0.5)" stroke-width="1.5" class="hiw-pulse-dot" style="animation-delay:0.6s"/>
          <line x1="240" y1="72" x2="240" y2="105" stroke="rgba(0,209,178,0.15)" stroke-width="1.5" stroke-dasharray="3,4"/>
          <line x1="240" y1="105" x2="240" y2="138" stroke="rgba(0,209,178,0.15)" stroke-width="1.5" stroke-dasharray="3,4"/>

          <!-- Metrics label -->
          <text x="240" y="168" text-anchor="middle" fill="rgba(255,255,255,0.25)" font-family="monospace" font-size="11" letter-spacing="0.1em">METRICS</text>

          <!-- ===== CENTER: GOVERNED DATA PRODUCT (the model box) ===== -->
          <line x1="260" y1="72" x2="380" y2="72" stroke="rgba(244,162,97,0.18)" stroke-width="1.5" stroke-dasharray="5,5" class="hiw-flow-rtl" style="animation-delay:0.2s"/>
          <line x1="260" y1="105" x2="380" y2="105" stroke="rgba(244,162,97,0.25)" stroke-width="1.5" stroke-dasharray="5,5" class="hiw-flow-rtl" style="animation-delay:0.4s"/>
          <line x1="260" y1="138" x2="380" y2="138" stroke="rgba(244,162,97,0.18)" stroke-width="1.5" stroke-dasharray="5,5" class="hiw-flow-rtl" style="animation-delay:0.6s"/>

          <!-- Data product box -->
          <rect x="380" y="30" rx="8" ry="8" width="360" height="150" fill="rgba(244,162,97,0.04)" stroke="rgba(244,162,97,0.2)" stroke-width="1.5"/>

          <!-- Data product label -->
          <text x="560" y="22" text-anchor="middle" fill="rgba(244,162,97,0.45)" font-family="monospace" font-size="11" font-weight="bold" letter-spacing="0.12em">GOVERNED DATA PRODUCT</text>

          <!-- Internal semantic network (amber tones) — bigger nodes -->
          <circle cx="415" cy="65" r="4" fill="rgba(244,162,97,0.15)" stroke="rgba(244,162,97,0.4)" stroke-width="1.5"/>
          <circle cx="415" cy="105" r="5" fill="rgba(244,162,97,0.18)" stroke="rgba(244,162,97,0.45)" stroke-width="1.5"/>
          <circle cx="415" cy="145" r="4" fill="rgba(244,162,97,0.15)" stroke="rgba(244,162,97,0.4)" stroke-width="1.5"/>

          <!-- Semantic layer nodes -->
          <circle cx="500" cy="55" r="4" fill="rgba(244,162,97,0.12)" stroke="rgba(244,162,97,0.35)" stroke-width="1.5" class="hiw-pulse-dot" style="animation-delay:0.3s"/>
          <circle cx="500" cy="90" r="5" fill="rgba(244,162,97,0.18)" stroke="rgba(244,162,97,0.45)" stroke-width="2"/>
          <circle cx="500" cy="125" r="4" fill="rgba(244,162,97,0.12)" stroke="rgba(244,162,97,0.35)" stroke-width="1.5" class="hiw-pulse-dot" style="animation-delay:0.9s"/>
          <circle cx="500" cy="155" r="3" fill="rgba(244,162,97,0.1)" stroke="rgba(244,162,97,0.28)" stroke-width="1"/>

          <!-- Governance nodes (white) -->
          <circle cx="585" cy="62" r="3.5" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.3)" stroke-width="1.5" class="hiw-pulse-dot" style="animation-delay:1s"/>
          <circle cx="585" cy="98" r="4" fill="rgba(255,255,255,0.12)" stroke="rgba(255,255,255,0.35)" stroke-width="1.5"/>
          <circle cx="585" cy="134" r="4" fill="rgba(255,255,255,0.12)" stroke="rgba(255,255,255,0.35)" stroke-width="1.5"/>

          <!-- Convergence nodes -->
          <circle cx="665" cy="80" r="4" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.25)" stroke-width="1.5"/>
          <circle cx="665" cy="128" r="4" fill="rgba(255,255,255,0.1)" stroke="rgba(255,255,255,0.25)" stroke-width="1.5"/>

          <!-- Internal connections — thicker -->
          <line x1="415" y1="65" x2="500" y2="55" stroke="rgba(244,162,97,0.18)" stroke-width="1.5"/>
          <line x1="415" y1="65" x2="500" y2="90" stroke="rgba(244,162,97,0.12)" stroke-width="1.5"/>
          <line x1="415" y1="105" x2="500" y2="90" stroke="rgba(244,162,97,0.22)" stroke-width="1.5"/>
          <line x1="415" y1="105" x2="500" y2="125" stroke="rgba(244,162,97,0.15)" stroke-width="1.5"/>
          <line x1="415" y1="145" x2="500" y2="125" stroke="rgba(244,162,97,0.18)" stroke-width="1.5"/>
          <line x1="415" y1="145" x2="500" y2="155" stroke="rgba(244,162,97,0.12)" stroke-width="1.5"/>
          <line x1="500" y1="55" x2="585" y2="62" stroke="rgba(255,255,255,0.1)" stroke-width="1.5"/>
          <line x1="500" y1="90" x2="585" y2="62" stroke="rgba(255,255,255,0.07)" stroke-width="1.5"/>
          <line x1="500" y1="90" x2="585" y2="98" stroke="rgba(255,255,255,0.12)" stroke-width="1.5"/>
          <line x1="500" y1="125" x2="585" y2="98" stroke="rgba(255,255,255,0.1)" stroke-width="1.5"/>
          <line x1="500" y1="125" x2="585" y2="134" stroke="rgba(255,255,255,0.12)" stroke-width="1.5"/>
          <line x1="500" y1="155" x2="585" y2="134" stroke="rgba(255,255,255,0.07)" stroke-width="1.5"/>
          <line x1="585" y1="62" x2="665" y2="80" stroke="rgba(255,255,255,0.1)" stroke-width="1.5"/>
          <line x1="585" y1="98" x2="665" y2="80" stroke="rgba(255,255,255,0.08)" stroke-width="1.5"/>
          <line x1="585" y1="98" x2="665" y2="128" stroke="rgba(255,255,255,0.08)" stroke-width="1.5"/>
          <line x1="585" y1="134" x2="665" y2="128" stroke="rgba(255,255,255,0.1)" stroke-width="1.5"/>

          <!-- Vertical dashed connections inside semantic layer -->
          <line x1="500" y1="55" x2="500" y2="90" stroke="rgba(244,162,97,0.1)" stroke-width="1" stroke-dasharray="3,4"/>
          <line x1="500" y1="90" x2="500" y2="125" stroke="rgba(244,162,97,0.1)" stroke-width="1" stroke-dasharray="3,4"/>
          <line x1="585" y1="62" x2="585" y2="98" stroke="rgba(255,255,255,0.06)" stroke-width="1" stroke-dasharray="3,4"/>
          <line x1="585" y1="98" x2="585" y2="134" stroke="rgba(255,255,255,0.06)" stroke-width="1" stroke-dasharray="3,4"/>

          <!-- Connect node on right edge of box -->
          <circle cx="740" cy="105" r="7" fill="rgba(255,255,255,0.12)" stroke="rgba(255,255,255,0.35)" stroke-width="2"/>
          <line x1="665" y1="80" x2="740" y2="105" stroke="rgba(255,255,255,0.12)" stroke-width="1.5"/>
          <line x1="665" y1="128" x2="740" y2="105" stroke="rgba(255,255,255,0.12)" stroke-width="1.5"/>

          <!-- ===== RIGHT: SOURCE SYSTEMS (dim, secondary) ===== -->

          <!-- Dashed lines from box to source dots -->
          <line x1="748" y1="105" x2="830" y2="95" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" stroke-dasharray="5,5" class="hiw-flow-rtl"/>
          <line x1="748" y1="105" x2="830" y2="105" stroke="rgba(255,255,255,0.18)" stroke-width="1.5" stroke-dasharray="5,5" class="hiw-flow-rtl" style="animation-delay:0.3s"/>
          <line x1="748" y1="105" x2="830" y2="115" stroke="rgba(255,255,255,0.15)" stroke-width="1.5" stroke-dasharray="5,5" class="hiw-flow-rtl" style="animation-delay:0.6s"/>

          <!-- Diverging lines to individual sources -->
          <line x1="830" y1="95" x2="1084" y2="40" stroke="rgba(255,255,255,0.08)" stroke-width="1" stroke-dasharray="5,5" class="hiw-flow-rtl"/>
          <line x1="830" y1="98" x2="1084" y2="72" stroke="rgba(255,255,255,0.06)" stroke-width="1" stroke-dasharray="5,5" class="hiw-flow-rtl" style="animation-delay:0.2s"/>
          <line x1="830" y1="105" x2="1084" y2="105" stroke="rgba(255,255,255,0.09)" stroke-width="1" stroke-dasharray="5,5" class="hiw-flow-rtl" style="animation-delay:0.4s"/>
          <line x1="830" y1="112" x2="1084" y2="138" stroke="rgba(255,255,255,0.06)" stroke-width="1" stroke-dasharray="5,5" class="hiw-flow-rtl" style="animation-delay:0.6s"/>
          <line x1="830" y1="115" x2="1084" y2="170" stroke="rgba(255,255,255,0.08)" stroke-width="1" stroke-dasharray="5,5" class="hiw-flow-rtl" style="animation-delay:0.8s"/>

          <!-- Source system dots (dim white) -->
          <circle cx="1084" cy="40" r="3" fill="rgba(255,255,255,0.18)" class="hiw-pulse-dot"/>
          <circle cx="1084" cy="72" r="3" fill="rgba(255,255,255,0.18)" class="hiw-pulse-dot" style="animation-delay:0.4s"/>
          <circle cx="1084" cy="105" r="3" fill="rgba(255,255,255,0.18)" class="hiw-pulse-dot" style="animation-delay:0.8s"/>
