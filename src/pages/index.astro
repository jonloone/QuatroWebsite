  <!-- Engagement scroll — updates sticky label on scroll -->
  <script>
    (function () {
      var section = document.getElementById('engagements-scroll');
      if (!section) return;
      var blocks = section.querySelectorAll('.engagement-block');
      var label = section.querySelector('.engagement-label');
      var sublabel = section.querySelector('.engagement-sublabel');
      if (!label || !sublabel || blocks.length === 0) return;

      var currentLabel = label.getAttribute('data-default') || '';

      function update() {
        var closest = null;
        var closestDist = Infinity;
        var viewMid = window.innerHeight * 0.4;

        blocks.forEach(function (block) {
          var rect = block.getBoundingClientRect();
          var blockMid = rect.top + rect.height * 0.3;
          var dist = Math.abs(blockMid - viewMid);
          if (rect.top < window.innerHeight * 0.7 && rect.bottom > 0 && dist < closestDist) {
            closestDist = dist;
            closest = block;
          }
        });

        if (closest) {
          var newLabel = closest.getAttribute('data-label') || '';
          if (newLabel !== currentLabel) {
            currentLabel = newLabel;
            label.style.opacity = '0';
            label.style.transform = 'translateY(8px)';
            sublabel.style.opacity = '0';
            setTimeout(function () {
              label.textContent = newLabel;
              sublabel.textContent = closest.getAttribute('data-sublabel') || '';
              label.style.opacity = '1';
              label.style.transform = 'translateY(0)';
              sublabel.style.opacity = '1';
            }, 250);
          }
        }
      }

      window.addEventListener('scroll', update, { passive: true });
      update();
    })();
  </script>

