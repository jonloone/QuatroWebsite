  <!-- Dotted Wireframe Globe (D3 orthographic projection, 21st.dev/shadway style) -->
  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/d3/7.9.0/d3.min.js"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', function () {
      var canvas = document.getElementById('globe-canvas');
      if (!canvas || typeof d3 === 'undefined') return;
      var ctx = canvas.getContext('2d');
      if (!ctx) return;

      // ─── Sizing ───
      var section = canvas.parentElement;
      var w, h, radius;

      function resize() {
        var rect = section.getBoundingClientRect();
        var dpr = Math.min(window.devicePixelRatio || 1, 2);
        w = rect.width;
        h = rect.height;
        canvas.width = w * dpr;
        canvas.height = h * dpr;
        canvas.style.width = w + 'px';
        canvas.style.height = h + 'px';
        ctx.setTransform(dpr, 0, 0, dpr, 0, 0);
        radius = Math.min(w, h) * 0.42;
        projection.scale(radius).translate([w * 0.62, h * 0.48]);
      }

      // ─── D3 Projection ───
      var projection = d3.geoOrthographic().clipAngle(90);
      var path = d3.geoPath().projection(projection);
      var rotation = [30, -15];
      var rotationSpeed = 0.18;

      // ─── Colors (forest green palette) ───
      var dotColor = 'rgba(15, 76, 58, 0.7)';
      var graticuleColor = 'rgba(15, 76, 58, 0.15)';
      var outlineColor = 'rgba(15, 76, 58, 0.3)';
      var sphereStroke = 'rgba(15, 76, 58, 0.2)';

      // Operational presence markers
      var regions = [
        { coords: [-98.5, 39.8], size: 6 },   // US HQ
        { coords: [-78.5, -1.8], size: 6 },   // Ecuador / LATAM
        { coords: [45, 25], size: 5 },         // MENA
        { coords: [-99.1, 19.4], size: 4 },   // Mexico
        { coords: [36.8, -1.3], size: 4 },    // East Africa
        { coords: [-47.9, -15.8], size: 3 },  // Brazil
        { coords: [-0.1, 51.5], size: 3 },    // UK
        { coords: [54.4, 24.5], size: 3 },    // UAE
        { coords: [3.4, 6.5], size: 3 },      // West Africa
      ];

      // ─── Point-in-polygon ───
      function pointInPolygon(pt, ring) {
        var x = pt[0], y = pt[1], inside = false;
        for (var i = 0, j = ring.length - 1; i < ring.length; j = i++) {
          var xi = ring[i][0], yi = ring[i][1];
          var xj = ring[j][0], yj = ring[j][1];
          if ((yi > y) !== (yj > y) && x < ((xj - xi) * (y - yi)) / (yj - yi) + xi) {
            inside = !inside;
          }
        }
        return inside;
      }

      function pointInFeature(pt, feature) {
        var geom = feature.geometry;
        if (geom.type === 'Polygon') {
          if (!pointInPolygon(pt, geom.coordinates[0])) return false;
          for (var i = 1; i < geom.coordinates.length; i++) {
            if (pointInPolygon(pt, geom.coordinates[i])) return false;
          }
          return true;
        } else if (geom.type === 'MultiPolygon') {
          for (var p = 0; p < geom.coordinates.length; p++) {
            var poly = geom.coordinates[p];
            if (pointInPolygon(pt, poly[0])) {
              var inHole = false;
              for (var h = 1; h < poly.length; h++) {
                if (pointInPolygon(pt, poly[h])) { inHole = true; break; }
              }
              if (!inHole) return true;
            }
          }
        }
        return false;
      }

      function generateDots(feature, step) {
        var dots = [];
        var bounds = d3.geoBounds(feature);
        var stepSize = step * 0.08;
        for (var lng = bounds[0][0]; lng <= bounds[1][0]; lng += stepSize) {
          for (var lat = bounds[0][1]; lat <= bounds[1][1]; lat += stepSize) {
            var pt = [lng, lat];
            if (pointInFeature(pt, feature)) dots.push(pt);
          }
        }
        return dots;
      }

      // ─── Render ───
      var allDots = [];
      var landFeatures = null;
      var graticule = d3.geoGraticule();

      function render() {
        ctx.clearRect(0, 0, w, h);
        path.context(ctx);

        // Sphere outline
        ctx.beginPath();
        path({ type: 'Sphere' });
        ctx.strokeStyle = sphereStroke;
        ctx.lineWidth = 1.5;
        ctx.stroke();

        // Graticule grid
        ctx.beginPath();
        path(graticule());
        ctx.strokeStyle = graticuleColor;
        ctx.lineWidth = 0.5;
        ctx.stroke();

        if (landFeatures) {
          // Land outlines
          ctx.beginPath();
          landFeatures.features.forEach(function (f) { path(f); });
          ctx.strokeStyle = outlineColor;
          ctx.lineWidth = 0.8;
          ctx.stroke();

          // Halftone dots on land
          allDots.forEach(function (dot) {
            var projected = projection(dot);
            if (projected) {
              // Only draw if on visible hemisphere (check against clip)
              var dist = d3.geoDistance(dot, projection.invert([w * 0.62, h * 0.48]));
              if (dist < Math.PI / 2) {
                ctx.beginPath();
                ctx.arc(projected[0], projected[1], 1.0, 0, 2 * Math.PI);
                ctx.fillStyle = dotColor;
                ctx.fill();
              }
            }
          });

          // Operational presence markers (brighter, pulsing)
          var t = Date.now() / 1000;
          regions.forEach(function (r) {
            var projected = projection(r.coords);
            if (projected) {
              var dist = d3.geoDistance(r.coords, projection.invert([w * 0.62, h * 0.48]));
              if (dist < Math.PI / 2) {
                // Pulse glow
                var pulse = 0.4 + 0.3 * Math.sin(t * 2 + r.coords[0]);
                ctx.beginPath();
                ctx.arc(projected[0], projected[1], r.size * 2.5, 0, 2 * Math.PI);
                ctx.fillStyle = 'rgba(15, 76, 58, ' + (pulse * 0.3) + ')';
                ctx.fill();

                // Core dot
                ctx.beginPath();
                ctx.arc(projected[0], projected[1], r.size, 0, 2 * Math.PI);
                ctx.fillStyle = '#0f4c3a';
                ctx.fill();
                ctx.strokeStyle = 'rgba(255,255,255,0.15)';
                ctx.lineWidth = 0.8;
                ctx.stroke();
              }
            }
          });
        }
      }

      // ─── Animation ───
      var animId;
      function animate() {
        rotation[0] += rotationSpeed;
        projection.rotate(rotation);
        render();
        animId = requestAnimationFrame(animate);
      }

      // ─── Visibility gating ───
      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) {
            resize();
            animId = requestAnimationFrame(animate);
          } else {
            cancelAnimationFrame(animId);
          }
        });
      }, { threshold: 0.05 });

      observer.observe(canvas);
      window.addEventListener('resize', function () {
        resize();
        render();
      });

      // ─── Load land data ───
      resize();
      fetch('https://raw.githubusercontent.com/martynafford/natural-earth-geojson/refs/heads/master/110m/physical/ne_110m_land.json')
        .then(function (r) { return r.json(); })
        .then(function (data) {
          landFeatures = data;
          data.features.forEach(function (feature) {
            var dots = generateDots(feature, 18);
            dots.forEach(function (d) { allDots.push(d); });
          });
          render();
        })
        .catch(function () {
          // Graceful fallback — render graticule only
          render();
        });
    });
  </script>

