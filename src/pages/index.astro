---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SiteHeader from '@/components/layout/SiteHeader.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
---

<BaseLayout
  title="Quatro — Industrial Intelligence Platform"
  description="Quatro unifies OT and IT into a single intelligence platform — designed for critical infrastructure and the operational reality of Latin America."
>

  <SiteHeader />

  <!-- ═══════════════════════════════════════════════════════════════
       1. HERO — Full-screen background image
       ═══════════════════════════════════════════════════════════════ -->
  <section data-hero class="relative min-h-[85vh] lg:min-h-[90vh] flex items-end overflow-hidden px-6 pb-20 lg:pb-28">
    <!-- Background image -->
    <div class="absolute inset-0">
      <img src="/images/hero-bg.png" alt="" class="h-full w-full object-cover" />
      <div class="absolute inset-0" style="background: linear-gradient(180deg, rgba(0,0,0,0.3) 0%, rgba(0,0,0,0.5) 100%);"></div>
    </div>

    <!-- connect.png — bottom right graphic, overflows right edge -->
    <img src="/images/connect.png" alt="" class="absolute bottom-0 w-[90%] lg:w-[70%] object-contain pointer-events-none select-none" style="right: -20%;" />

    <div class="relative z-10 mx-auto max-w-5xl w-full text-left pt-16">
      <!-- Status badge -->
      <div class="inline-flex items-center gap-2.5 px-4 py-2 mb-10" style="background: rgba(255,255,255,0.1); backdrop-filter: blur(8px);">
        <div class="w-2 h-2 rounded-full pulse-dot" style="background-color: var(--color-forest);"></div>
        <span class="font-mono text-xs uppercase tracking-[0.05em] text-white/80">
          Platform v4.2 — Operational
        </span>
      </div>

      <!-- Eyebrow -->
      <p class="font-mono text-xs uppercase tracking-[0.05em] text-white/60 mb-8">
        For operations teams in critical infrastructure
      </p>

      <!-- H1 — Reckless Light -->
      <h1 class="font-sans font-light text-4xl sm:text-5xl lg:text-7xl leading-[1.1] text-white">
        Built with you.<br />
        For your operations.<br />
        Under your control.
      </h1>

      <!-- Subhead -->
      <p class="mt-8 font-sans text-base lg:text-lg text-white/60 max-w-xl leading-relaxed">
        Quatro unifies OT and IT into a single intelligence platform — designed for critical infrastructure and the operational reality of Latin America.
      </p>

      <!-- CTAs -->
      <div class="mt-10 flex flex-wrap items-center gap-4">
        <a
          href="/contact/demo"
          class="font-mono text-xs uppercase tracking-[0.05em] px-8 py-4 text-white transition-colors duration-300 ease-linear"
          style="background-color: var(--color-forest);"
        >
          Let's Talk
        </a>
        <a
          href="/platform"
          class="font-mono text-xs uppercase tracking-[0.05em] px-8 py-4 text-white transition-colors duration-300 ease-linear hover:bg-white/10"
          style="border: 1px solid rgba(255,255,255,0.2);"
        >
          Explore the Platform &rarr;
        </a>
      </div>

      <!-- Microcopy -->
      <p class="mt-4 font-mono text-xs text-white/40">
        Tell us about your operation. No commitment required.
      </p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       2. REGIONAL COMMITMENT — Pattern A (Grid Section)
       ═══════════════════════════════════════════════════════════════ -->
  <section class="px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-0">
        <!-- Sidebar label -->
        <div class="pt-20 lg:pt-28 lg:pb-28 lg:col-span-3 lg:border-r lg:pr-8" style="border-color: var(--color-structure);">
          <span class="lg:sticky lg:top-32 inline-block font-mono text-[12px] font-bold uppercase tracking-[0.2em]" style="color: var(--color-neutral-500);">Presence</span>
        </div>
        <!-- Main content -->
        <div class="pb-20 lg:py-28 lg:col-span-9 lg:pl-8">
          <h2 class="font-display text-5xl lg:text-7xl font-bold leading-[0.95]" style="color: var(--color-forest);">
            Regional<br />Presence<br />Commitment
          </h2>
          <!-- Card grid -->
          <div class="mt-12 grid md:grid-cols-3" style="border-top: 1px solid var(--color-structure); border-left: 1px solid var(--color-structure);">
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">01</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Teams in Latin America</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Engineers and consultants who know your industry and speak your language.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">02</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Your Data in Your Country</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Edge-first architecture with guaranteed regional data sovereignty.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">03</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Support in Your Language</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Documentation, training, and technical support in Spanish and Portuguese.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       3. PROBLEM STATEMENT — Pattern A (Grid Section)
       ═══════════════════════════════════════════════════════════════ -->
  <section class="px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-0">
        <!-- Sidebar label -->
        <div class="pt-20 lg:pt-28 lg:pb-28 lg:col-span-3 lg:border-r lg:pr-8" style="border-color: var(--color-structure);">
          <span class="lg:sticky lg:top-32 inline-block font-mono text-[12px] font-bold uppercase tracking-[0.2em]" style="color: var(--color-neutral-500);">Challenge</span>
        </div>
        <!-- Main content -->
        <div class="pb-20 lg:py-28 lg:col-span-9 lg:pl-8">
          <h2 class="font-display text-5xl lg:text-7xl font-bold leading-[0.95]" style="color: var(--color-forest);">
            Real<br />Operational<br />Challenges
          </h2>
          <p class="mt-8 font-sans text-base leading-relaxed max-w-2xl" style="color: var(--color-neutral-500);">
            Your operation deserves technology designed for your infrastructure. Legacy systems from foreign vendors were never built for the distances, connectivity, or regulatory reality of Latin America.
          </p>
          <!-- Card grid -->
          <div class="mt-12 grid md:grid-cols-3" style="border-top: 1px solid var(--color-structure); border-left: 1px solid var(--color-structure);">
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">01</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Foreign Vendor Dependency</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Dollar-denominated licenses, support in another time zone, and updates that don't consider your operational context.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">02</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Remote Operations Without Visibility</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Assets distributed across thousands of kilometers with intermittent connectivity. Data arrives late — or not at all.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">03</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Institutional Knowledge Is Leaving</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Operators with decades of experience are retiring. Their knowledge lives in their heads, not in your systems.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       4. DATA SOVEREIGNTY — Pattern A (Grid Section)
       ═══════════════════════════════════════════════════════════════ -->
  <section class="px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-0">
        <!-- Sidebar label -->
        <div class="pt-20 lg:pt-28 lg:pb-28 lg:col-span-3 lg:border-r lg:pr-8" style="border-color: var(--color-structure);">
          <span class="lg:sticky lg:top-32 inline-block font-mono text-[12px] font-bold uppercase tracking-[0.2em]" style="color: var(--color-neutral-500);">Sovereignty</span>
        </div>
        <!-- Main content -->
        <div class="pb-20 lg:py-28 lg:col-span-9 lg:pl-8">
          <h2 class="font-display text-5xl lg:text-7xl font-bold leading-[0.95]" style="color: var(--color-forest);">
            Your<br />Data<br />Your Control
          </h2>
          <!-- Card grid -->
          <div class="mt-12 grid md:grid-cols-3" style="border-top: 1px solid var(--color-structure); border-left: 1px solid var(--color-structure);">
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">01</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Edge-First Architecture</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Local processing at every site. Data is analyzed where it's generated — with or without cloud connectivity.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">02</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Flexible Deployment</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">On-premise, private cloud, hybrid, or air-gapped. Adapts to your security and regulatory requirements.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-[rgba(15,76,58,0.04)]" style="border-right: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
              <span class="font-mono text-xs" style="color: var(--color-forest);">03</span>
              <h3 class="font-display text-lg font-bold mt-2" style="color: var(--color-neutral-800);">Open Formats</h3>
              <p class="mt-2 font-sans text-sm" style="color: var(--color-neutral-500);">Open APIs and standard formats. Your data is yours — always exportable, always accessible.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       5. THE PLATFORM — Pattern B (Palantir Vertical List)
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-20 lg:py-28 px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <!-- Editorial intro -->
      <p class="font-sans text-2xl lg:text-4xl font-light leading-snug max-w-4xl" style="color: var(--color-neutral-800);">
        Our platform unifies OT and IT into a single intelligence system — designed for the infrastructure and operational reality of <span style="color: var(--color-forest);">Latin America</span>.
      </p>

      <!-- Sub-heading -->
      <h2 class="font-display text-xl font-bold mt-16 mb-8" style="color: var(--color-forest);">
        Our Platform
      </h2>

      <!-- Connect -->
      <a href="/platform/connect" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center" style="border-top: 1px solid var(--color-structure);">
        <div>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Integrate your data. Over 8,000 industrial connectors. Universal connectivity for your infrastructure.</p>
          <span class="font-mono text-xs mt-3 inline-block" style="color: var(--color-forest);">/0.1</span>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-bold transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Connect</span>
        </div>
      </a>

      <!-- Operate -->
      <a href="/platform/operate" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center" style="border-top: 1px solid var(--color-structure);">
        <div>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Operate with intelligence. AI-powered anomaly detection, predictive maintenance, and process optimization.</p>
          <span class="font-mono text-xs mt-3 inline-block" style="color: var(--color-forest);">/0.2</span>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-bold transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Operate</span>
        </div>
      </a>

      <!-- Command -->
      <a href="/platform/command" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center" style="border-top: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
        <div>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">See everything. Respond as one team. Unified command center for distributed operations.</p>
          <span class="font-mono text-xs mt-3 inline-block" style="color: var(--color-forest);">/0.3</span>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-bold transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Command</span>
        </div>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       6. WHY QUATRO — Pattern A (Grid Section, Dark)
       ═══════════════════════════════════════════════════════════════ -->
  <section class="relative px-6 overflow-hidden" style="border-top: 1px solid var(--color-structure);">
    <!-- Background image -->
    <div class="absolute inset-0">
      <img src="/images/bg.jpg" alt="" class="h-full w-full object-cover" />
      <div class="absolute inset-0" style="background: rgba(0,0,0,0.8);"></div>
    </div>
    <div class="relative z-10 mx-auto max-w-6xl">
      <div class="grid lg:grid-cols-12 gap-8 lg:gap-0">
        <!-- Sidebar label -->
        <div class="pt-20 lg:pt-28 lg:pb-28 lg:col-span-3 lg:border-r lg:pr-8" style="border-color: rgba(255,255,255,0.1);">
          <span class="lg:sticky lg:top-32 inline-block font-mono text-[12px] font-bold uppercase tracking-[0.2em]" style="color: var(--color-neutral-500);">Why Quatro</span>
        </div>
        <!-- Main content -->
        <div class="pb-20 lg:py-28 lg:col-span-9 lg:pl-8">
          <h2 class="font-display text-5xl lg:text-7xl font-bold leading-[0.95] text-white">
            Regional<br />By Design<br />Yours to Own
          </h2>
          <!-- Card grid — 2 rows of 3 -->
          <div class="mt-12 grid md:grid-cols-3" style="border-top: 1px solid rgba(255,255,255,0.1); border-left: 1px solid rgba(255,255,255,0.1);">
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-white/20" style="background: rgba(255,255,255,0.05); border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
              <span class="font-mono text-xs text-white/60">01</span>
              <h3 class="font-display text-lg font-bold mt-2 text-white">Regional Presence</h3>
              <p class="mt-2 font-sans text-sm text-white/50">Engineering and support teams in the region. Implementation with local context.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-white/20" style="background: rgba(255,255,255,0.05); border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
              <span class="font-mono text-xs text-white/60">02</span>
              <h3 class="font-display text-lg font-bold mt-2 text-white">Data Sovereignty</h3>
              <p class="mt-2 font-sans text-sm text-white/50">Your operational data stays in your country. Compliant with local regulations.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-white/20" style="background: rgba(255,255,255,0.05); border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
              <span class="font-mono text-xs text-white/60">03</span>
              <h3 class="font-display text-lg font-bold mt-2 text-white">Flexible Investment</h3>
              <p class="mt-2 font-sans text-sm text-white/50">CAPEX, OPEX, or hybrid models. Local currency billing where possible.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-white/20" style="background: rgba(255,255,255,0.05); border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
              <span class="font-mono text-xs text-white/60">04</span>
              <h3 class="font-display text-lg font-bold mt-2 text-white">Built for Your Infrastructure</h3>
              <p class="mt-2 font-sans text-sm text-white/50">Works with intermittent connectivity, legacy equipment, and real-world conditions.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-white/20" style="background: rgba(255,255,255,0.05); border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
              <span class="font-mono text-xs text-white/60">05</span>
              <h3 class="font-display text-lg font-bold mt-2 text-white">Integrates with Existing Systems</h3>
              <p class="mt-2 font-sans text-sm text-white/50">Don't replace your SCADA. Quatro integrates on top of what you already have.</p>
            </div>
            <div class="p-6 transition-colors duration-300 ease-linear hover:bg-white/20" style="background: rgba(255,255,255,0.05); border-right: 1px solid rgba(255,255,255,0.1); border-bottom: 1px solid rgba(255,255,255,0.1);">
              <span class="font-mono text-xs text-white/60">06</span>
              <h3 class="font-display text-lg font-bold mt-2 text-white">Support in Your Language</h3>
              <p class="mt-2 font-sans text-sm text-white/50">Documentation, UI, training, and technical support in Spanish and Portuguese.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       8. INDUSTRIES — Pattern B (Palantir Vertical List)
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-20 lg:py-28 px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <!-- Editorial intro -->
      <p class="font-sans text-2xl lg:text-4xl font-light leading-snug max-w-4xl" style="color: var(--color-neutral-800);">
        Built for the industries that power <span style="color: var(--color-forest);">Latin America</span> — from the wellhead to the last mile.
      </p>

      <!-- Sub-heading -->
      <h2 class="font-display text-xl font-bold mt-16 mb-8" style="color: var(--color-forest);">
        Our Industries
      </h2>

      <!-- Oil & Gas -->
      <a href="/industries/energy" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center" style="border-top: 1px solid var(--color-structure);">
        <div>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Pipeline monitoring, production optimization, and integrity management — from wellhead to refinery.</p>
          <span class="font-mono text-xs mt-3 inline-block" style="color: var(--color-forest);">/0.1</span>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-bold transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Oil & Gas</span>
        </div>
      </a>

      <!-- Mining & Minerals -->
      <a href="#" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center" style="border-top: 1px solid var(--color-structure);">
        <div>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Fleet and heavy asset monitoring. Tailings management and environmental compliance.</p>
          <span class="font-mono text-xs mt-3 inline-block" style="color: var(--color-forest);">/0.2</span>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-bold transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Mining & Minerals</span>
        </div>
      </a>

      <!-- Energy & Utilities -->
      <a href="/industries/infrastructure" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center" style="border-top: 1px solid var(--color-structure);">
        <div>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Grid management, renewable integration, and intelligent distribution.</p>
          <span class="font-mono text-xs mt-3 inline-block" style="color: var(--color-forest);">/0.3</span>
        </div>
        <div class="text-right lg:text-right">
