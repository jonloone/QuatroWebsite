---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SiteHeader from '@/components/layout/SiteHeader.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
import { getCollection } from 'astro:content'
const insights = (await getCollection('insights'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 5)
---

<BaseLayout
  title="Quatro — Systems That Think. People Who Build."
  description="Quatro unifies your entire operation into one intelligence picture — so the people behind your infrastructure stop managing data and start building what's next."
  lang="en"
>

  <SiteHeader lang="en" />

  <!-- ═══════════════════════════════════════════════════════════════
       1. HERO — Dithering Card
       ═══════════════════════════════════════════════════════════════ -->
  <section class="pt-24 pb-12 lg:pt-28 lg:pb-20 px-4 md:px-6" data-hero style="background: #0a0a0a;">
    <div class="w-full max-w-7xl mx-auto relative" data-hero-card>
      <div class="relative overflow-hidden rounded-[32px] lg:rounded-[48px] min-h-[600px] md:min-h-[700px] flex flex-col items-center justify-center" style="border: 1px solid rgba(15,76,58,0.4); background: #0a0a0a;">

        <!-- Canvas dithering overlay — samples hero-bg.png -->
        <canvas id="hero-dither-canvas" class="absolute inset-0 w-full h-full z-[1] opacity-85"></canvas>

        <!-- Dark center vignette for text readability -->
        <div class="absolute inset-0 z-[2] pointer-events-none" style="background: radial-gradient(ellipse at center, rgba(0,0,0,0.65) 0%, rgba(0,0,0,0.25) 50%, transparent 80%);"></div>

        <!-- Film grain -->
        <svg style="position:absolute;width:0;height:0;">
          <filter id="hero-grain-filter">
            <feTurbulence type="fractalNoise" baseFrequency="0.65" numOctaves="3" />
            <feColorMatrix type="saturate" values="0" />
          </filter>
        </svg>
        <div class="absolute inset-0 z-[3] pointer-events-none opacity-[0.06]" style="filter: url(#hero-grain-filter);"></div>

        <!-- Content — centered -->
        <div class="relative z-10 flex flex-col items-center justify-center text-center px-6 py-16 lg:py-24 max-w-4xl mx-auto">

          <!-- Badge -->
          <div class="inline-flex items-center px-5 py-2.5 rounded-full mb-10" style="border: 1px solid rgba(255,255,255,0.12); background: rgba(255,255,255,0.05); backdrop-filter: blur(8px);">
            <span class="font-mono text-[11px] uppercase tracking-[0.15em] text-white/60">Quatro</span>
          </div>

          <!-- H1 -->
          <h1 class="font-sans font-light text-4xl sm:text-5xl md:text-7xl lg:text-8xl leading-[1.05] tracking-tight text-white">
            Systems That Think.<br />
            <span class="text-white/60">People Who Build.</span>
          </h1>

          <!-- Subhead -->
          <p class="mt-8 font-sans text-base lg:text-lg text-white/50 leading-relaxed max-w-2xl">
            Quatro unifies your entire operation into one intelligence picture — so the operators, engineers, and decision-makers behind your infrastructure stop managing data and start building what's next.
          </p>

          <!-- CTA — single primary per StoryBrand -->
          <div class="mt-10">
            <a
              href="/contact/demo"
              class="group inline-flex items-center gap-2 font-mono text-xs uppercase tracking-[0.08em] px-8 py-4 rounded-full transition-all duration-300 ease-out hover:scale-105"
              style="background-color: var(--color-forest); color: white;"
            >
              Schedule an Assessment
              <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
            </a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       2. INDUSTRIES — Palantir-style vertical list
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-20 lg:py-28 px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <!-- Editorial intro — large type, frames the platform before listing industries -->
      <h2 class="font-sans font-light text-3xl sm:text-4xl lg:text-6xl xl:text-7xl leading-[1.15] tracking-tight fade-up" style="color: var(--color-neutral-800);">
        Operational intelligence for the industries that keep communities <span style="color: var(--color-forest);">connected, powered, and safe</span>.
      </h2>

      <!-- Energy -->
      <a href="/industries/energy" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up mt-16" style="border-top: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Overlay modernization for grid, pipeline, and production operations. Modern analytics on legacy SCADA — months, not years.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Energy</span>
        </div>
      </a>

      <!-- National Security -->
      <a href="/industries/national-security" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up" style="border-top: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Unified command across physical, cyber, and intelligence domains. Sovereign deployment. Air-gapped capable.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">National Security</span>
        </div>
      </a>

      <!-- Networks -->
      <a href="/industries/networks" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up" style="border-top: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Unified operations from ground to orbit. Terrestrial, satellite, and hybrid connectivity in one intelligence network.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Networks</span>
        </div>
      </a>

      <!-- Critical Infrastructure -->
      <a href="/industries/critical-infrastructure" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up" style="border-top: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 0h.008v.008h-.008V7.5z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Intelligence for the systems cities depend on — water, transportation, municipal operations, and the built environment.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Critical Infrastructure</span>
        </div>
      </a>

      <!-- Finance -->
      <a href="/industries/finance" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up" style="border-top: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Intelligence products that unify the 15–30 systems your bank already operates. Production-ready in weeks.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Finance</span>
        </div>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       3. THE NETWORK — Utility-framing: connect to intelligence already built
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-20 lg:py-28 px-6" style="background: var(--color-neutral-50, #fafafa); border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">

      <!-- Editorial lead -->
      <p class="font-mono text-xs uppercase tracking-[0.1em] mb-8 fade-up" style="color: var(--color-forest);">The Network</p>
      <h2 class="font-sans font-light text-3xl sm:text-4xl lg:text-5xl xl:text-6xl leading-[1.15] tracking-tight fade-up" style="color: var(--color-neutral-800);">
        One network. <span style="color: var(--color-neutral-400);">Complete intelligence.</span>
      </h2>

      <p class="mt-8 font-sans text-lg leading-relaxed max-w-3xl fade-up" style="color: var(--color-neutral-600);">
        Most platforms connect your systems. Some analyze your data. This network does both — simultaneously — because operational intelligence without business context is just monitoring, and business intelligence without operational data is just reporting.
      </p>

      <!-- Unified SVG Connection Diagram — single network, two properties -->
      <div class="mt-16 lg:mt-20 fade-up">
        <svg viewBox="0 0 960 240" fill="none" xmlns="http://www.w3.org/2000/svg" class="w-full max-w-4xl mx-auto" role="img" aria-label="Your systems connect to the Quatro intelligence network, which provides both operational intelligence and enterprise meaning, producing industry outcomes">

          <!-- Left node: Your Systems -->
          <rect x="16" y="40" width="180" height="110" rx="12" stroke="#CBD5E1" stroke-width="1.5" fill="white"/>
          <text x="106" y="72" text-anchor="middle" font-family="ui-monospace, monospace" font-size="9" letter-spacing="0.1em" fill="#94A3B8">YOUR SYSTEMS</text>
          <text x="106" y="96" text-anchor="middle" font-family="ui-sans-serif, system-ui, sans-serif" font-size="11.5" fill="#64748B">SCADA · IoT · PLCs</text>
          <text x="106" y="114" text-anchor="middle" font-family="ui-sans-serif, system-ui, sans-serif" font-size="11.5" fill="#64748B">ERP · CRM · Billing</text>
          <text x="106" y="132" text-anchor="middle" font-family="ui-sans-serif, system-ui, sans-serif" font-size="11.5" fill="#64748B">Cloud · Edge · On-prem</text>

          <!-- Connection line left -->
          <line x1="196" y1="95" x2="278" y2="95" stroke="#0f4c3a" stroke-width="1.5" stroke-dasharray="6 4" opacity="0.4"/>
          <polygon points="274,90 284,95 274,100" fill="#0f4c3a" opacity="0.4"/>

          <!-- Center node: The Intelligence Network (unified) -->
          <rect x="284" y="10" width="392" height="170" rx="16" stroke="#0f4c3a" stroke-width="2" fill="#0f4c3a" fill-opacity="0.04"/>
          <text x="480" y="38" text-anchor="middle" font-family="ui-monospace, monospace" font-size="9" letter-spacing="0.1em" fill="#0f4c3a">THE INTELLIGENCE NETWORK</text>
          <line x1="310" y1="50" x2="650" y2="50" stroke="#0f4c3a" stroke-width="0.5" opacity="0.12"/>

          <!-- Left property: Operational Intelligence -->
          <text x="390" y="72" text-anchor="middle" font-family="ui-monospace, monospace" font-size="7.5" letter-spacing="0.08em" fill="#0f4c3a" opacity="0.5">OPERATIONAL INTELLIGENCE</text>
          <circle cx="310" cy="90" r="2.5" fill="#0f4c3a" opacity="0.3"/>
          <text x="320" y="94" font-family="ui-sans-serif, system-ui, sans-serif" font-size="11" fill="#0f4c3a" opacity="0.65">9,000+ native integrations</text>
          <circle cx="310" cy="110" r="2.5" fill="#0f4c3a" opacity="0.3"/>
          <text x="320" y="114" font-family="ui-sans-serif, system-ui, sans-serif" font-size="11" fill="#0f4c3a" opacity="0.65">Pre-built operational workflows</text>
          <circle cx="310" cy="130" r="2.5" fill="#0f4c3a" opacity="0.3"/>
          <text x="320" y="134" font-family="ui-sans-serif, system-ui, sans-serif" font-size="11" fill="#0f4c3a" opacity="0.65">Intelligent alarming</text>

          <!-- Divider line -->
          <line x1="480" y1="64" x2="480" y2="168" stroke="#0f4c3a" stroke-width="0.5" opacity="0.1"/>

          <!-- Right property: Enterprise Meaning -->
          <text x="576" y="72" text-anchor="middle" font-family="ui-monospace, monospace" font-size="7.5" letter-spacing="0.08em" fill="#0f4c3a" opacity="0.5">ENTERPRISE MEANING</text>
          <circle cx="500" cy="90" r="2.5" fill="#0f4c3a" opacity="0.3"/>
          <text x="510" y="94" font-family="ui-sans-serif, system-ui, sans-serif" font-size="11" fill="#0f4c3a" opacity="0.65">Governed definitions</text>
          <circle cx="500" cy="110" r="2.5" fill="#0f4c3a" opacity="0.3"/>
          <text x="510" y="114" font-family="ui-sans-serif, system-ui, sans-serif" font-size="11" fill="#0f4c3a" opacity="0.65">Cross-domain reasoning</text>
          <circle cx="500" cy="130" r="2.5" fill="#0f4c3a" opacity="0.3"/>
          <text x="510" y="134" font-family="ui-sans-serif, system-ui, sans-serif" font-size="11" fill="#0f4c3a" opacity="0.65">Financial + operational context</text>

          <!-- Compound value line -->
          <text x="480" y="162" text-anchor="middle" font-family="ui-monospace, monospace" font-size="7" letter-spacing="0.06em" fill="#0f4c3a" opacity="0.3">EACH SERVICE CONNECTS TO EVERY OTHER THROUGH A SHARED FOUNDATION</text>

          <!-- Status indicator -->
          <circle cx="648" cy="34" r="4" fill="#0f4c3a" opacity="0.5"/>

          <!-- Connection line right -->
          <line x1="676" y1="95" x2="758" y2="95" stroke="#0f4c3a" stroke-width="1.5" stroke-dasharray="6 4" opacity="0.4"/>
          <polygon points="754,90 764,95 754,100" fill="#0f4c3a" opacity="0.4"/>

          <!-- Right node: Industry Outcomes -->
          <rect x="764" y="40" width="180" height="110" rx="12" stroke="#0f4c3a" stroke-width="1.5" fill="#0f4c3a" fill-opacity="0.06"/>
          <text x="854" y="72" text-anchor="middle" font-family="ui-monospace, monospace" font-size="9" letter-spacing="0.1em" fill="#0f4c3a">OUTCOMES</text>
          <text x="854" y="96" text-anchor="middle" font-family="ui-sans-serif, system-ui, sans-serif" font-size="11.5" fill="#0f4c3a" opacity="0.8">Fewer false alarms</text>
          <text x="854" y="114" text-anchor="middle" font-family="ui-sans-serif, system-ui, sans-serif" font-size="11.5" fill="#0f4c3a" opacity="0.8">Faster incident response</text>
          <text x="854" y="132" text-anchor="middle" font-family="ui-sans-serif, system-ui, sans-serif" font-size="11.5" fill="#0f4c3a" opacity="0.8">One intelligence picture</text>

        </svg>
      </div>

      <!-- Fused narrative — single description, not two columns -->
      <div class="mt-14 lg:mt-16 fade-up" style="border-top: 1px solid var(--color-structure); padding-top: 2rem;">
        <p class="font-sans text-base leading-relaxed max-w-3xl" style="color: var(--color-neutral-600);">
          The network connects to your existing infrastructure through 9,000+ native integrations. It ingests operational signals in real time. And it interprets every signal through a governed model built for your industry — so when an anomaly fires, your team doesn't just see the alert. They see which asset is affected, which customers are impacted, which SLAs are at risk, and what to do about it. Built for the systems and vendors your operation already depends on.
        </p>
        <p class="mt-4 font-sans text-sm" style="color: var(--color-neutral-400);">
          Each intelligence service connects to every other through a shared foundation — so the more you connect, the more you see.
        </p>
      </div>

      <!-- Proof metrics strip -->
      <div class="mt-10 grid grid-cols-2 sm:grid-cols-4 gap-6 fade-up" style="border-top: 1px solid var(--color-structure); padding-top: 1.5rem;">
        <div>
          <span class="font-display text-2xl lg:text-3xl font-light" style="color: var(--color-neutral-800);">9,000+</span>
          <p class="font-sans text-xs mt-1" style="color: var(--color-neutral-500);">Native integrations</p>
        </div>
        <div>
          <span class="font-display text-2xl lg:text-3xl font-light" style="color: var(--color-neutral-800);">1,000+</span>
          <p class="font-sans text-xs mt-1" style="color: var(--color-neutral-500);">Vendors supported</p>
        </div>
        <div>
          <span class="font-display text-2xl lg:text-3xl font-light" style="color: var(--color-neutral-800);">125+</span>
          <p class="font-sans text-xs mt-1" style="color: var(--color-neutral-500);">Countries deployed</p>
        </div>
        <div>
          <span class="font-display text-2xl lg:text-3xl font-light" style="color: var(--color-neutral-800);">Weeks</span>
          <p class="font-sans text-xs mt-1" style="color: var(--color-neutral-500);">To production</p>
        </div>
      </div>

      <!-- Anonymized proof stories -->
      <div class="mt-10 grid sm:grid-cols-3 gap-6 fade-up" style="border-top: 1px solid var(--color-structure); padding-top: 1.5rem;">
        <div>
          <p class="font-mono text-[10px] uppercase tracking-[0.12em] mb-2" style="color: var(--color-forest);">National Communications Provider</p>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">98% of infrastructure unified on one network. 5,000+ devices. Siloed tools and manual workflows replaced with real-time unified operations.</p>
        </div>
        <div>
          <p class="font-mono text-[10px] uppercase tracking-[0.12em] mb-2" style="color: var(--color-forest);">National Infrastructure Operator</p>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">14,000 elements. 7,000 services. Equipment provisioning reduced from months to weeks. Critical event procedures from months of development to hours.</p>
        </div>
        <div>
          <p class="font-mono text-[10px] uppercase tracking-[0.12em] mb-2" style="color: var(--color-forest);">National Broadband Operator</p>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">4 million devices monitored. Half a billion KPIs tracked continuously. 20,000 fewer customer site visits per year through proactive intelligence.</p>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       4. THE PLAN — StoryBrand 3-step buyer plan
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-16 lg:py-24 px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <p class="font-mono text-xs uppercase tracking-[0.1em] mb-8 fade-up" style="color: var(--color-forest);">How It Works</p>

      <div class="grid sm:grid-cols-3 gap-8 lg:gap-12 fade-up">
        <!-- Step 1 -->
        <div>
          <span class="font-display text-4xl lg:text-5xl font-light" style="color: var(--color-forest); opacity: 0.3;">01</span>
          <h3 class="mt-3 font-sans text-lg font-medium" style="color: var(--color-neutral-800);">Connect</h3>
          <p class="mt-2 font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">
            Pick the system that costs you the most to operate. We connect it to the intelligence network — your infrastructure, your data, your control.
          </p>
        </div>
        <!-- Step 2 -->
        <div>
          <span class="font-display text-4xl lg:text-5xl font-light" style="color: var(--color-forest); opacity: 0.3;">02</span>
          <h3 class="mt-3 font-sans text-lg font-medium" style="color: var(--color-neutral-800);">Prove</h3>
          <p class="mt-2 font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">
            Four weeks. Measurable results on your stack before you commit. The proof of value is credited toward your contract.
          </p>
        </div>
        <!-- Step 3 -->
        <div>
          <span class="font-display text-4xl lg:text-5xl font-light" style="color: var(--color-forest); opacity: 0.3;">03</span>
