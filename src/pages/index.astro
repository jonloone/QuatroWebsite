  <!-- CTA Bayer dither engine (same as HeroCanvas, initializes data-dither-canvas on CTA) -->
  <script is:inline>
    (function () {
      var bayer = [
        [0/16, 8/16, 2/16, 10/16],
        [12/16, 4/16, 14/16, 6/16],
        [3/16, 11/16, 1/16, 9/16],
        [15/16, 7/16, 13/16, 5/16]
      ];

      var canvas = document.getElementById('cta-dither-canvas');
      if (!canvas) return;
      var ctx = canvas.getContext('2d');
      if (!ctx) return;

      var imageSrc = canvas.getAttribute('data-image-src') || '/images/bg555.png';
      var pixelSize = parseInt(canvas.getAttribute('data-pixel-size') || '3', 10);
      var baseSpeed = parseFloat(canvas.getAttribute('data-base-speed') || '0.06');
      var hoverSpeed = parseFloat(canvas.getAttribute('data-hover-speed') || '0.35');
      var greenBlend = parseFloat(canvas.getAttribute('data-green-blend') || '0.5');

      var card = canvas.closest('[data-cta-card]');
      var isHovered = false;
      var animId, startTime = performance.now();

      var bgImg = new Image();
      bgImg.crossOrigin = 'anonymous';
      bgImg.src = imageSrc;
      var offscreen = document.createElement('canvas');
      var offCtx = offscreen.getContext('2d');
      var imgLoaded = false;
      bgImg.onload = function () { imgLoaded = true; };

      function resize() {
        var rect = canvas.getBoundingClientRect();
        canvas.width = rect.width;
        canvas.height = rect.height;
      }

      function render(time) {
        var w = canvas.width, h = canvas.height;
        if (w === 0 || h === 0) { animId = requestAnimationFrame(render); return; }

        var elapsed = (time - startTime) / 1000;
        var speed = isHovered ? hoverSpeed : baseSpeed;
        var t = elapsed * speed;

        var srcPixels = null;
        if (imgLoaded) {
          offscreen.width = w;
          offscreen.height = h;
          // Cover-fit
          var imgAspect = bgImg.naturalWidth / bgImg.naturalHeight;
          var canvasAspect = w / h;
          var sx = 0, sy = 0, sw = bgImg.naturalWidth, sh = bgImg.naturalHeight;
          if (imgAspect > canvasAspect) {
            sw = bgImg.naturalHeight * canvasAspect;
            sx = (bgImg.naturalWidth - sw) / 2;
          } else {
            sh = bgImg.naturalWidth / canvasAspect;
            sy = (bgImg.naturalHeight - sh) / 2;
          }
          offCtx.drawImage(bgImg, sx, sy, sw, sh, 0, 0, w, h);
          srcPixels = offCtx.getImageData(0, 0, w, h).data;
        }

        var imageData = ctx.createImageData(w, h);
        var data = imageData.data;
        var cols = Math.ceil(w / pixelSize);
        var rows = Math.ceil(h / pixelSize);

        for (var row = 0; row < rows; row++) {
          for (var col = 0; col < cols; col++) {
            var centerX = col * pixelSize + (pixelSize >> 1);
            var centerY = row * pixelSize + (pixelSize >> 1);

            var sR = 0, sG = 0, sB = 0, imgBrightness = 0.3;
            if (srcPixels && centerX < w && centerY < h) {
              var sIdx = (centerY * w + centerX) * 4;
              sR = srcPixels[sIdx]; sG = srcPixels[sIdx+1]; sB = srcPixels[sIdx+2];
              imgBrightness = (sR * 0.299 + sG * 0.587 + sB * 0.114) / 255;
            }

            var cx = col / cols, cy = row / rows;
            var warpX = 0.12 * Math.sin(cy * 5.0 + t * 1.3) + 0.08 * Math.cos(cx * 4.0 + t * 0.9);
            var warpY = 0.12 * Math.cos(cx * 5.0 + t * 1.1) + 0.08 * Math.sin(cy * 4.0 + t * 1.5);
            var wx = cx + warpX, wy = cy + warpY;
            var d1 = Math.sqrt((wx - 0.5) * (wx - 0.5) + (wy - 0.5) * (wy - 0.5));
            var warpIntensity = 0.3 + 0.25 * Math.sin(d1 * 8.0 - t * 2.0) + 0.15 * Math.cos((wx + wy) * 6.0 + t);

            var intensity = imgBrightness * 0.92 + warpIntensity * 0.2;
            intensity = Math.max(0, Math.min(1, intensity));

            var threshold = bayer[row % 4][col % 4];
            var on = intensity > threshold;

            var r, g, b, a;
            if (on) {
              var blend = greenBlend + (1 - greenBlend) * 0.3 * warpIntensity;
              r = Math.round(sR * (1 - blend) + 15 * blend);
              g = Math.round(sG * (1 - blend) + 76 * blend);
              b = Math.round(sB * (1 - blend) + 58 * blend);
              a = Math.round(intensity * 180 + 75);
            } else {
              r = 0; g = 0; b = 0; a = 0;
            }

            for (var py = 0; py < pixelSize; py++) {
              for (var px = 0; px < pixelSize; px++) {
                var x = col * pixelSize + px;
                var y = row * pixelSize + py;
                if (x >= w || y >= h) continue;
                var idx = (y * w + x) * 4;
                data[idx] = r; data[idx+1] = g; data[idx+2] = b; data[idx+3] = a;
              }
            }
          }
        }

        ctx.putImageData(imageData, 0, 0);
        animId = requestAnimationFrame(render);
      }

      if (card) {
        card.addEventListener('mouseenter', function () { isHovered = true; });
        card.addEventListener('mouseleave', function () { isHovered = false; });
      }

      var observer = new IntersectionObserver(function (entries) {
        entries.forEach(function (entry) {
          if (entry.isIntersecting) { resize(); startTime = performance.now(); animId = requestAnimationFrame(render); }
          else { cancelAnimationFrame(animId); }
        });
      }, { threshold: 0.1 });

      window.addEventListener('resize', resize);
      observer.observe(canvas);
    })();
  </script>

