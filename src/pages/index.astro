---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SiteHeader from '@/components/layout/SiteHeader.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
import QuatroLogo from '@/components/QuatroLogo.astro'
import { getCollection } from 'astro:content'
const insights = (await getCollection('insights'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 5)
---

<BaseLayout
  title="Quatro — Operational Intelligence for Critical Infrastructure"
  description="We integrate the hardware, software, and domain expertise that energy, defense, network, and infrastructure operators need — delivered as a utility, built so you own the intelligence from day one."
  lang="en"
>

  <SiteHeader lang="en" />

  <!-- ═══════════════════════════════════════════════════════════════
       1. HERO — Full-width editorial canvas, centered statement
       ═══════════════════════════════════════════════════════════════ -->
  <section class="relative min-h-screen overflow-hidden" id="hero-carousel" data-dither-section data-nav-dark>

    <!-- Bayer 4×4 image-dither canvas — full bleed background -->
    <canvas id="hero-dither-canvas" class="absolute inset-0 w-full h-full z-[1]" style="background: #0f2e24;"></canvas>

    <!-- Full overlay — base darkening layer across entire canvas -->
    <div class="absolute inset-0 pointer-events-none z-[2]" style="background: rgba(10,30,22,0.45);"></div>
    <!-- Text backdrop — strong center darken for WCAG contrast on headline/subtitle -->
    <div class="absolute inset-0 pointer-events-none z-[3]" style="background: radial-gradient(ellipse 80% 55% at 50% 42%, rgba(10,30,22,0.55) 0%, transparent 70%);"></div>
    <!-- Bottom gradient for caption legibility -->
    <div class="absolute inset-0 pointer-events-none z-[4]" style="background: linear-gradient(to top, rgba(10,30,22,0.8) 0%, rgba(10,30,22,0.3) 20%, transparent 40%);"></div>

    <!-- Hero text — centered editorial composition -->
    <div class="relative z-10 flex flex-col items-center justify-center min-h-screen pt-20 px-8 lg:px-16 text-center">
      <div class="max-w-4xl">
        <!-- Eyebrow — frames the structural problem, not a category label -->
        <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-white/60 mb-8">
          Your systems generate the data. You should own the intelligence.
        </p>
        <!-- Headline — Reckless Light, editorial scale -->
        <h1 class="font-sans font-light text-4xl sm:text-5xl md:text-6xl lg:text-7xl xl:text-8xl leading-[1.05] tracking-tight text-white">
          Making critical infrastructure intelligent.
        </h1>
        <!-- Subtitle — connects physical + data systems, outcome-first -->
        <p class="mt-8 font-display text-lg lg:text-xl leading-relaxed text-white/90 max-w-2xl mx-auto">
          We connect your physical systems and your data systems into one operational model — so your team sees, decides, and acts from a single source of intelligence.
        </p>
        <!-- CTA -->
        <div class="mt-12">
          <a href="/contact/demo" class="group inline-flex items-center gap-3 font-mono text-xs uppercase tracking-[0.08em] px-8 py-4 rounded-full transition-all duration-300 ease-out hover:scale-[1.03] hover:shadow-lg" style="background-color: var(--color-forest); color: white;">
            Talk to Our Team
            <svg class="w-4 h-4 transition-transform duration-300 group-hover:translate-x-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M17 8l4 4m0 0l-4 4m4-4H3" /></svg>
          </a>
        </div>
      </div>
    </div>

    <!-- Bottom bar: rotating caption left + dots right -->
    <div class="absolute bottom-0 left-0 right-0 z-10 px-8 lg:px-16 xl:px-20 pb-8 lg:pb-12">
      <div class="flex items-end justify-between gap-8">
        <!-- Left: Rotating engagement caption -->
        <div class="relative flex-1 max-w-xl" style="min-height: 72px;">
          <div class="hero-slide-caption absolute bottom-0 left-0 right-0 flex flex-col items-start transition-all duration-700 ease-in-out" data-slide="0">
            <p class="font-display font-light text-lg md:text-xl lg:text-2xl text-white/50 tracking-tight leading-[1.2]">18 agencies seeing one risk picture for the first time</p>
            <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-white/20 mt-2">Community Intelligence · National Scale</p>
          </div>
          <div class="hero-slide-caption absolute bottom-0 left-0 right-0 flex flex-col items-start transition-all duration-700 ease-in-out opacity-0 translate-y-4" data-slide="1">
            <p class="font-display font-light text-lg md:text-xl lg:text-2xl text-white/50 tracking-tight leading-[1.2]">Coastal surveillance that connects satellite, sensor, and ground truth</p>
            <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-white/20 mt-2">Maritime &amp; Environmental Operations</p>
          </div>
          <div class="hero-slide-caption absolute bottom-0 left-0 right-0 flex flex-col items-start transition-all duration-700 ease-in-out opacity-0 translate-y-4" data-slide="2">
            <p class="font-display font-light text-lg md:text-xl lg:text-2xl text-white/50 tracking-tight leading-[1.2]">Detection to governed response in under thirty seconds</p>
            <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-white/20 mt-2">Sovereign · Air-Gapped · Auditable</p>
          </div>
          <div class="hero-slide-caption absolute bottom-0 left-0 right-0 flex flex-col items-start transition-all duration-700 ease-in-out opacity-0 translate-y-4" data-slide="3">
            <p class="font-display font-light text-lg md:text-xl lg:text-2xl text-white/50 tracking-tight leading-[1.2]">Legacy grid and modern DER unified in one operational model</p>
            <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-white/20 mt-2">Energy Infrastructure Intelligence</p>
          </div>
          <div class="hero-slide-caption absolute bottom-0 left-0 right-0 flex flex-col items-start transition-all duration-700 ease-in-out opacity-0 translate-y-4" data-slide="4">
            <p class="font-display font-light text-lg md:text-xl lg:text-2xl text-white/50 tracking-tight leading-[1.2]">A thousand kilometers of pipeline, finally connected</p>
            <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-white/20 mt-2">Edge-to-Cloud · Real-Time Visibility</p>
          </div>
          <div class="hero-slide-caption absolute bottom-0 left-0 right-0 flex flex-col items-start transition-all duration-700 ease-in-out opacity-0 translate-y-4" data-slide="5">
            <p class="font-display font-light text-lg md:text-xl lg:text-2xl text-white/50 tracking-tight leading-[1.2]">Connecting the 15-30 systems your bank already runs</p>
            <p class="font-mono text-[10px] uppercase tracking-[0.1em] text-white/20 mt-2">Financial Services Intelligence</p>
          </div>
        </div>

        <!-- Right: Dots + counter -->
        <div class="flex items-center gap-4 flex-shrink-0">
          <div class="flex items-center gap-2">
            <button class="hero-dot w-2 h-2 rounded-full transition-all duration-500 cursor-pointer" data-slide="0" style="background: rgba(255,255,255,0.9);" aria-label="Slide 1"></button>
            <button class="hero-dot w-2 h-2 rounded-full transition-all duration-500 cursor-pointer" data-slide="1" style="background: rgba(255,255,255,0.3);" aria-label="Slide 2"></button>
            <button class="hero-dot w-2 h-2 rounded-full transition-all duration-500 cursor-pointer" data-slide="2" style="background: rgba(255,255,255,0.3);" aria-label="Slide 3"></button>
            <button class="hero-dot w-2 h-2 rounded-full transition-all duration-500 cursor-pointer" data-slide="3" style="background: rgba(255,255,255,0.3);" aria-label="Slide 4"></button>
            <button class="hero-dot w-2 h-2 rounded-full transition-all duration-500 cursor-pointer" data-slide="4" style="background: rgba(255,255,255,0.3);" aria-label="Slide 5"></button>
            <button class="hero-dot w-2 h-2 rounded-full transition-all duration-500 cursor-pointer" data-slide="5" style="background: rgba(255,255,255,0.3);" aria-label="Slide 6"></button>
          </div>
          <p class="font-mono text-sm text-white/40" id="hero-counter">01 / 06</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Hero Carousel + Bayer 4×4 Image Dither (Quatro signature effect) -->
  <script>
    (function () {
      const TOTAL = 6;
      const INTERVAL = 6000;
      let current = 0;
      let timer: ReturnType<typeof setInterval>;

      const captions = document.querySelectorAll('.hero-slide-caption');
      const dots = document.querySelectorAll('.hero-dot');
      const counter = document.getElementById('hero-counter');

      // ─── Image sources for the carousel ───
      const imageSources = [
        '/images/mission-youth-risk-v3b.png',
        '/images/mission-galapagos-v2.png',
        '/images/hero-us-defense-intel.png',
        '/images/hero-mena-energy-ops.png',
        '/images/proof-energy.png',
        '/images/proof-finance.png'
      ];

      // ─── Bayer 4×4 dither engine (from HeroCanvas.astro) ───
      const bayer4x4 = [
        [ 0/16,  8/16,  2/16, 10/16],
        [12/16,  4/16, 14/16,  6/16],
        [ 3/16, 11/16,  1/16,  9/16],
        [15/16,  7/16, 13/16,  5/16]
      ];

      const canvas = document.getElementById('hero-dither-canvas') as HTMLCanvasElement | null;
      if (!canvas) return;
      const ctx = canvas.getContext('2d');
      if (!ctx) return;

      const pixelSize = 2;
      const greenBlend = 0.25;
      let baseSpeed = 0.08;
      let startTime = performance.now();
      let animId: number;

      // Preload all images
      const images: HTMLImageElement[] = [];
      const offscreen = document.createElement('canvas');
      const offCtx = offscreen.getContext('2d')!;
      let currentImgIndex = 0;
      let nextImgIndex = -1;
      let crossfade = 0; // 0 = showing currentImgIndex fully, 1 = fully transitioned to nextImgIndex
      let crossfadeActive = false;
      const CROSSFADE_DURATION = 1200; // ms
      let crossfadeStart = 0;

      // Offscreen canvases for crossfade blending
      const offA = document.createElement('canvas');
      const offACtx = offA.getContext('2d')!;
      const offB = document.createElement('canvas');
      const offBCtx = offB.getContext('2d')!;

      imageSources.forEach((src) => {
        const img = new Image();
        img.crossOrigin = 'anonymous';
        img.src = src;
        images.push(img);
      });

      function resize() {
        const rect = canvas!.getBoundingClientRect();
        canvas!.width = rect.width;
        canvas!.height = rect.height;
        offscreen.width = rect.width;
        offscreen.height = rect.height;
        offA.width = rect.width;
        offA.height = rect.height;
        offB.width = rect.width;
        offB.height = rect.height;
      }

      function getImagePixels(imgIndex: number, w: number, h: number): Uint8ClampedArray | null {
        const img = images[imgIndex];
        if (!img || !img.complete || img.naturalWidth === 0) return null;
        offscreen.width = w;
        offscreen.height = h;
        // Cover-fit the image (same as object-cover)
        const imgAspect = img.naturalWidth / img.naturalHeight;
        const canvasAspect = w / h;
        let sx = 0, sy = 0, sw = img.naturalWidth, sh = img.naturalHeight;
        if (imgAspect > canvasAspect) {
          sw = img.naturalHeight * canvasAspect;
          sx = (img.naturalWidth - sw) / 2;
        } else {
          sh = img.naturalWidth / canvasAspect;
          sy = (img.naturalHeight - sh) / 2;
        }
        offCtx.drawImage(img, sx, sy, sw, sh, 0, 0, w, h);
        return offCtx.getImageData(0, 0, w, h).data;
      }

      function render(time: number) {
        if (!ctx) return;
        const w = canvas!.width;
        const h = canvas!.height;
        if (w === 0 || h === 0) { animId = requestAnimationFrame(render); return; }

        const elapsed = (time - startTime) / 1000;
        const t = elapsed * baseSpeed;

        // Handle crossfade timing
        if (crossfadeActive) {
          crossfade = Math.min(1, (time - crossfadeStart) / CROSSFADE_DURATION);
          if (crossfade >= 1) {
            currentImgIndex = nextImgIndex;
            crossfadeActive = false;
            crossfade = 0;
            nextImgIndex = -1;
          }
        }

        // Get pixel data for current (and next if crossfading)
        const srcA = getImagePixels(currentImgIndex, w, h);
        const srcB = crossfadeActive && nextImgIndex >= 0 ? getImagePixels(nextImgIndex, w, h) : null;

        const imageData = ctx.createImageData(w, h);
        const data = imageData.data;
        const cols = Math.ceil(w / pixelSize);
        const rows = Math.ceil(h / pixelSize);

        for (let row = 0; row < rows; row++) {
          for (let col = 0; col < cols; col++) {
            const centerX = col * pixelSize + (pixelSize >> 1);
            const centerY = row * pixelSize + (pixelSize >> 1);

            // Sample source pixel (blend A and B if crossfading)
            let sR = 0, sG = 0, sB = 0;
            let imgBrightness = 0.3;

            if (centerX < w && centerY < h) {
              const sIdx = (centerY * w + centerX) * 4;
              if (srcA) {
                const aR = srcA[sIdx], aG = srcA[sIdx+1], aB = srcA[sIdx+2];
                if (srcB && crossfadeActive) {
                  const bR = srcB[sIdx], bG = srcB[sIdx+1], bB = srcB[sIdx+2];
                  sR = aR + (bR - aR) * crossfade;
                  sG = aG + (bG - aG) * crossfade;
                  sB = aB + (bB - aB) * crossfade;
                } else {
                  sR = aR; sG = aG; sB = aB;
                }
                imgBrightness = (sR * 0.299 + sG * 0.587 + sB * 0.114) / 255;
              }
            }

            const cx = col / cols;
            const cy = row / rows;

            // Warp animation (from HeroCanvas engine)
            const warpX = 0.12 * Math.sin(cy * 5.0 + t * 1.3) + 0.08 * Math.cos(cx * 4.0 + t * 0.9);
            const warpY = 0.12 * Math.cos(cx * 5.0 + t * 1.1) + 0.08 * Math.sin(cy * 4.0 + t * 1.5);
            const wx = cx + warpX;
            const wy = cy + warpY;
            const d1 = Math.sqrt((wx - 0.5) ** 2 + (wy - 0.5) ** 2);
            const warpIntensity = 0.3 + 0.25 * Math.sin(d1 * 8.0 - t * 2.0) + 0.15 * Math.cos((wx + wy) * 6.0 + t);

            let intensity = imgBrightness * 0.85 + warpIntensity * 0.35;
            intensity = Math.max(0, Math.min(1, intensity));

            // Bayer threshold
            const threshold = bayer4x4[row % 4][col % 4];
            const on = intensity > threshold;

            let r: number, g: number, b: number, a: number;
            if (on) {
              // Bright, vivid dither dots on deep green canvas — image pops through
              const blend = greenBlend + (1 - greenBlend) * 0.2 * warpIntensity;
              r = Math.round(sR * (1 - blend) + 80  * blend);
              g = Math.round(sG * (1 - blend) + 185 * blend);
              b = Math.round(sB * (1 - blend) + 140 * blend);
              a = Math.round(intensity * 160 + 95);
            } else {
              // Transparent — deep forest green canvas (#0f2e24) shows through
              r = 0; g = 0; b = 0; a = 0;
            }

            // Fill pixel block
            for (let py = 0; py < pixelSize; py++) {
              for (let px = 0; px < pixelSize; px++) {
                const x = col * pixelSize + px;
                const y = row * pixelSize + py;
                if (x >= w || y >= h) continue;
                const idx = (y * w + x) * 4;
                data[idx]     = r;
                data[idx + 1] = g;
                data[idx + 2] = b;
                data[idx + 3] = a;
              }
            }
          }
        }

        ctx.putImageData(imageData, 0, 0);
        animId = requestAnimationFrame(render);
      }

      // ─── Carousel Controller (integrated with dither) ───
      function goTo(index: number) {
        // Update captions
        captions.forEach((el) => {
          (el as HTMLElement).style.opacity = '0';
          (el as HTMLElement).style.transform = 'translateY(1rem)';
        });
        dots.forEach((el) => {
          (el as HTMLElement).style.background = 'rgba(255,255,255,0.3)';
        });

        const activeCaption = document.querySelector(`.hero-slide-caption[data-slide="${index}"]`) as HTMLElement;
        const activeDot = document.querySelector(`.hero-dot[data-slide="${index}"]`) as HTMLElement;

        if (activeCaption) { activeCaption.style.opacity = '1'; activeCaption.style.transform = 'translateY(0)'; }
        if (activeDot) { activeDot.style.background = 'rgba(255,255,255,0.9)'; }
        if (counter) { counter.textContent = `${String(index + 1).padStart(2, '0')} / ${String(TOTAL).padStart(2, '0')}`; }

        // Trigger dither crossfade
        if (index !== currentImgIndex) {
          nextImgIndex = index;
          crossfadeActive = true;
          crossfadeStart = performance.now();
        }

        current = index;
      }

      function next() {
        goTo((current + 1) % TOTAL);
      }

      function startAutoplay() {
        timer = setInterval(next, INTERVAL);
      }

      function resetAutoplay() {
        clearInterval(timer);
        startAutoplay();
      }

      dots.forEach((dot) => {
        dot.addEventListener('click', () => {
          const idx = parseInt((dot as HTMLElement).dataset.slide || '0', 10);
          goTo(idx);
          resetAutoplay();
        });
      });

      // Carousel continues autoplaying — no hover pause

      // ─── Visibility gating ───
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            resize();
            startTime = performance.now();
            animId = requestAnimationFrame(render);
          } else {
            cancelAnimationFrame(animId);
          }
        });
      }, { threshold: 0.1 });

      window.addEventListener('resize', resize);
      observer.observe(canvas);

      goTo(0);
      startAutoplay();
    })();
  </script>

  <!-- ═══════════════════════════════════════════════════════════════
       2. INDUSTRIES — Palantir-style vertical list (giant typography, hover-to-green)
       ═══════════════════════════════════════════════════════════════ -->
  <section id="industries" style="border-top: 1px solid var(--color-structure);">
    <div class="py-20 lg:py-28 px-6 lg:px-12">
      <h2 class="font-sans font-light text-3xl sm:text-4xl lg:text-6xl xl:text-7xl leading-[1.15] tracking-tight fade-up max-w-5xl" style="color: var(--color-neutral-800);">
        Operational intelligence for the industries that keep communities<br /><span style="color: var(--color-forest);">connected, powered, and safe</span>.
      </h2>
    </div>

    <!-- Industry rows — full-bleed hover, padded content -->
    <!-- Energy -->
    <a href="/industries/energy" class="industry-row group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 px-6 lg:px-12 items-center fade-up block transition-all duration-300" style="border-top: 1px solid var(--color-structure);">
      <div class="max-w-lg">
        <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>
        <p class="font-sans text-sm leading-relaxed transition-colors duration-300 group-hover:text-[var(--color-neutral-700)]" style="color: var(--color-neutral-500);">Pipeline, grid, and production unified into one operational model. Predictive maintenance on legacy SCADA — visibility flowing before the first sprint ends.</p>
      </div>
      <div class="text-right">
        <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Energy</span>
      </div>
    </a>

    <!-- National Security -->
    <a href="/industries/defense" class="industry-row group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 px-6 lg:px-12 items-center fade-up block transition-all duration-300" style="border-top: 1px solid var(--color-structure);">
      <div class="max-w-lg">
        <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
        <p class="font-sans text-sm leading-relaxed transition-colors duration-300 group-hover:text-[var(--color-neutral-700)]" style="color: var(--color-neutral-500);">Sovereign intelligence connecting community protection and territorial security — air-gapped, auditable, your team owns it from day one.</p>
      </div>
      <div class="text-right">
        <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">National Security</span>
      </div>
    </a>

    <!-- Networks -->
    <a href="/industries/networks" class="industry-row group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 px-6 lg:px-12 items-center fade-up block transition-all duration-300" style="border-top: 1px solid var(--color-structure);">
      <div class="max-w-lg">
        <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z" /></svg>
        <p class="font-sans text-sm leading-relaxed transition-colors duration-300 group-hover:text-[var(--color-neutral-700)]" style="color: var(--color-neutral-500);">Ground to orbit, subscriber to service — unified in one operational view.</p>
      </div>
      <div class="text-right">
        <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Networks</span>
      </div>
    </a>

    <!-- Cities -->
    <a href="/industries/cities" class="industry-row group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 px-6 lg:px-12 items-center fade-up block transition-all duration-300" style="border-top: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
      <div class="max-w-lg">
        <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 0h.008v.008h-.008V7.5z" /></svg>
        <p class="font-sans text-sm leading-relaxed transition-colors duration-300 group-hover:text-[var(--color-neutral-700)]" style="color: var(--color-neutral-500);">Water, waste, transport — connected into one operational model for the cities communities depend on.</p>
