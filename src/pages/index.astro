---
import BaseLayout from '@/layouts/BaseLayout.astro'
import SiteHeader from '@/components/layout/SiteHeader.astro'
import SiteFooter from '@/components/layout/SiteFooter.astro'
import HeroCanvas from '@/components/marketing/HeroCanvas.astro'
import FloatingPaths from '@/components/ui/FloatingPaths'
import OperationalModelFlow from '@/components/ui/OperationalModelFlow'
import { getCollection } from 'astro:content'
const insights = (await getCollection('insights'))
  .sort((a, b) => b.data.publishDate.getTime() - a.data.publishDate.getTime())
  .slice(0, 5)
---

<BaseLayout
  title="Quatro — The Operational Intelligence Utility"
  description="Tell us the outcome that matters. We connect the systems that hold the answer. Your team gets workflows, agents, automations, and APIs — deployed your way, governed for trust."
  lang="en"
>

  <SiteHeader lang="en" />

  <!-- ═══════════════════════════════════════════════════════════════
       1. HERO — Dithering Card (via HeroCanvas component)
       ═══════════════════════════════════════════════════════════════ -->
  <HeroCanvas
    badge="Quatro"
    title='Systems That Think.<br/><span class="text-white/60">People Who Build.</span>'
    body="Your operations generate data across dozens of systems — but that data doesn't talk to itself. Quatro is the operational intelligence utility. Tell us the outcome that matters, and we connect the systems that hold the answer. Your team gets back workflows, agents, automations, and APIs — built on the data that matters, not all the data."
    ctaLabel="Schedule an Assessment"
    ctaHref="/contact/demo"
    imageSrc="/images/hero-bg.png"
    pixelSize={3}
    baseSpeed={0.1}
    hoverSpeed={0.5}
    greenBlend={0.75}
    canvasOpacity={85}
    minHeight="min-h-[480px] md:min-h-[560px]"
  />

  <!-- ═══════════════════════════════════════════════════════════════
       2. INDUSTRIES — Palantir-style vertical list
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-20 lg:py-28 px-6" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-6xl">
      <!-- Editorial intro — large type, frames the platform before listing industries -->
      <h2 class="font-sans font-light text-3xl sm:text-4xl lg:text-6xl xl:text-7xl leading-[1.15] tracking-tight fade-up" style="color: var(--color-neutral-800);">
        Operational intelligence for the industries that keep communities<br /><span style="color: var(--color-forest);">connected, powered, and safe</span>.
      </h2>

      <!-- Energy -->
      <a href="/industries/energy" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up mt-16" style="border-top: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 13.5l10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Connect pipeline, grid, and production operations. Predictive intelligence on legacy SCADA — intelligence flowing in weeks, not years.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Energy</span>
        </div>
      </a>

      <!-- National Security -->
      <a href="/industries/national-security" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up" style="border-top: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Multi-domain operational intelligence with sovereign deployment. Air-gapped capable. Governed and auditable.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">National Security</span>
        </div>
      </a>

      <!-- Networks -->
      <a href="/industries/networks" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up" style="border-top: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 017.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 011.06 0z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Operational intelligence from ground to orbit. Terrestrial, satellite, and hybrid connectivity — one view, one intelligence layer.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Networks</span>
        </div>
      </a>

      <!-- Critical Infrastructure -->
      <a href="/industries/critical-infrastructure" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up" style="border-top: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M2.25 21h19.5m-18-18v18m10.5-18v18m6-13.5V21M6.75 6.75h.75m-.75 3h.75m-.75 3h.75m3-6h.75m-.75 3h.75m-.75 3h.75M6.75 21v-3.375c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21M3 3h12m-.75 4.5H21m-3.75 0h.008v.008h-.008V7.5z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Intelligence for the systems cities depend on — water, transportation, municipal operations, and the built environment.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Critical Infrastructure</span>
        </div>
      </a>

      <!-- Finance -->
      <a href="/industries/finance" class="group grid lg:grid-cols-[1fr_2fr] gap-8 py-10 lg:py-14 items-center fade-up" style="border-top: 1px solid var(--color-structure); border-bottom: 1px solid var(--color-structure);">
        <div>
          <svg class="w-7 h-7 mb-3 transition-colors duration-300 group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-400);" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 013 19.875v-6.75zM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V8.625zM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 01-1.125-1.125V4.125z" /></svg>
          <p class="font-sans text-sm leading-relaxed" style="color: var(--color-neutral-500);">Connect the 15–30 systems your institution already operates. Operational intelligence production-ready in weeks.</p>
        </div>
        <div class="text-right lg:text-right">
          <span class="font-display text-5xl lg:text-8xl font-light transition-colors duration-300 ease-linear group-hover:text-[var(--color-forest)]" style="color: var(--color-neutral-800);">Finance</span>
        </div>
      </a>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       3. THE UTILITY — Intelligence pillars, how it works, proof stories
       ═══════════════════════════════════════════════════════════════ -->
  <section class="relative py-24 lg:py-32 px-6 overflow-hidden" style="background: #0a0a0a;">
    <!-- Animated background paths -->
    <div class="absolute inset-0 opacity-60">
      <FloatingPaths client:visible />
    </div>
    <div class="relative z-10 mx-auto max-w-6xl">

      <!-- Editorial lead -->
      <p class="font-mono text-xs uppercase tracking-[0.1em] mb-8 fade-up" style="color: var(--color-forest);">The Intelligence Utility</p>
      <h2 class="font-sans font-light text-3xl sm:text-4xl lg:text-5xl xl:text-6xl leading-[1.15] tracking-tight text-white fade-up">
        Tell us the outcome.<br /><span class="text-white/40">We model the relationships that answer it.</span>
      </h2>
      <p class="mt-6 font-sans text-lg lg:text-xl leading-relaxed max-w-3xl text-white/50 fade-up">
        Tell us the question your team needs answered. We connect your systems, model the relationships between them — devices, services, customers, circuits, alarms — and build the operational model that governs how your operations run. The result: agents, workflows, automations, and APIs that all draw from the same intelligence — and compound with every use case.
      </p>

      <!-- How it works — visual flow diagram -->
      <div class="mt-14 lg:mt-18 fade-up rounded-3xl px-6 py-10 lg:px-10 lg:py-14" style="background: #111111; border: 1px solid #1a1a1a;">

        <!-- Operational model flow — concrete labeled examples -->
        <div class="mb-10">
          <OperationalModelFlow client:visible theme="dark" />
        </div>

        <!-- 3-column labels — reframed around ontology and relationships -->
        <div class="grid grid-cols-1 sm:grid-cols-3 gap-8 sm:gap-0">
          <div class="sm:pr-7">
            <p class="font-mono text-[11px] uppercase tracking-[0.12em] mb-2.5" style="color: #2dd4bf;">Start with the question</p>
            <p class="font-sans text-xl font-semibold tracking-tight mb-2" style="color: #e5e5e5;">What does your team need to know?</p>
            <p class="font-sans text-sm leading-relaxed max-w-[320px]" style="color: #a8a29e;">You tell us the outcome. We work backward to the systems that hold the answer — and connect only what matters. Use case first. Always.</p>
          </div>
          <div class="sm:px-7">
            <p class="font-mono text-[11px] uppercase tracking-[0.12em] mb-2.5" style="color: #2dd4bf;">Model the relationships</p>
            <p class="font-sans text-xl font-semibold tracking-tight mb-2" style="color: #e5e5e5;">Process ontologies that think like your operations</p>
            <p class="font-sans text-sm leading-relaxed max-w-[320px]" style="color: #a8a29e;">Devices serve services. Alarms affect circuits. Circuits impact customers. The operational model maps every relationship — and defines the workflows, rules, and intelligence rails that govern what happens next.</p>
          </div>
          <div class="sm:pl-7">
            <p class="font-mono text-[11px] uppercase tracking-[0.12em] mb-2.5" style="color: #2dd4bf;">Operate from the model</p>
            <p class="font-sans text-xl font-semibold tracking-tight mb-2" style="color: #e5e5e5;">Workflows, agents, and automations — shaped by your data</p>
            <p class="font-sans text-sm leading-relaxed max-w-[320px]" style="color: #a8a29e;">The model doesn't produce reports — it generates the applications your team works from. Every use case feeds results back, making the model smarter and unlocking new automations over time.</p>
          </div>
        </div>
      </div>


    </div>
  </section>

  <!-- ═══════════════════════════════════════════════════════════════
       4. PROOF STORIES — Light section with xOps callout + real outcomes
       ═══════════════════════════════════════════════════════════════ -->
  <section class="py-20 lg:py-24 px-6" style="background: var(--color-neutral-50);">
    <div class="mx-auto max-w-6xl">

      <!-- xOps callout card — light card on light background -->
      <a href="/utility/xops" class="group block mb-16 lg:mb-20 fade-up rounded-2xl overflow-hidden transition-all duration-300 hover:scale-[1.003]" style="background: #ffffff; box-shadow: 0 4px 24px rgba(0,0,0,0.06), 0 0 0 1px rgba(0,0,0,0.04);">
        <div class="grid grid-cols-1 lg:grid-cols-[5fr_7fr] items-center">
          <!-- Left: Text -->
          <div class="p-8 lg:p-10 xl:p-12">
            <p class="font-mono text-[10px] uppercase tracking-[0.12em] mb-4" style="color: var(--color-forest); opacity: 0.6;">xOps — Adaptive Operations</p>
            <h3 class="font-sans font-light text-2xl sm:text-3xl tracking-tight leading-snug" style="color: #1c1917;">
              Your operations shape the suite — <span style="color: var(--color-forest);">not the other way around</span>.
            </h3>
            <p class="mt-4 font-sans text-sm leading-relaxed max-w-md" style="color: #78716c;">
              The operational model generates the applications your team works from. Asset management, monitoring, orchestration, service assurance — each one molds to your data. As the model deepens, new workflows and automations unlock automatically.
            </p>
            <div class="mt-5 flex flex-wrap gap-2">
              <span class="font-mono text-[9px] uppercase tracking-[0.08em] px-2.5 py-1 rounded-full" style="color: var(--color-forest); opacity: 0.7; border: 1px solid rgba(0,209,178,0.25);">MediaOps</span>
              <span class="font-mono text-[9px] uppercase tracking-[0.08em] px-2.5 py-1 rounded-full" style="color: var(--color-forest); opacity: 0.7; border: 1px solid rgba(0,209,178,0.25);">GridOps</span>
              <span class="font-mono text-[9px] uppercase tracking-[0.08em] px-2.5 py-1 rounded-full" style="color: var(--color-forest); opacity: 0.7; border: 1px solid rgba(0,209,178,0.25);">SatOps</span>
              <span class="font-mono text-[9px] uppercase tracking-[0.08em] px-2.5 py-1 rounded-full" style="color: var(--color-forest); opacity: 0.7; border: 1px solid rgba(0,209,178,0.25);">NetOps</span>
              <span class="font-mono text-[9px] uppercase tracking-[0.08em] px-2.5 py-1 rounded-full" style="color: var(--color-forest); opacity: 0.7; border: 1px solid rgba(0,209,178,0.25);">IoTOps</span>
            </div>
            <span class="inline-flex items-center mt-6 font-mono text-xs uppercase tracking-wider transition-colors duration-200 group-hover:opacity-80" style="color: var(--color-forest);">
              Explore xOps <span class="ml-2 transition-transform duration-200 group-hover:translate-x-1">&rarr;</span>
            </span>
          </div>
          <!-- Right: Video -->
          <div class="relative" style="border-left: 1px solid rgba(0,0,0,0.06);">
            <div class="flex items-center gap-1.5 px-4 py-2" style="background: rgba(0,0,0,0.02); border-bottom: 1px solid rgba(0,0,0,0.06);">
              <span class="w-1.5 h-1.5 rounded-full" style="background: rgba(0,0,0,0.12);"></span>
              <span class="w-1.5 h-1.5 rounded-full" style="background: rgba(0,0,0,0.12);"></span>
              <span class="w-1.5 h-1.5 rounded-full" style="background: rgba(0,0,0,0.12);"></span>
              <span class="ml-2 font-mono text-[8px] tracking-wider" style="color: rgba(0,0,0,0.25);">xOps Dashboard</span>
            </div>
            <video
              autoplay
              loop
              muted
              playsinline
              class="w-full h-auto block"
              poster="/images/platform-screenshot.png"
            >
              <source src="/videos/xops-demo.mp4" type="video/mp4" />
            </video>
          </div>
        </div>
      </a>

      <!-- Intelligence pillars card — clustered under xOps -->
      <div class="mb-16 lg:mb-20 fade-up rounded-2xl overflow-hidden" style="background: #ffffff; box-shadow: 0 4px 24px rgba(0,0,0,0.06), 0 0 0 1px rgba(0,0,0,0.04);">
        <div class="p-8 lg:p-10 xl:p-12 grid grid-cols-1 sm:grid-cols-2 gap-y-10 gap-x-10 lg:gap-x-14">
          <div>
            <svg class="w-7 h-7 mb-4" style="color: var(--color-forest);" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 12.75 11.25 15 15 9.75m-3-7.036A11.959 11.959 0 0 1 3.598 6 11.99 11.99 0 0 0 3 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285Z" />
            </svg>
            <h3 class="font-sans font-semibold text-lg tracking-tight mb-2" style="color: #1c1917;">
              Real-time visibility
            </h3>
            <p class="font-sans text-sm leading-relaxed" style="color: #78716c;">
              8,000+ integrations across 1,000+ vendors. Every signal validated, enriched, and contextualized. One screen instead of fifteen. Real-time instead of yesterday's report.
            </p>
          </div>
          <div>
            <svg class="w-7 h-7 mb-4" style="color: var(--color-forest);" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M7.217 10.907a2.25 2.25 0 1 0 0 2.186m0-2.186c.18.324.283.696.283 1.093s-.103.77-.283 1.093m0-2.186 9.566-5.314m-9.566 7.5 9.566 5.314m0 0a2.25 2.25 0 1 0 3.935 2.186 2.25 2.25 0 0 0-3.935-2.186Zm0-12.814a2.25 2.25 0 1 0 3.933-2.185 2.25 2.25 0 0 0-3.933 2.185Z" />
            </svg>
            <h3 class="font-sans font-semibold text-lg tracking-tight mb-2" style="color: #1c1917;">
              Predictive intelligence
            </h3>
            <p class="font-sans text-sm leading-relaxed" style="color: #78716c;">
              Domain-trained intelligence models forecast failures before they happen. Automated root cause analysis. Intelligence grounded in your operational reality — not generic AI guesses.
            </p>
          </div>
          <div>
            <svg class="w-7 h-7 mb-4" style="color: var(--color-forest);" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="m3.75 13.5 10.5-11.25L12 10.5h8.25L9.75 21.75 12 13.5H3.75Z" />
            </svg>
            <h3 class="font-sans font-semibold text-lg tracking-tight mb-2" style="color: #1c1917;">
              Governed autonomous action
            </h3>
            <p class="font-sans text-sm leading-relaxed" style="color: #78716c;">
              Cross the gap from copilot to autonomous operations. Every action bounded, auditable, and provably correct. Full accountability from data through reasoning through action.
            </p>
          </div>
          <div>
            <svg class="w-7 h-7 mb-4" style="color: var(--color-forest);" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6h4.5m4.5 0a9 9 0 1 1-18 0 9 9 0 0 1 18 0Z" />
            </svg>
            <h3 class="font-sans font-semibold text-lg tracking-tight mb-2" style="color: #1c1917;">
              Intelligence compounds
            </h3>
            <p class="font-sans text-sm leading-relaxed" style="color: #78716c;">
              Each new system you connect makes every other system smarter. Production-grade intelligence in weeks, not quarters. Deploy cloud, hybrid, or air-gapped.
            </p>
          </div>
        </div>
      </div>

      <p class="font-mono text-xs uppercase tracking-[0.1em] mb-10 fade-up" style="color: var(--color-forest);">Results in Production</p>
      <div class="space-y-0 fade-up">
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-6 lg:gap-12 py-10 lg:py-12" style="border-top: 1px solid var(--color-structure);">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 shrink-0" style="color: var(--color-forest);" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M8.288 15.038a5.25 5.25 0 0 1 7.424 0M5.106 11.856c3.807-3.808 9.98-3.808 13.788 0M1.924 8.674c5.565-5.565 14.587-5.565 20.152 0M12.53 18.22l-.53.53-.53-.53a.75.75 0 0 1 1.06 0Z" />
            </svg>
            <p class="font-mono text-xs uppercase tracking-[0.1em]" style="color: var(--color-forest);">National Communications Provider</p>
          </div>
          <p class="font-sans text-lg lg:text-xl leading-relaxed" style="color: var(--color-neutral-600);">
            98% of infrastructure unified on one operational view. 5,000+ devices. Siloed tools and manual workflows replaced with real-time unified operations.
          </p>
        </div>
        <div class="grid grid-cols-1 lg:grid-cols-[1fr_2fr] gap-6 lg:gap-12 py-10 lg:py-12" style="border-top: 1px solid var(--color-structure);">
          <div class="flex items-center gap-3">
            <svg class="w-5 h-5 shrink-0" style="color: var(--color-forest);" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" d="M5.25 14.25h13.5m-13.5 0a3 3 0 0 1-3-3m3 3a3 3 0 1 0 0 6h13.5a3 3 0 1 0 0-6m-16.5-3a3 3 0 0 1 3-3h13.5a3 3 0 0 1 3 3m-19.5 0a4.5 4.5 0 0 1 .9-2.7L5.737 5.1a3.375 3.375 0 0 1 2.7-1.35h7.126c1.062 0 2.062.5 2.7 1.35l2.587 3.45a4.5 4.5 0 0 1 .9 2.7m0 0a3 3 0 0 1-3 3m0 3h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Zm-3 6h.008v.008h-.008v-.008Zm0-6h.008v.008h-.008v-.008Z" />
            </svg>
            <p class="font-mono text-xs uppercase tracking-[0.1em]" style="color: var(--color-forest);">National Infrastructure Operator</p>
          </div>
          <p class="font-sans text-lg lg:text-xl leading-relaxed" style="color: var(--color-neutral-600);">
            14,000 elements. 7,000 services. Equipment provisioning reduced from months to weeks. Critical event procedures from months of development to hours.
          </p>
        </div>
