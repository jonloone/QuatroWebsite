---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import Hero from '@/components/marketing/Hero.astro'
import Section from '@/components/marketing/Section.astro'
import DualCta from '@/components/marketing/DualCta.astro'
import Placeholder from '@/components/marketing/Placeholder.astro'
---

<MarketingLayout
  title="About — Our Mission, Vision & Values"
  description="Learn about Quatro's mission to deliver industrial intelligence at the speed of operations."
>
  <Hero
    eyebrow="About Quatro"
    title="Industrial Intelligence at the Speed of Operations"
    description="We're building the platform that unifies OT and IT, enabling organizations to see, understand, and orchestrate their most critical operations."
  />

  <Section>
    <div class="grid gap-12 lg:grid-cols-2">
      <div>
        <h2 class="font-display text-2xl font-bold text-neutral-800">Our Mission</h2>
        <p class="mt-4 text-lg text-neutral-600">
          To deliver industrial intelligence that enables organizations to see everything, act faster, and orchestrate with confidence.
        </p>
      </div>
      <Placeholder label="Company Image" class="min-h-[300px]" />
    </div>
  </Section>

  <DualCta
    title={`See what <span style="color: var(--color-forest);">operational intelligence</span> looks like for your operation.`}
    description="Pick one challenge. We deploy on your systems in 4 weeks. You see the value before you commit."
    primaryCta={{ label: 'Schedule an Assessment', href: '/contact/demo' }}
    secondaryCta={{ label: 'Talk to an Engineer', href: '/contact/sales' }}
    microcopy="4-week proof of value · Credited toward annual contract"
  />
</MarketingLayout>
