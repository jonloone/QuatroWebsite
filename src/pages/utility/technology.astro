---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import HeroCanvas from '@/components/marketing/HeroCanvas.astro'
import Section from '@/components/marketing/Section.astro'
import DualCta from '@/components/marketing/DualCta.astro'

const accountabilityChain = [
  { question: 'Is the data trustworthy?', answer: 'Governed data products with quality SLOs, lineage, access policies, and semantic contracts.', layer: 'DataOS' },
  { question: 'What does the data mean?', answer: 'Ontology, semantic modeling, controlled vocabulary, and entity resolution — shared across every model and agent.', layer: 'DataOS' },
  { question: 'What intelligence does it produce?', answer: 'Domain-trained reasoning models operating on the governed semantic substrate — not general-purpose LLMs guessing.', layer: 'ECR + Partners' },
  { question: 'Is the reasoning sound?', answer: 'Model pinning, behavioral regression testing, and deterministic execution for logic and math.', layer: 'Second Wind' },
  { question: 'Is the action governed?', answer: 'Execution contracts — signed, scoped, and time-bounded. Immutable compiled governance that prompts cannot override.', layer: 'Second Wind' },
  { question: 'Can we prove what happened?', answer: 'Run manifests — cryptographic proof linking data → reasoning → action → outcome.', layer: 'Second Wind' },
  { question: 'Does it work behind our firewall?', answer: 'Sovereign on-host execution, air-gapped deployment, local model arbitrage. Your data never leaves your control.', layer: 'All layers' },
]
---

<MarketingLayout
  title="Technology — The Three Body Problem of Enterprise Intelligence"
  description="Analytics, predictions, and operations run as three disconnected worlds. The intelligence utility is the operating model that unifies them — built on a governed semantic substrate, composable open-source compute, and six purpose-built layers from sensor to autonomous action."
>
  <HeroCanvas
    badge="Technology"
    title="The Three Body Problem of Enterprise Intelligence."
    body="Analytics knows what happened. Predictions know what will happen. Operations reacts in real time. But they don't talk to each other — and your team pays the price every shift. The intelligence utility is the operating model that finally unifies all three into a single execution surface."
    ctaLabel="Talk to an Engineer"
    ctaHref="/contact/sales"
  />

  <!-- Strategic partners — full-width white bar below hero (real SVG logos only) -->
  <section class="py-6 lg:py-8" style="background: #ffffff;">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 fade-up">
      <p class="font-mono text-[9px] uppercase tracking-[0.14em] text-center mb-5" style="color: var(--color-neutral-400);">Strategic partners</p>
      <div class="flex flex-wrap items-center justify-center gap-10 lg:gap-16">
        <img src="/images/partners/dataminer.svg" alt="DataMiner by Skyline" class="h-7 w-auto" style="opacity: 0.6;" />
        <img src="/images/partners/dataos.svg" alt="DataOS by Modern" class="h-5 w-auto" style="color: var(--color-neutral-800); opacity: 0.6;" />
        <img src="/images/partners/ecr.svg" alt="Edge Case Research" class="h-8 w-auto" style="color: var(--color-neutral-800); opacity: 0.6;" />
      </div>
    </div>
  </section>

  <!-- The Stakes — what continues to go wrong when three worlds stay disconnected -->
  <section class="py-16 lg:py-24" style="background: var(--color-paper);">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-16">

        <!-- Left: structural framing -->
        <div class="lg:col-span-5">
          <p class="font-mono text-[10px] uppercase tracking-[0.12em] fade-up" style="color: var(--color-neutral-400);">
            The cost of disconnection
          </p>
          <h2 class="mt-4 font-sans font-light text-2xl sm:text-3xl lg:text-4xl leading-[1.15] tracking-tight fade-up" style="color: var(--color-neutral-800);">
            When analytics, predictions, and operations run as <span style="color: var(--color-forest);">three separate worlds</span> — the gaps become invisible until they're expensive.
          </h2>
        </div>

        <!-- Right: specific failure modes -->
        <div class="lg:col-span-7">
          <div class="space-y-6 lg:pt-10">
            <div class="fade-up">
              <h3 class="font-display text-base font-bold" style="color: var(--color-neutral-800);">Cascade failures detected after impact, not before</h3>
              <p class="mt-2 text-sm leading-relaxed" style="color: var(--color-neutral-500);">
                Predictive models see the pattern. Operations sees the alarm. But they're in different systems with different timelines. By the time someone correlates them manually, four million people have already lost power — or a satellite has already missed its window.
              </p>
            </div>

            <div class="fade-up">
              <h3 class="font-display text-base font-bold" style="color: var(--color-neutral-800);">SLA breaches nobody saw coming</h3>
              <p class="mt-2 text-sm leading-relaxed" style="color: var(--color-neutral-500);">
                Customer impact doesn't live in one system. It's scattered across ticketing, provisioning, network management, and billing. When those systems don't share a model, SLA violations surface in quarterly reviews — months after the revenue leaked.
              </p>
            </div>

            <div class="fade-up">
              <h3 class="font-display text-base font-bold" style="color: var(--color-neutral-800);">Compliance gaps that surface in audits, not operations</h3>
              <p class="mt-2 text-sm leading-relaxed" style="color: var(--color-neutral-500);">
                Regulatory evidence is assembled manually from disconnected sources. The data exists to prove compliance — but it takes weeks to collect it, and the connections between events, actions, and outcomes can't be traced because they were never modeled together.
              </p>
            </div>

            <div class="fade-up">
              <h3 class="font-display text-base font-bold" style="color: var(--color-neutral-800);">Intelligence that expires before it reaches the people who need it</h3>
              <p class="mt-2 text-sm leading-relaxed" style="color: var(--color-neutral-500);">
                Analytics produces an insight. By the time it's exported, reformatted, and presented to operations, the operational context has changed. The insight was right when it was generated. It's wrong by the time someone acts on it.
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- The 6-layer stack overview -->
  <section class="py-20 lg:py-28" style="background: #0a0a0a; border-top: 1px solid rgba(255,255,255,0.06);">
    <div class="absolute inset-0 opacity-[0.03] pointer-events-none" style="background-image: url('data:image/svg+xml,%3Csvg viewBox=%270 0 256 256%27 xmlns=%27http://www.w3.org/2000/svg%27%3E%3Cfilter id=%27noise%27%3E%3CfeTurbulence type=%27fractalNoise%27 baseFrequency=%270.65%27 numOctaves=%273%27 stitchTiles=%27stitch%27/%3E%3C/filter%3E%3Crect width=%27100%25%27 height=%27100%25%27 filter=%27url(%23noise)%27/%3E%3C/svg%3E');"></div>

    <div class="mx-auto max-w-7xl px-6 lg:px-8 relative">
      <div class="mb-8 fade-up" style="padding: 16px 20px; background: rgba(0,209,178,0.08); border-left: 3px solid rgba(0,209,178,0.4); border-radius: 6px;">
        <p class="font-mono text-[9px] uppercase tracking-[0.14em]" style="color: rgba(0,209,178,0.6); margin: 0;">For Technical Teams</p>
        <p class="text-sm leading-relaxed mt-2" style="color: rgba(255,255,255,0.6); margin: 0;">The architecture below explains how the semantic substrate, governance layers, and reasoning models work together. Not all visitors need this level of detail — if you're evaluating outcomes rather than implementation, skip to the use cases below.</p>
      </div>

      <p class="font-mono text-[10px] uppercase tracking-[0.12em] text-white/30 mb-4 fade-up">
        How the operating model delivers
      </p>
      <h2 class="font-display text-2xl font-bold tracking-tight text-white/90 sm:text-3xl mb-4 fade-up">
        From raw data to autonomous action.
      </h2>
      <p class="text-base leading-relaxed text-white/40 max-w-3xl mb-16 fade-up">
        Your systems connect into a shared operational model. The model produces meaning, reasoning, and governed action — closing the loop between knowing and doing.
      </p>

      <!-- ===== VERTICAL ARCHITECTURE DIAGRAM — Desktop ===== -->
      <div class="fade-up hidden lg:block">
        <svg class="w-full h-auto" viewBox="0 0 900 920" fill="none" xmlns="http://www.w3.org/2000/svg">
          <defs>
            <!-- Color-coded glow filters -->
            <filter id="glow-blue" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="6" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <filter id="glow-green" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="8" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <filter id="glow-amber" x="-50%" y="-50%" width="200%" height="200%">
              <feGaussianBlur stdDeviation="5" result="blur"/>
              <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
            </filter>
            <!-- Gradient for connect bar -->
            <linearGradient id="grad-connect" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="rgba(96,165,250,0)"/>
              <stop offset="20%" stop-color="rgba(96,165,250,0.12)"/>
              <stop offset="80%" stop-color="rgba(96,165,250,0.12)"/>
              <stop offset="100%" stop-color="rgba(96,165,250,0)"/>
            </linearGradient>
            <!-- Gradient for intelligence plane -->
            <linearGradient id="grad-intel" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="rgba(251,191,36,0)"/>
              <stop offset="15%" stop-color="rgba(251,191,36,0.06)"/>
              <stop offset="85%" stop-color="rgba(251,191,36,0.06)"/>
              <stop offset="100%" stop-color="rgba(251,191,36,0)"/>
            </linearGradient>
            <!-- Gradient for govern bar -->
            <linearGradient id="grad-govern" x1="0" y1="0" x2="1" y2="0">
              <stop offset="0%" stop-color="rgba(0,209,178,0)"/>
              <stop offset="20%" stop-color="rgba(0,209,178,0.1)"/>
              <stop offset="80%" stop-color="rgba(0,209,178,0.1)"/>
              <stop offset="100%" stop-color="rgba(0,209,178,0)"/>
            </linearGradient>
          </defs>

          <style>
            @keyframes tech-flow { 0% { stroke-dashoffset: 0; } 100% { stroke-dashoffset: -20; } }
            @keyframes tech-pulse { 0%, 100% { opacity: 0.3; } 50% { opacity: 1; } }
            @keyframes node-breathe { 0%, 100% { r: 5; opacity: 0.6; } 50% { r: 6; opacity: 1; } }
            .tech-flow { animation: tech-flow 1.5s linear infinite; }
            .tech-pulse { animation: tech-pulse 2.5s ease-in-out infinite; }
            .node-breathe { animation: node-breathe 3s ease-in-out infinite; }
          </style>

          <!-- ════════════════════════════════════════ -->
          <!-- LAYER 1 — YOUR SYSTEMS (top, blue-gray) -->
          <!-- ════════════════════════════════════════ -->
          <text x="450" y="24" text-anchor="middle" fill="rgba(148,163,184,0.5)" font-family="monospace" font-size="11" font-weight="bold" letter-spacing="0.15em">YOUR SYSTEMS</text>

          <!-- Source system pills — horizontal row -->
          <rect x="60"  y="42" rx="8" ry="8" width="115" height="38" fill="rgba(148,163,184,0.06)" stroke="rgba(148,163,184,0.18)" stroke-width="1.5"/>
          <text x="117" y="66" text-anchor="middle" fill="rgba(148,163,184,0.55)" font-family="monospace" font-size="10" font-weight="bold">SCADA / OT</text>

          <rect x="190" y="42" rx="8" ry="8" width="115" height="38" fill="rgba(148,163,184,0.06)" stroke="rgba(148,163,184,0.18)" stroke-width="1.5"/>
          <text x="247" y="66" text-anchor="middle" fill="rgba(148,163,184,0.55)" font-family="monospace" font-size="10" font-weight="bold">NMS / OSS</text>

          <rect x="320" y="42" rx="8" ry="8" width="115" height="38" fill="rgba(148,163,184,0.06)" stroke="rgba(148,163,184,0.18)" stroke-width="1.5"/>
          <text x="377" y="66" text-anchor="middle" fill="rgba(148,163,184,0.55)" font-family="monospace" font-size="10" font-weight="bold">IoT / Sensors</text>

          <rect x="450" y="42" rx="8" ry="8" width="115" height="38" fill="rgba(148,163,184,0.06)" stroke="rgba(148,163,184,0.18)" stroke-width="1.5"/>
          <text x="507" y="66" text-anchor="middle" fill="rgba(148,163,184,0.55)" font-family="monospace" font-size="10" font-weight="bold">CRM / ERP</text>

          <rect x="580" y="42" rx="8" ry="8" width="115" height="38" fill="rgba(148,163,184,0.06)" stroke="rgba(148,163,184,0.18)" stroke-width="1.5"/>
          <text x="637" y="66" text-anchor="middle" fill="rgba(148,163,184,0.55)" font-family="monospace" font-size="10" font-weight="bold">Ticketing</text>

          <rect x="710" y="42" rx="8" ry="8" width="130" height="38" fill="rgba(148,163,184,0.06)" stroke="rgba(148,163,184,0.18)" stroke-width="1.5"/>
          <text x="775" y="66" text-anchor="middle" fill="rgba(148,163,184,0.55)" font-family="monospace" font-size="10" font-weight="bold">Satellite / RF</text>

          <!-- Converging flow lines down to connect bar -->
          <line x1="117" y1="80" x2="300" y2="114" stroke="rgba(96,165,250,0.15)" stroke-width="1" stroke-dasharray="4,4" class="tech-flow"/>
          <line x1="247" y1="80" x2="350" y2="114" stroke="rgba(96,165,250,0.2)" stroke-width="1" stroke-dasharray="4,4" class="tech-flow" style="animation-delay:0.15s"/>
          <line x1="377" y1="80" x2="420" y2="114" stroke="rgba(96,165,250,0.2)" stroke-width="1" stroke-dasharray="4,4" class="tech-flow" style="animation-delay:0.3s"/>
          <line x1="507" y1="80" x2="480" y2="114" stroke="rgba(96,165,250,0.2)" stroke-width="1" stroke-dasharray="4,4" class="tech-flow" style="animation-delay:0.45s"/>
          <line x1="637" y1="80" x2="550" y2="114" stroke="rgba(96,165,250,0.2)" stroke-width="1" stroke-dasharray="4,4" class="tech-flow" style="animation-delay:0.6s"/>
          <line x1="775" y1="80" x2="600" y2="114" stroke="rgba(96,165,250,0.15)" stroke-width="1" stroke-dasharray="4,4" class="tech-flow" style="animation-delay:0.75s"/>

          <!-- ════════════════════════════════════════ -->
          <!-- LAYER 2 — CONNECT (blue bar)            -->
          <!-- ════════════════════════════════════════ -->
          <rect x="100" y="110" rx="12" ry="12" width="700" height="56" fill="url(#grad-connect)" stroke="rgba(96,165,250,0.3)" stroke-width="1.5"/>
          <text x="450" y="135" text-anchor="middle" fill="rgba(96,165,250,0.9)" font-family="monospace" font-size="14" font-weight="bold" letter-spacing="0.1em">CONNECT</text>
          <text x="450" y="153" text-anchor="middle" fill="rgba(96,165,250,0.4)" font-family="monospace" font-size="10">8,000+ protocol connectors · real-time ingestion · streaming &amp; batch</text>

          <!-- Arrow down from Connect -->
          <line x1="450" y1="166" x2="450" y2="200" stroke="rgba(96,165,250,0.25)" stroke-width="2" stroke-dasharray="4,4" class="tech-flow"/>
          <circle cx="450" cy="183" r="3" fill="rgba(96,165,250,0.6)" class="tech-pulse"/>

          <!-- ════════════════════════════════════════════════════ -->
          <!-- LAYER 3 — OPERATIONAL MODEL (large, green, complex) -->
          <!-- ════════════════════════════════════════════════════ -->
          <rect x="80" y="200" rx="16" ry="16" width="740" height="340" fill="rgba(15,76,58,0.05)" stroke="rgba(15,76,58,0.35)" stroke-width="2"/>
          <!-- Inner border for depth -->
          <rect x="92" y="212" rx="12" ry="12" width="716" height="316" fill="none" stroke="rgba(15,76,58,0.12)" stroke-width="1" stroke-dasharray="2,6"/>

          <!-- Title -->
          <text x="450" y="240" text-anchor="middle" fill="rgba(15,76,58,0.9)" font-family="monospace" font-size="16" font-weight="bold" letter-spacing="0.12em">OPERATIONAL MODEL</text>
          <text x="450" y="258" text-anchor="middle" fill="rgba(15,76,58,0.45)" font-family="monospace" font-size="10">The semantic substrate — ontology, knowledge graph, process rules, governance</text>

          <!-- ── Rich Ontology Network (center of model) ── -->
          <!-- Primary entity nodes (large, labeled) -->
          <circle cx="230" cy="320" r="22" fill="rgba(15,76,58,0.12)" stroke="rgba(15,76,58,0.5)" stroke-width="2"/>
          <text x="230" y="324" text-anchor="middle" fill="rgba(15,76,58,0.8)" font-family="monospace" font-size="8" font-weight="bold">Device</text>

          <circle cx="380" cy="295" r="22" fill="rgba(15,76,58,0.12)" stroke="rgba(15,76,58,0.5)" stroke-width="2"/>
          <text x="380" y="299" text-anchor="middle" fill="rgba(15,76,58,0.8)" font-family="monospace" font-size="8" font-weight="bold">Service</text>

          <circle cx="530" cy="310" r="22" fill="rgba(15,76,58,0.12)" stroke="rgba(15,76,58,0.5)" stroke-width="2"/>
          <text x="530" y="314" text-anchor="middle" fill="rgba(15,76,58,0.8)" font-family="monospace" font-size="8" font-weight="bold">Customer</text>

          <circle cx="670" cy="320" r="22" fill="rgba(15,76,58,0.12)" stroke="rgba(15,76,58,0.5)" stroke-width="2"/>
          <text x="670" y="324" text-anchor="middle" fill="rgba(15,76,58,0.8)" font-family="monospace" font-size="8" font-weight="bold">Location</text>

          <circle cx="300" cy="400" r="20" fill="rgba(15,76,58,0.1)" stroke="rgba(15,76,58,0.4)" stroke-width="1.5"/>
          <text x="300" y="404" text-anchor="middle" fill="rgba(15,76,58,0.7)" font-family="monospace" font-size="8" font-weight="bold">Alarm</text>

          <circle cx="450" cy="380" r="24" fill="rgba(15,76,58,0.15)" stroke="rgba(15,76,58,0.6)" stroke-width="2"/>
          <text x="450" y="376" text-anchor="middle" fill="rgba(15,76,58,0.9)" font-family="monospace" font-size="7" font-weight="bold">Process</text>
          <text x="450" y="388" text-anchor="middle" fill="rgba(15,76,58,0.9)" font-family="monospace" font-size="7" font-weight="bold">Ontology</text>

          <circle cx="590" cy="405" r="20" fill="rgba(15,76,58,0.1)" stroke="rgba(15,76,58,0.4)" stroke-width="1.5"/>
          <text x="590" y="409" text-anchor="middle" fill="rgba(15,76,58,0.7)" font-family="monospace" font-size="8" font-weight="bold">KPI</text>

          <circle cx="180" cy="420" r="16" fill="rgba(15,76,58,0.08)" stroke="rgba(15,76,58,0.3)" stroke-width="1"/>
          <text x="180" y="424" text-anchor="middle" fill="rgba(15,76,58,0.6)" font-family="monospace" font-size="7" font-weight="bold">Circuit</text>

          <circle cx="720" cy="410" r="16" fill="rgba(15,76,58,0.08)" stroke="rgba(15,76,58,0.3)" stroke-width="1"/>
          <text x="720" y="414" text-anchor="middle" fill="rgba(15,76,58,0.6)" font-family="monospace" font-size="7" font-weight="bold">Metric</text>

          <!-- Secondary satellite nodes (small, unlabeled) -->
          <circle cx="155" cy="345" r="5" fill="rgba(15,76,58,0.15)" stroke="rgba(15,76,58,0.3)" stroke-width="1" class="node-breathe"/>
          <circle cx="280" cy="460" r="4" fill="rgba(15,76,58,0.12)" stroke="rgba(15,76,58,0.25)" stroke-width="1" class="node-breathe" style="animation-delay:0.5s"/>
          <circle cx="500" cy="460" r="5" fill="rgba(15,76,58,0.12)" stroke="rgba(15,76,58,0.25)" stroke-width="1" class="node-breathe" style="animation-delay:1s"/>
          <circle cx="650" cy="450" r="4" fill="rgba(15,76,58,0.1)" stroke="rgba(15,76,58,0.2)" stroke-width="1" class="node-breathe" style="animation-delay:1.5s"/>
          <circle cx="760" cy="360" r="5" fill="rgba(15,76,58,0.1)" stroke="rgba(15,76,58,0.2)" stroke-width="1" class="node-breathe" style="animation-delay:2s"/>
          <circle cx="140" cy="390" r="4" fill="rgba(15,76,58,0.08)" stroke="rgba(15,76,58,0.18)" stroke-width="1"/>
          <circle cx="350" cy="470" r="3" fill="rgba(15,76,58,0.08)" stroke="rgba(15,76,58,0.18)" stroke-width="1"/>
          <circle cx="430" cy="450" r="4" fill="rgba(15,76,58,0.1)" stroke="rgba(15,76,58,0.2)" stroke-width="1"/>
          <circle cx="770" cy="430" r="3" fill="rgba(15,76,58,0.08)" stroke="rgba(15,76,58,0.15)" stroke-width="1"/>

          <!-- Relationship edges (labeled) -->
          <!-- Device → Service: "serves" -->
          <line x1="252" y1="318" x2="358" y2="297" stroke="rgba(15,76,58,0.25)" stroke-width="1.5"/>
          <text x="300" y="300" text-anchor="middle" fill="rgba(15,76,58,0.45)" font-family="monospace" font-size="7" transform="rotate(-8 300 300)">serves</text>

          <!-- Service → Customer: "delivers" -->
          <line x1="402" y1="295" x2="508" y2="310" stroke="rgba(15,76,58,0.25)" stroke-width="1.5"/>
          <text x="455" y="296" text-anchor="middle" fill="rgba(15,76,58,0.45)" font-family="monospace" font-size="7">delivers</text>

          <!-- Customer → Location: "at" -->
          <line x1="552" y1="315" x2="648" y2="320" stroke="rgba(15,76,58,0.2)" stroke-width="1.5"/>
          <text x="600" y="310" text-anchor="middle" fill="rgba(15,76,58,0.4)" font-family="monospace" font-size="7">at</text>

          <!-- Device → Alarm: "triggers" -->
          <line x1="230" y1="342" x2="300" y2="380" stroke="rgba(15,76,58,0.2)" stroke-width="1.2"/>
          <text x="256" y="368" text-anchor="middle" fill="rgba(15,76,58,0.4)" font-family="monospace" font-size="7" transform="rotate(25 256 368)">triggers</text>

          <!-- Alarm → Process Ontology: "escalates" -->
          <line x1="320" y1="400" x2="426" y2="384" stroke="rgba(15,76,58,0.2)" stroke-width="1.2"/>
          <text x="370" y="386" text-anchor="middle" fill="rgba(15,76,58,0.4)" font-family="monospace" font-size="7">escalates</text>

          <!-- Service → Process Ontology: "governed by" -->
          <line x1="380" y1="317" x2="445" y2="356" stroke="rgba(15,76,58,0.2)" stroke-width="1.2"/>
          <text x="402" y="340" text-anchor="middle" fill="rgba(15,76,58,0.4)" font-family="monospace" font-size="7" transform="rotate(30 402 340)">governed by</text>

          <!-- Customer → KPI: "measured by" -->
          <line x1="535" y1="332" x2="585" y2="385" stroke="rgba(15,76,58,0.2)" stroke-width="1.2"/>
          <text x="568" y="360" text-anchor="middle" fill="rgba(15,76,58,0.4)" font-family="monospace" font-size="7" transform="rotate(45 568 360)">measured by</text>

