---
import MarketingLayout from '@/layouts/MarketingLayout.astro'
import HeroCanvas from '@/components/marketing/HeroCanvas.astro'
import Section from '@/components/marketing/Section.astro'
import EditorialOutcome from '@/components/marketing/EditorialOutcome.astro'
import CapabilityIndex from '@/components/marketing/CapabilityIndex.astro'
import DualCta from '@/components/marketing/DualCta.astro'
import IntelligenceRails from '@/components/ui/IntelligenceRails'

const deliveryMechanisms = [
  {
    name: 'Workflows your team runs',
    description: 'Adaptive operational applications that emerge from your data model — not rigid SaaS modules designed for someone else\'s workflow. Asset management, monitoring, orchestration, service assurance — each application molds to how your operations actually run and evolves as they change.',
    outcome: 'An adaptive xOps suite that shapes itself to your operations — not the other way around.',
  },
  {
    name: 'Agents that reason across your systems',
    description: 'AI agents that don\'t just answer questions — they reason against your operational model, correlate across data sources, and surface what matters. Grounded in your governed data, not generic training sets.',
    outcome: 'Domain-trained intelligence that understands your operations, not just your documents.',
  },
  {
    name: 'Automations that execute governed actions',
    description: 'When the model identifies a condition that requires action, governed automations execute it — with audit trails, execution contracts, and deterministic repeatability. As your operational model deepens, new automations unlock automatically. Every action is attributable and reversible.',
    outcome: 'Autonomous operations that expand as your model matures — with the governance regulated industries require.',
  },
  {
    name: 'APIs that feed intelligence back',
    description: 'Intelligence doesn\'t stay locked in Quatro. APIs deliver operational intelligence back into the tools your team already uses — BI platforms, ticketing systems, ERPs, custom applications. The model feeds everywhere.',
    outcome: 'Intelligence compounds across your entire technology stack, not just inside one tool.',
  },
]

const exampleOutputs = [
  { category: 'Energy', output: 'Pipeline integrity scoring across 12 monitoring systems, with automated compliance reporting' },
  { category: 'Defense', output: 'Multi-domain awareness from sovereign sensors to command-level decision support' },
  { category: 'Telecom', output: 'NOC unification across terrestrial, satellite, and hybrid networks in one operational view' },
  { category: 'Infrastructure', output: 'Water system health across SCADA, GIS, and IoT — with predictive leak detection' },
  { category: 'Finance', output: 'Cross-system risk correlation from trading floors to compliance reporting' },
  { category: 'Smart Cities', output: 'Municipal operations from traffic to waste to public safety — connected in one model' },
]
---

<MarketingLayout
  title="What You Get — The Intelligence Utility"
  description="Workflows your team runs. Agents that reason across your systems. Automations that execute governed actions. APIs that feed intelligence back into the tools you already use."
>
  <HeroCanvas
    badge="What You Get"
    title="Concrete Intelligence. Not Abstract Promises."
    body="Workflows your team runs. Agents that reason across your systems. Automations that execute governed actions. APIs that feed intelligence back into the tools you already use. The more you connect, the smarter everything gets."
    ctaLabel="See It On Your Systems"
    ctaHref="/contact/demo"
  />

  <!-- Editorial lead-in -->
  <EditorialOutcome
    statement={`What flows back is <span style="color: var(--color-forest);">concrete.</span>`}
    description="The intelligence utility doesn't deliver dashboards and reports. It gives your team the operational applications, reasoning agents, governed automations, and APIs they need to act — not just to look. Every output is grounded in your governed operational model."
  />

  <!-- The four delivery mechanisms — dark indexed section -->
  <CapabilityIndex
    title="Four delivery mechanisms"
    capabilities={deliveryMechanisms}
  />

  <!-- Visual: Data Product → Intelligence Rails → Governed Outputs -->
  <Section>
    <div class="mx-auto max-w-7xl">
      <div class="mb-10">
        <p class="font-mono text-[10px] uppercase tracking-[0.12em] fade-up" style="color: var(--color-neutral-400);">
          From model to action
        </p>
        <h2 class="mt-4 font-display text-2xl font-bold tracking-tight sm:text-3xl fade-up" style="color: var(--color-neutral-800);">
          Start with what your team needs. We connect what makes it possible.
        </h2>
        <p class="mt-4 max-w-3xl text-base leading-relaxed fade-up" style="color: var(--color-neutral-500);">
          Between your systems and the outcomes your team works from sits one operational model — governed, compounding, and connected to everything. It knows what exists, what matters, what should happen, and what's allowed.
        </p>
      </div>

      <!-- Intelligence Rails — interactive React component -->
      <div class="rounded-xl p-6 lg:p-10 fade-up" style="background: #f5f5f4; border: 1px solid #e7e5e4;">
        <IntelligenceRails client:visible />
      </div>
    </div>
  </Section>

  <!-- xOps in action — capabilities from your data, not more SaaS tools -->
  <section class="py-16 lg:py-24" style="background: #0a0a0a;">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 items-center">
        <!-- Left: video -->
        <div class="lg:col-span-7 fade-up">
          <div class="rounded-xl overflow-hidden" style="border: 1px solid rgba(255,255,255,0.08);">
            <video autoplay loop muted playsinline class="w-full h-auto">
              <source src="/videos/xops-demo.mp4" type="video/mp4" />
            </video>
          </div>
        </div>

        <!-- Right: messaging -->
        <div class="lg:col-span-5 fade-up">
          <p class="font-mono text-[10px] uppercase tracking-[0.12em] mb-4" style="color: var(--color-forest);">
            Capabilities from your data
          </p>
          <h3 class="font-sans font-light text-2xl sm:text-3xl tracking-tight text-white/90 leading-tight mb-4">
            Operational capabilities that emerge from the model — not another SaaS tool.
          </h3>
          <p class="text-base leading-relaxed text-white/50 mb-6">
            Every workflow, agent, and automation you see here was generated from the governed data product — not pre-built by a vendor. As your operational model deepens, new capabilities unlock automatically. No feature requests. No rigid modules.
          </p>
          <a
            href="/utility/xops"
            class="inline-flex items-center gap-2 font-mono text-[11px] uppercase tracking-wider transition-colors hover:opacity-80"
            style="color: var(--color-forest);"
          >
            Explore the xOps suite <span class="ml-1">&rarr;</span>
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- xOps callout — the adaptive application layer -->
  <section class="py-12 lg:py-16" style="background: #0a0a0a; border-bottom: 1px solid rgba(255,255,255,0.06);">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <a href="/utility/xops" class="group block p-8 lg:p-10 rounded-xl fade-up transition-all hover:scale-[1.005]" style="background: rgba(15,76,58,0.08); border: 1px solid rgba(15,76,58,0.2);">
        <div class="grid grid-cols-1 lg:grid-cols-12 gap-6 lg:gap-10">
          <div class="lg:col-span-7">
            <p class="font-mono text-[10px] uppercase tracking-[0.12em] mb-3" style="color: var(--color-forest);">The Operations Suite</p>
            <h3 class="font-display text-xl lg:text-2xl font-bold text-white/90 mb-3">
              xOps — adaptive applications that mold to your operations.
            </h3>
            <p class="text-sm leading-relaxed text-white/45 max-w-xl">
              No rigid SaaS modules. No vendor feature requests. The operational model generates the applications your team needs — asset management, monitoring, orchestration, service assurance, AI-powered intelligence — and they evolve as your operations change. As the model deepens, new workflows and automations unlock automatically.
            </p>
          </div>
          <div class="lg:col-span-5 flex items-center">
            <div class="grid grid-cols-2 gap-3 w-full">
              <div class="p-4 rounded-lg text-center" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
                <p class="font-display text-sm font-bold text-white/70">MediaOps</p>
                <p class="mt-1 font-mono text-[9px] text-white/25">Broadcast</p>
              </div>
              <div class="p-4 rounded-lg text-center" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
                <p class="font-display text-sm font-bold text-white/70">GridOps</p>
                <p class="mt-1 font-mono text-[9px] text-white/25">Energy</p>
              </div>
              <div class="p-4 rounded-lg text-center" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
                <p class="font-display text-sm font-bold text-white/70">SatOps</p>
                <p class="mt-1 font-mono text-[9px] text-white/25">Satellite</p>
              </div>
              <div class="p-4 rounded-lg text-center" style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);">
                <p class="font-display text-sm font-bold text-white/70">NetOps</p>
                <p class="mt-1 font-mono text-[9px] text-white/25">Telecom</p>
              </div>
            </div>
          </div>
        </div>
        <p class="mt-6 inline-flex items-center font-mono text-[11px] uppercase tracking-wider transition-colors" style="color: var(--color-forest);">
          Explore the xOps suite <span class="ml-1.5 transition-transform group-hover:translate-x-1">&rarr;</span>
        </p>
      </a>
    </div>
  </section>

  <!-- What this looks like by vertical -->
  <section class="py-20 lg:py-28" style="background: #0a0a0a;">
    <div class="mx-auto max-w-7xl px-6 lg:px-8 relative">
      <p class="font-mono text-[10px] uppercase tracking-[0.12em] text-white/30 mb-4 fade-up">
        Intelligence by domain
      </p>
      <h2 class="font-display text-2xl font-bold tracking-tight text-white/90 sm:text-3xl mb-12 fade-up">
        What the utility looks like in your industry.
      </h2>

      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {exampleOutputs.map((ex) => (
          <div
            class="p-6 rounded-xl fade-up"
            style="background: rgba(255,255,255,0.04); border: 1px solid rgba(255,255,255,0.08);"
          >
            <span class="font-mono text-[10px] uppercase tracking-[0.12em] text-white/20">{ex.category}</span>
            <p class="mt-3 text-sm leading-relaxed text-white/60">{ex.output}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- What makes this possible: the data product -->
  <Section>
    <div class="mx-auto max-w-7xl">
      <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12">
        <div class="lg:col-span-5">
          <p class="font-mono text-[10px] uppercase tracking-[0.12em] fade-up" style="color: var(--color-neutral-400);">
            What powers the output
          </p>
          <h2 class="mt-4 font-display text-2xl font-bold tracking-tight sm:text-3xl fade-up" style="color: var(--color-neutral-800);">
            Every output is built on a governed data product.
          </h2>
          <p class="mt-4 text-base leading-relaxed fade-up" style="color: var(--color-neutral-500);">
            Underneath every workflow, agent, automation, and API is a purpose-built intelligence product — not a raw dataset. It carries its own context: what the data means, who owns it, what quality standards it meets, and how it should be used.
          </p>
        </div>

        <div class="lg:col-span-7">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            {[
              { title: 'Purpose-built', desc: 'Designed for a specific use case, not a generic data dump. Your team defines the outcome — the product is built to serve it.' },
              { title: 'Semantically rich', desc: 'Carries measures, dimensions, relationships, and quality guarantees. Business people define it. The operating model maintains it.' },
              { title: 'Multi-interface', desc: 'Consumable through dashboards, APIs, agent queries, and third-party tools — the same governed truth, multiple consumption paths.' },
              { title: 'Compounds over time', desc: 'Each new data product enriches the whole model. Shared entities, shared context, shared governance — intelligence that grows.' },
            ].map((item) => (
              <div class="p-6 rounded-xl bg-white fade-up" style="border: 1px solid var(--color-structure); box-shadow: 0 1px 3px rgba(15,23,42,0.04);">
                <h3 class="font-display text-base font-bold" style="color: var(--color-neutral-800);">{item.title}</h3>
                <p class="mt-2 text-sm leading-relaxed" style="color: var(--color-neutral-500);">{item.desc}</p>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </Section>

  <!-- The feedback loop -->
  <EditorialOutcome
    statement={`The more you connect, the smarter <span style="color: var(--color-forest);">everything gets.</span>`}
    description="Every workflow executed feeds results back into the operational model. Every agent decision becomes context for the next one. Every automation outcome refines the prediction. This is the intelligence flywheel — and it's real today, not a roadmap item."
    stats={[
      { value: 'Real-time', label: 'Model updates' },
      { value: 'Governed', label: 'Every action' },
      { value: 'Auditable', label: 'Every decision' },
    ]}
  />

  <!-- Navigation to sibling pages -->
  <section class="py-16 lg:py-20" style="border-top: 1px solid var(--color-structure);">
    <div class="mx-auto max-w-7xl px-6 lg:px-8">
      <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
        <a href="/utility" class="group p-8 rounded-xl bg-white transition-all hover:shadow-md fade-up" style="border: 1px solid var(--color-structure);">
          <p class="font-mono text-[10px] uppercase tracking-[0.12em]" style="color: var(--color-forest);">Previous</p>
          <h3 class="mt-3 font-display text-xl font-bold tracking-tight group-hover:text-brand-600" style="color: var(--color-neutral-800);">
            <span class="inline-block transition-transform group-hover:-translate-x-1">&larr;</span>
            What Is It
          </h3>
          <p class="mt-2 text-sm leading-relaxed" style="color: var(--color-neutral-500);">One operational model from every system your operations touch.</p>
        </a>
        <a href="/utility/how-it-starts" class="group p-8 rounded-xl bg-white transition-all hover:shadow-md fade-up" style="border: 1px solid var(--color-structure);">
          <p class="font-mono text-[10px] uppercase tracking-[0.12em]" style="color: var(--color-forest);">Next</p>
          <h3 class="mt-3 font-display text-xl font-bold tracking-tight group-hover:text-brand-600" style="color: var(--color-neutral-800);">
            How It Starts
            <span class="inline-block transition-transform group-hover:translate-x-1">&rarr;</span>
          </h3>
          <p class="mt-2 text-sm leading-relaxed" style="color: var(--color-neutral-500);">You tell us the outcome. We connect the systems. Your team works from the model.</p>
        </a>
      </div>
    </div>
  </section>

  <DualCta
    title={`Tell us the outcome. We connect the <span style="color: var(--color-forest);">systems that hold the answer.</span>`}
    description="Your team starts working from the model. Workflows, agents, automations, and APIs — all from day one."
    primaryCta={{ label: 'Start With an Outcome', href: '/contact/demo' }}
    secondaryCta={{ label: 'Talk to an Engineer', href: '/contact/sales' }}
  />
</MarketingLayout>
